PORT=3000
NODE_ENV=development

DATABASE_URL=mysql://root:@localhost:3306/clipador

# Obrigatória para gerar matéria (https://platform.deepseek.com)
DEEPSEEK_API_KEY=
PEXELS_API_KEY=

# Busca de pautas (opcional; Google News RSS funciona sem chave)
BRAVE_SEARCH_API_KEY=
SERPER_API_KEY=

FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:3000/api/auth/facebook/callback

SESSION_SECRET=troque-por-um-segredo-forte

# Caminho do ffmpeg (opcional se estiver no PATH)
# FFMPEG_PATH=C:\\ffmpeg\\bin\\ffmpeg.exe

# Autenticação yt-dlp/YouTube (não use as duas opções ao mesmo tempo)
# Desenvolvimento local: chrome, edge, firefox, brave, opera ou vivaldi
# YTDLP_COOKIES_FROM_BROWSER=chrome
# Produção: arquivo Netscape cookies.txt fora de public/ e storage/, sempre com caminho absoluto
# YTDLP_COOKIES_FILE=/home/viralizeai/secrets/youtube-cookies.txt

# Extração de fala: Python 3.9+ + faster-whisper
# pip install -r scripts/requirements.txt
# Se `python` não estiver no PATH, aponte o executável:
# PYTHON_PATH=C:\\Python313\\python.exe
PYTHON_PATH=

# YouTube / yt-dlp (produção CloudPanel)
# YTDLP_COOKIES_FILE=/home/viralizeai/secrets/youtube-cookies.txt
# YTDLP_JS_RUNTIME=node:/usr/local/bin/node
# YTDLP_PATH=/usr/local/bin/yt-dlp

# --- Produção (CloudPanel exemplo) ---
# PORT=3010
# NODE_ENV=production
# DATABASE_URL=mysql://clipador:SENHA@127.0.0.1:3306/clipador
# FACEBOOK_REDIRECT_URI=https://www.viralizeai.online/api/auth/facebook/callback
# SESSION_SECRET=gere-um-segredo-longo-aleatorio
