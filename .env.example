PORT=3000
NODE_ENV=development

DATABASE_URL=mysql://root:@localhost:3306/clipador

# Obrigatória para gerar matéria (https://platform.deepseek.com)
DEEPSEEK_API_KEY=
PEXELS_API_KEY=

# Busca de pautas (opcional; Google News RSS funciona sem chave)
BRAVE_SEARCH_API_KEY=
SERPER_API_KEY=
# SerpApi (https://serpapi.com) — Google Images para sugestões de capa (pessoa/assunto)
SERPAPI_API_KEY=

FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:3000/api/auth/facebook/callback

# PostPulse (API comercial — sem App Review da Meta)
# No painel PostPulse, Redirect URI deve ser EXATAMENTE o valor abaixo:
POSTPULSE_CLIENT_ID=
POSTPULSE_CLIENT_SECRET=
POSTPULSE_REDIRECT_URI=http://localhost:3000/api/auth/postpulse/callback

# PostSyncer (alternativa ao PostPulse — API key em Settings → API Integration)
# https://app.postsyncer.com → Settings → API Integration → Create
POSTSYNCER_API_KEY=
# Opcional: se vazio, usa o primeiro workspace da conta
POSTSYNCER_WORKSPACE_ID=

# auto = PostSyncer (se vinculado) → PostPulse → Graph API
# postsyncer = sempre PostSyncer | postpulse | facebook
PUBLISH_PROVIDER=postsyncer

SESSION_SECRET=troque-por-um-segredo-forte

# Caminho do ffmpeg (opcional se estiver no PATH)
# FFMPEG_PATH=C:\\ffmpeg\\bin\\ffmpeg.exe

# Autenticação yt-dlp/YouTube (não use as duas opções ao mesmo tempo)
# Desenvolvimento local: chrome, edge, firefox, brave, opera ou vivaldi
# YTDLP_COOKIES_FROM_BROWSER=chrome
# Produção: arquivo Netscape cookies.txt fora de public/ e storage/, sempre com caminho absoluto
# YTDLP_COOKIES_FILE=/home/viralizeai/secrets/youtube-cookies.txt

# Extração de fala: Python 3.9+ + faster-whisper
# pip install -r scripts/requirements.txt
# Se `python` não estiver no PATH, aponte o executável:
# PYTHON_PATH=C:\\Python313\\python.exe
PYTHON_PATH=

# YouTube / yt-dlp (produção CloudPanel)
# YTDLP_COOKIES_FILE=/home/viralizeai/secrets/youtube-cookies.txt
# Cookies do Instagram (Netscape) — Biblioteca + gerar matéria a partir de link IG em /conteudo
# YTDLP_IG_COOKIES_FILE=/home/viralizeai/secrets/instagram-cookies.txt
# YTDLP_JS_RUNTIME=node:/usr/local/bin/node
# YTDLP_PATH=/usr/local/bin/yt-dlp

# --- Produção (CloudPanel exemplo) ---
# PORT=3010
# NODE_ENV=production
# DATABASE_URL=mysql://clipador:SENHA@127.0.0.1:3306/clipador
# FACEBOOK_REDIRECT_URI=https://www.viralizeai.online/api/auth/facebook/callback
# POSTPULSE_CLIENT_ID=
# POSTPULSE_CLIENT_SECRET=
# POSTPULSE_REDIRECT_URI=https://www.viralizeai.online/api/auth/postpulse/callback
# POSTSYNCER_API_KEY=
# POSTSYNCER_WORKSPACE_ID=
# PUBLISH_PROVIDER=auto
# SESSION_SECRET=gere-um-segredo-longo-aleatorio
# Fuso para logs/processo (opcional; agendamento de matérias usa Araguaína UTC−3 no código)
# TZ=America/Araguaina
