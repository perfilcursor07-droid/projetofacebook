<%- include('partials/app-start') %>

  <main class="mx-auto max-w-8xl px-6 py-8">
    <%- include('partials/content-nav', { contentTab: 'production' }) %>

    <div class="flex flex-wrap items-center justify-between gap-3">
      <div>
        <h1 class="text-2xl font-semibold text-white">Produção e publicação</h1>
        <p class="mt-1 text-xs text-slate-500">Cortes por IA ou manuais, matérias, imagens e publicações em um só lugar.</p>
      </div>
      <div class="flex items-center gap-3">
        <span id="last-updated" class="text-xs text-slate-500"></span>
        <button id="refresh-btn" type="button"
          class="rounded-lg border border-slate-700 px-3 py-1.5 text-xs text-slate-300 transition hover:border-emerald-500 hover:text-emerald-300">
          Atualizar
        </button>
      </div>
    </div>

    <div id="global-msg" class="mt-3 hidden rounded-lg border border-rose-500/30 bg-rose-500/10 px-4 py-2.5 text-sm text-rose-200"></div>

    <details class="group mt-5 rounded-2xl border border-slate-800 bg-slate-900/40">
      <summary class="flex cursor-pointer list-none items-center justify-between px-5 py-3 text-sm font-medium text-slate-300 hover:text-white">
        <span class="inline-flex items-center gap-2">
          <svg class="h-4 w-4 text-[#1877F2]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12.5h2.54v-2.2c0-2.5 1.49-3.89 3.77-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56v1.87h2.78l-.44 2.39h-2.34v6.99A10 10 0 0 0 22 12Z"/></svg>
          Publicar texto rápido
        </span>
        <span class="text-xs text-slate-500 group-open:hidden">clique para expandir</span>
      </summary>
      <div class="space-y-3 border-t border-slate-800 p-5">
        <form id="text-post-form" class="space-y-3">
          <textarea name="texto" rows="3" required maxlength="63206" placeholder="Texto do post…"
            class="w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-100 placeholder:text-slate-600 focus:border-emerald-500 focus:outline-none"></textarea>
          <div class="flex flex-wrap items-center gap-2">
            <span id="text-post-pages"></span>
            <input type="url" name="link" placeholder="Link (opcional)"
              class="w-56 rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 text-xs text-slate-100 placeholder:text-slate-600 focus:border-emerald-500 focus:outline-none" />
            <button type="submit"
              class="rounded-lg bg-[#1877F2] px-4 py-2 text-xs font-semibold text-white transition hover:bg-[#166FE5] disabled:opacity-50">
              Publicar no Facebook
            </button>
          </div>
        </form>
        <p class="text-[11px] leading-relaxed text-slate-500">Reels 9:16 · 3–90s · ≥10s para monetização · conteúdo original · máx. 30 Reels/página/24h</p>
      </div>
    </details>

    <div class="mt-6 inline-flex flex-wrap rounded-xl border border-slate-700 bg-slate-900 p-1" role="tablist" aria-label="Seções da fila">
      <button type="button" data-tab="videos" class="tab-btn rounded-lg bg-emerald-500 px-4 py-2 text-sm font-semibold text-slate-950">
        Vídeos <span id="count-videos" class="ml-1 font-normal opacity-70"></span>
      </button>
      <button type="button" data-tab="imagens" class="tab-btn rounded-lg px-4 py-2 text-sm text-slate-300 hover:text-white">
        Imagens <span id="count-imagens" class="ml-1 font-normal opacity-70"></span>
      </button>
      <button type="button" data-tab="publicacoes" class="tab-btn rounded-lg px-4 py-2 text-sm text-slate-300 hover:text-white">
        Publicações <span id="count-publicacoes" class="ml-1 font-normal opacity-70"></span>
      </button>
    </div>

    <section id="tab-videos" class="tab-panel mt-4">
      <div class="flex flex-wrap items-center justify-between gap-2">
        <div id="videos-filter" class="flex flex-wrap gap-1.5"></div>
        <div class="flex items-center gap-2">
          <button type="button" id="collapse-all-videos"
            class="rounded-lg border border-slate-700 px-2.5 py-1 text-[11px] text-slate-400 transition hover:border-slate-500 hover:text-slate-200">
            Recolher todos
          </button>
          <button type="button" id="expand-all-videos"
            class="rounded-lg border border-slate-700 px-2.5 py-1 text-[11px] text-slate-400 transition hover:border-slate-500 hover:text-slate-200">
            Expandir todos
          </button>
          <span id="videos-status" class="text-xs text-slate-500">Carregando…</span>
        </div>
      </div>
      <div id="videos-list" class="mt-3 space-y-3"></div>
    </section>

    <section id="tab-imagens" class="tab-panel mt-4 hidden">
      <div class="flex flex-wrap items-center justify-between gap-2">
        <div id="imagens-filter" class="flex flex-wrap gap-1.5"></div>
        <span id="imagens-status" class="text-xs text-slate-500">Carregando…</span>
      </div>
      <div id="imagens-list" class="mt-3 grid gap-3 lg:grid-cols-2"></div>
    </section>

    <section id="tab-publicacoes" class="tab-panel mt-4 hidden">
      <div class="flex flex-wrap items-center justify-between gap-2">
        <div id="publicacoes-filter" class="flex flex-wrap gap-1.5"></div>
        <span id="publicacoes-status" class="text-xs text-slate-500">Carregando…</span>
      </div>
      <div id="publicacoes-list" class="mt-3"></div>
    </section>
  </main>

  <script>
    const refreshBtn = document.getElementById('refresh-btn');
    const globalMsg = document.getElementById('global-msg');
    const lastUpdatedEl = document.getElementById('last-updated');

    const STATUS_TONE = {
      publicado: 'bg-emerald-500/15 text-emerald-300',
      pronto: 'bg-emerald-500/15 text-emerald-300',
      pronta: 'bg-emerald-500/15 text-emerald-300',
      pendente: 'bg-amber-500/15 text-amber-300',
      processando: 'bg-amber-500/15 text-amber-300',
      gerando: 'bg-amber-500/15 text-amber-300',
      baixado: 'bg-sky-500/15 text-sky-300',
      cortado: 'bg-violet-500/15 text-violet-300',
      erro: 'bg-rose-500/15 text-rose-300',
      sugerido: 'bg-slate-700/40 text-slate-300',
    };

    function escapeHtml(text) {
      return String(text || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }

    function badge(status, label) {
      const tone = STATUS_TONE[status] || 'bg-slate-700/40 text-slate-300';
      return `<span class="rounded-full px-2.5 py-0.5 text-[11px] font-medium ${tone}">${escapeHtml(label || status)}</span>`;
    }

    function materiaStatusBadge(status) {
      if (!status || status === 'pendente') return '';
      const map = { gerando: ['gerando', 'gerando…'], pronta: ['pronta', 'matéria ok'], erro: ['erro', 'erro matéria'] };
      const [key, label] = map[status] || ['sugerido', status];
      return badge(key, label);
    }

    function showError(msg) {
      globalMsg.textContent = msg;
      globalMsg.classList.remove('hidden');
      setTimeout(() => globalMsg.classList.add('hidden'), 6000);
    }

    function fmtDate(value) {
      if (!value) return '—';
      try {
        return new Date(value).toLocaleString('pt-BR', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' });
      } catch (_) {
        return String(value);
      }
    }

    function cleanTranscript(text) {
      return String(text || '').replace(/^Kind:\s*\w+\s*Language:\s*\w+\s*/i, '').replace(/\s+/g, ' ').trim();
    }

    // —— estado ——
    let fbPages = [];
    let allVideos = [];
    let allImagens = [];
    let allPublicacoes = [];
    let activeTab = 'videos';
    let filterVideo = 'todos';
    let filterImagem = 'todos';
    let filterPub = 'todos';

    // Estado de recolher (sobrevive ao auto-refresh)
    const uiCollapse = {
      video: {},   // id -> bool (card inteiro: form + cortes)
      form: {},    // id -> bool (painel de corte)
      clips: {},   // id -> bool (grade de cortes)
    };

    function isCollapsed(group, id) {
      if (uiCollapse[group] && Object.prototype.hasOwnProperty.call(uiCollapse[group], id)) {
        return Boolean(uiCollapse[group][id]);
      }
      // Padrão: se já há cortes, recolhe o formulário (a grade de cortes fica aberta)
      if (group === 'form') {
        const v = allVideos.find((x) => String(x.id) === String(id));
        return Boolean(v?.clips?.length);
      }
      return false;
    }

    function setCollapsed(group, id, value) {
      if (!uiCollapse[group]) uiCollapse[group] = {};
      uiCollapse[group][id] = Boolean(value);
    }

    function collapseLabel(collapsed, openText, closedText) {
      return collapsed ? closedText : openText;
    }

    const VIDEO_STATUSES = [
      { key: 'todos', label: 'Todos' },
      { key: 'pendente', label: 'Pendente' },
      { key: 'baixado', label: 'Baixado' },
      { key: 'cortado', label: 'Cortado' },
      { key: 'publicado', label: 'Publicado' },
      { key: 'erro', label: 'Erro' },
    ];
    const IMAGEM_STATUSES = [
      { key: 'todos', label: 'Todos' },
      { key: 'pendente', label: 'Pendente' },
      { key: 'baixado', label: 'Baixado' },
      { key: 'publicado', label: 'Publicado' },
      { key: 'erro', label: 'Erro' },
    ];
    const PUB_STATUSES = [
      { key: 'todos', label: 'Todos' },
      { key: 'pendente', label: 'Pendente' },
      { key: 'publicado', label: 'Publicado' },
      { key: 'erro', label: 'Erro' },
    ];

    function renderChips(containerEl, statuses, items, active, group) {
      containerEl.innerHTML = statuses
        .map((st) => {
          const count = st.key === 'todos' ? items.length : items.filter((i) => i.status === st.key).length;
          const isActive = st.key === active;
          const cls = isActive
            ? 'rounded-full bg-emerald-500 px-3 py-1 text-[11px] font-semibold text-slate-950'
            : 'rounded-full border border-slate-700 px-3 py-1 text-[11px] font-medium text-slate-400 transition hover:border-slate-500 hover:text-slate-200';
          return `<button type="button" class="filter-chip ${cls}" data-filter-group="${group}" data-filter-value="${st.key}">${st.label} (${count})</button>`;
        })
        .join('');
    }

    // —— preserva edições do usuário durante o auto-refresh ——
    function captureEdits(containerEl) {
      const edits = {};
      containerEl.querySelectorAll('form[data-kind]').forEach((form) => {
        edits[form.dataset.kind + ':' + form.dataset.id] = {
          legenda: form.legenda ? form.legenda.value : undefined,
          pageId: form.facebook_page_id ? form.facebook_page_id.value : undefined,
          modo: form.modo ? form.modo.value : undefined,
        };
      });
      containerEl.querySelectorAll('.clip-tema').forEach((inp) => {
        if (inp.value) edits['tema:clip:' + inp.dataset.clipTema] = inp.value;
      });
      containerEl.querySelectorAll('.img-tema').forEach((inp) => {
        if (inp.value) edits['tema:imagem:' + inp.dataset.imgTema] = inp.value;
      });
      return edits;
    }

    function restoreEdits(containerEl, edits) {
      containerEl.querySelectorAll('form[data-kind]').forEach((form) => {
        const e = edits[form.dataset.kind + ':' + form.dataset.id];
        if (!e) return;
        // Não sobrescrever matéria fresca do servidor com textarea vazio capturado
        // antes da geração terminar (causa "matéria ok" + campo em branco).
        if (e.legenda != null && form.legenda) {
          const captured = String(e.legenda);
          const serverVal = String(form.legenda.value || '');
          if (captured.trim() || !serverVal.trim()) {
            form.legenda.value = captured;
          }
        }
        if (e.pageId != null && form.facebook_page_id) form.facebook_page_id.value = e.pageId;
        if (e.modo != null && form.modo) form.modo.value = e.modo;
      });
      containerEl.querySelectorAll('.clip-tema').forEach((inp) => {
        const v = edits['tema:clip:' + inp.dataset.clipTema];
        if (v) inp.value = v;
      });
      containerEl.querySelectorAll('.img-tema').forEach((inp) => {
        const v = edits['tema:imagem:' + inp.dataset.imgTema];
        if (v) inp.value = v;
      });
    }

    // —— publicar (clip/imagem) ——
    function pageSelectHtml(current) {
      return `
        <select name="facebook_page_id" class="rounded-lg border border-slate-700 bg-slate-950 px-2.5 py-1.5 text-xs text-slate-100 focus:border-emerald-500 focus:outline-none">
          ${fbPages.map((p) => `<option value="${p.id}" ${String(p.id) === String(current) ? 'selected' : ''}>${escapeHtml(p.page_name)}</option>`).join('')}
        </select>`;
    }

    function publishFormHtml(kind, id, defaultLegenda = '') {
      const isClip = kind === 'clip';
      const publishControls = fbPages.length
        ? `<div class="grid grid-cols-1 gap-2 ${isClip ? 'sm:grid-cols-[1fr_auto_auto]' : 'sm:grid-cols-[1fr_auto]'}">
            ${pageSelectHtml()}
            ${isClip ? `
            <select name="modo" class="rounded-lg border border-slate-700 bg-slate-950 px-2.5 py-1.5 text-xs text-slate-100 focus:border-emerald-500 focus:outline-none">
              <option value="reel">Reel</option>
              <option value="video">Vídeo</option>
            </select>` : ''}
            <button type="submit" class="rounded-lg bg-[#1877F2] px-4 py-1.5 text-xs font-semibold text-white transition hover:bg-[#166FE5] disabled:opacity-50">Publicar</button>
          </div>`
        : `<a href="/paginas" class="inline-flex text-xs text-sky-400 hover:text-sky-300">Conecte uma página para publicar →</a>`;

      return `
        <form class="publish-form space-y-2" data-kind="${kind}" data-id="${id}">
          <label class="block">
            <span class="text-[11px] font-semibold uppercase tracking-wide text-violet-300">Matéria</span>
            <textarea name="legenda" rows="${isClip ? 4 : 3}" placeholder="A matéria aparece aqui após gerar…"
              class="mt-1 w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 text-sm leading-relaxed text-slate-100 placeholder:text-slate-600 focus:border-emerald-500 focus:outline-none">${escapeHtml(defaultLegenda)}</textarea>
          </label>
          ${publishControls}
        </form>`;
    }

    // —— clipes ——
    function clipPreviewHtml(clip) {
      if (clip.caminho_arquivo) {
        return `<div class="relative overflow-hidden rounded-xl bg-black ring-1 ring-white/5">
          <video src="/media/${escapeHtml(clip.caminho_arquivo)}" controls playsinline preload="metadata"
            class="aspect-[9/16] max-h-64 w-full object-contain sm:aspect-video sm:max-h-52"></video>
        </div>`;
      }

      if (clip.status === 'processando') {
        return `<div class="relative flex aspect-video max-h-52 w-full flex-col items-center justify-center gap-3 overflow-hidden rounded-xl bg-gradient-to-br from-slate-950 via-slate-900 to-amber-950/40 ring-1 ring-amber-500/20">
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_30%,rgba(245,158,11,0.12),transparent_55%)]"></div>
          <span class="relative inline-flex h-10 w-10 items-center justify-center rounded-full border border-amber-400/30 bg-amber-500/10">
            <span class="h-5 w-5 animate-spin rounded-full border-2 border-amber-300/30 border-t-amber-300"></span>
          </span>
          <div class="relative text-center">
            <p class="text-sm font-medium text-amber-100">Gerando corte…</p>
            <p class="mt-1 text-[11px] text-amber-200/60">ffmpeg em andamento</p>
          </div>
        </div>`;
      }

      if (clip.status === 'erro') {
        return `<div class="flex aspect-video max-h-52 w-full flex-col items-center justify-center gap-2 rounded-xl bg-gradient-to-br from-slate-950 to-rose-950/30 ring-1 ring-rose-500/20">
          <span class="flex h-9 w-9 items-center justify-center rounded-full bg-rose-500/15 text-rose-300">!</span>
          <p class="text-sm font-medium text-rose-200">Falha no corte</p>
          <p class="text-[11px] text-rose-300/70">Use retentar ou exclua e recrie</p>
        </div>`;
      }

      return `<div class="flex aspect-video max-h-52 w-full items-center justify-center rounded-xl bg-slate-950 text-xs text-slate-500 ring-1 ring-slate-800">Sem arquivo</div>`;
    }

    function looksLikeTranscriptInMateria(materia, fala) {
      const a = String(materia || '').toLowerCase().replace(/\s+/g, ' ').trim();
      const b = String(fala || '').toLowerCase().replace(/\s+/g, ' ').trim();
      if (!a || !b || b.length < 40) return false;
      if (a === b) return true;
      // Só esconde se a matéria for praticamente a transcrição inteira
      if (a.length >= b.length * 0.85 && a.includes(b.slice(0, Math.min(160, b.length)))) return true;
      if (b.length >= a.length * 0.85 && b.includes(a.slice(0, Math.min(160, a.length)))) return true;
      return false;
    }

    function clipHtml(clip, index) {
      const canAi = clip.status === 'pronto' || clip.status === 'publicado';
      const canRetry = clip.status === 'processando' || clip.status === 'erro';
      const extracting = clip.materia_status === 'gerando';
      const fala = cleanTranscript(clip.transcricao);
      // Não mostrar transcrição no campo Matéria (só texto editorial)
      let materia = String(clip.legenda_sugerida || '').trim();
      if (
        !materia ||
        /^\[(sem fala|falha)/i.test(materia) ||
        looksLikeTranscriptInMateria(materia, fala)
      ) {
        materia = '';
      }
      const inicio = Number(clip.inicio_segundo);
      const fim = Number(clip.fim_segundo);
      const dur = Number.isFinite(inicio) && Number.isFinite(fim) ? Math.max(0, Math.round(fim - inicio)) : null;
      const ratio = clip.aspect_ratio || '9:16';
      const borderTone = clip.status === 'erro'
        ? 'border-rose-500/30 hover:border-rose-500/50'
        : clip.status === 'processando'
          ? 'border-amber-500/25 hover:border-amber-500/40'
          : clip.status === 'pronto' || clip.status === 'publicado'
            ? 'border-emerald-500/20 hover:border-emerald-500/40'
            : 'border-slate-800 hover:border-slate-700';

      return `
        <article class="group flex h-full flex-col overflow-hidden rounded-2xl border bg-slate-950/50 shadow-sm shadow-black/20 transition ${borderTone}">
          ${clipPreviewHtml(clip)}

          <div class="flex flex-1 flex-col gap-3 p-3.5">
            <div class="flex items-center justify-between gap-2">
              <div class="flex min-w-0 flex-wrap items-center gap-2">
                <span class="inline-flex h-6 min-w-[1.5rem] items-center justify-center rounded-md bg-violet-500/15 px-1.5 text-xs font-bold text-violet-300">#${index + 1}</span>
                <h3 class="text-sm font-semibold text-white">Corte</h3>
                ${badge(clip.status)}
                ${materiaStatusBadge(clip.materia_status)}
              </div>
              <button type="button"
                class="action-btn shrink-0 rounded-lg px-2 py-1 text-[11px] font-medium text-rose-400/80 transition hover:bg-rose-500/10 hover:text-rose-300"
                data-action="delete-clip" data-id="${clip.id}" title="Excluir corte">
                Excluir
              </button>
            </div>

            <div class="grid grid-cols-3 gap-1.5">
              <span class="rounded-md border border-slate-800 bg-slate-900/80 px-2 py-1 text-center text-[10px] text-slate-300">
                <span class="block text-slate-500">intervalo</span>${inicio}–${fim}s
              </span>
              <span class="rounded-md border border-slate-800 bg-slate-900/80 px-2 py-1 text-center text-[10px] text-slate-300">
                <span class="block text-slate-500">duração</span>${dur != null ? dur + 's' : '—'}
              </span>
              <span class="rounded-md border border-slate-800 bg-slate-900/80 px-2 py-1 text-center text-[10px] text-slate-300">
                <span class="block text-slate-500">formato</span>${escapeHtml(ratio)}
              </span>
            </div>

            ${extracting && !fala ? `
            <div class="flex items-center gap-2 rounded-lg border border-amber-500/20 bg-amber-500/5 px-3 py-2 text-xs text-amber-200">
              <span class="h-3.5 w-3.5 animate-spin rounded-full border border-amber-300/30 border-t-amber-300"></span>
              Extraindo fala…
            </div>` : ''}

            ${fala ? `
            <details class="rounded-lg border border-slate-800 bg-slate-900/40">
              <summary class="cursor-pointer px-3 py-2 text-xs font-medium text-slate-400 hover:text-slate-200">Ver fala / transcrição</summary>
              <p class="border-t border-slate-800 px-3 py-2 text-xs leading-relaxed text-slate-400">${escapeHtml(fala)}</p>
            </details>` : ''}

            ${clip.erro_mensagem ? `
            <div class="rounded-lg border border-rose-500/25 bg-rose-500/10 px-3 py-2 text-xs leading-relaxed text-rose-200">
              ${escapeHtml(clip.erro_mensagem)}
            </div>` : ''}

            ${canRetry ? `
            <div class="mt-auto border-t border-slate-800/80 pt-3">
              <button type="button"
                class="ai-btn w-full rounded-xl border border-amber-500/40 bg-amber-500/10 px-3 py-2 text-xs font-semibold text-amber-100 transition hover:bg-amber-500/20"
                data-action="retry-clip" data-id="${clip.id}">
                Retentar corte
              </button>
            </div>` : ''}

            ${canAi ? `
            <div class="mt-auto space-y-2.5 border-t border-slate-800/80 pt-3">
              <div class="grid grid-cols-1 gap-2">
                <input type="text"
                  class="clip-tema w-full rounded-xl border border-slate-700 bg-slate-900 px-3 py-2 text-xs text-slate-100 placeholder:text-slate-600 focus:border-emerald-500 focus:outline-none"
                  data-clip-tema="${clip.id}" placeholder="Tema da matéria (opcional)" />
                <div class="grid grid-cols-2 gap-2">
                  <button type="button"
                    class="ai-btn rounded-xl bg-violet-500 px-3 py-2 text-xs font-semibold text-white transition hover:bg-violet-400"
                    data-action="materia-clip" data-id="${clip.id}">${materia ? 'Refazer matéria' : 'Gerar matéria'}</button>
                  ${!fala
                    ? `<button type="button" class="ai-btn rounded-xl border border-slate-700 px-3 py-2 text-xs text-slate-300 transition hover:border-slate-500 hover:text-white" data-action="transcribe-clip" data-id="${clip.id}">Extrair fala</button>`
                    : `<span class="rounded-xl border border-emerald-500/20 bg-emerald-500/10 px-3 py-2 text-center text-[11px] text-emerald-300">Fala ok</span>`}
                </div>
              </div>
              ${publishFormHtml('clip', clip.id, materia)}
            </div>` : ''}
          </div>
        </article>`;
    }

    function videoActionsHtml(v) {
      if (v.status === 'pendente' || v.status === 'erro') {
        return `<button type="button" class="action-btn inline-flex items-center justify-center rounded-xl bg-emerald-500 px-4 py-2 text-xs font-bold text-slate-950 shadow-sm shadow-emerald-950/30 transition hover:bg-emerald-400" data-action="download-video" data-id="${v.id}">Baixar vídeo</button>`;
      }
      if (v.status === 'baixado' || v.status === 'cortado') {
        const max = Number(v.duracao) > 0 ? Number(v.duracao) : 600;
        if (max < 3) return `<p class="text-xs text-amber-300">Vídeo menor que 3s</p>`;
        const defaultFim = Math.min(max, 90);
        const estimativa = Math.floor(max / 90) + (max % 90 >= 3 ? 1 : 0);
        return `
          <form class="clip-form space-y-4 rounded-xl border border-slate-800 bg-slate-950/70 p-4" data-id="${v.id}" data-max="${max}">
            <div class="grid gap-2 sm:grid-cols-3">
              <div class="rounded-xl border border-fuchsia-500/25 bg-fuchsia-500/5 px-3 py-2.5">
                <p class="text-[10px] font-bold uppercase tracking-wider text-fuchsia-300">Recomendado</p>
                <p class="mt-0.5 text-xs font-semibold text-white">Melhores cortes por IA</p>
                <p class="mt-1 text-[11px] leading-relaxed text-slate-400">Fala completa, contexto e fechamento · 40–90s.</p>
              </div>
              <div class="rounded-xl border border-slate-800 bg-slate-900/60 px-3 py-2.5">
                <p class="text-[10px] font-bold uppercase tracking-wider text-slate-500">Manual</p>
                <p class="mt-0.5 text-xs font-semibold text-slate-200">Intervalo personalizado</p>
                <p class="mt-1 text-[11px] leading-relaxed text-slate-500">Você escolhe exatamente o início e o fim.</p>
              </div>
              <div class="rounded-xl border border-slate-800 bg-slate-900/60 px-3 py-2.5">
                <p class="text-[10px] font-bold uppercase tracking-wider text-slate-500">Automático</p>
                <p class="mt-0.5 text-xs font-semibold text-slate-200">Blocos de 90 segundos</p>
                <p class="mt-1 text-[11px] leading-relaxed text-slate-500">Divide tudo, sem avaliar o conteúdo da fala.</p>
              </div>
            </div>

            <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
              <label class="text-[11px] font-medium text-slate-400">Início (s)
                <input type="number" name="inicio" min="0" max="${Math.max(0, max - 3)}" value="0" step="1" required
                  class="mt-1.5 block w-full rounded-xl border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-100 focus:border-emerald-500 focus:outline-none" />
              </label>
              <label class="text-[11px] font-medium text-slate-400">Fim (s)
                <input type="number" name="fim" min="3" max="${max}" value="${defaultFim}" step="1" required
                  class="clip-fim mt-1.5 block w-full rounded-xl border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-100 focus:border-emerald-500 focus:outline-none" />
              </label>
              <label class="col-span-2 text-[11px] font-medium text-slate-400 sm:col-span-1">Formato
                <select name="aspect_ratio" class="mt-1.5 block w-full rounded-xl border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-100 focus:border-emerald-500 focus:outline-none">
                  <option value="9:16">9:16 · vertical</option>
                  <option value="1:1">1:1 · quadrado</option>
                  <option value="original">Formato original</option>
                </select>
              </label>
            </div>

            <div class="flex flex-wrap items-center gap-1.5">
              <span class="mr-1 text-[10px] font-semibold uppercase tracking-wide text-slate-500">Definir fim:</span>
              <button type="button" class="fim-preset rounded-lg border border-slate-700 px-2.5 py-1 text-[11px] text-slate-400 transition hover:border-emerald-500 hover:text-emerald-300" data-fim="${Math.min(max, 30)}">30s</button>
              <button type="button" class="fim-preset rounded-lg border border-slate-700 px-2.5 py-1 text-[11px] text-slate-400 transition hover:border-emerald-500 hover:text-emerald-300" data-fim="${Math.min(max, 60)}">60s</button>
              <button type="button" class="fim-preset rounded-lg border border-emerald-500/40 bg-emerald-500/10 px-2.5 py-1 text-[11px] font-medium text-emerald-300" data-fim="${Math.min(max, 90)}">90s</button>
              ${max > 90 ? `<button type="button" class="fim-preset rounded-lg border border-slate-700 px-2.5 py-1 text-[11px] text-slate-400 transition hover:border-amber-500 hover:text-amber-300" data-fim="${Math.min(max, 180)}">3min</button>` : ''}
              ${max > 90 ? `<button type="button" class="fim-preset rounded-lg border border-slate-700 px-2.5 py-1 text-[11px] text-slate-400 transition hover:border-amber-500 hover:text-amber-300" data-fim="${max}">Até o fim (${max}s)</button>` : ''}
            </div>

            <div class="grid gap-2 sm:grid-cols-3">
              <button type="button" class="action-btn order-first rounded-xl bg-gradient-to-r from-fuchsia-500 to-violet-500 px-4 py-2.5 text-xs font-bold text-white shadow-sm shadow-fuchsia-950/40 transition hover:brightness-110 disabled:cursor-wait disabled:opacity-60 sm:order-last"
                data-action="analyze-video" data-id="${v.id}">
                Gerar melhores cortes
              </button>
              <button type="submit" class="rounded-xl border border-violet-500/50 bg-violet-500/10 px-4 py-2.5 text-xs font-semibold text-violet-100 transition hover:bg-violet-500/20">Criar corte manual</button>
              <button type="button" class="action-btn rounded-xl border border-slate-700 bg-slate-900 px-4 py-2.5 text-xs font-semibold text-slate-300 transition hover:border-slate-500 hover:text-white"
                data-action="clip-auto" data-id="${v.id}" data-aspect="9:16">
                Dividir em 90s (~${estimativa})
              </button>
            </div>
          </form>`;
      }
      return '';
    }

    function parseVideoMeta(v) {
      if (!v?.metadata) return {};
      if (typeof v.metadata === 'object') return v.metadata;
      try { return JSON.parse(v.metadata); } catch { return {}; }
    }

    function videoHtml(v) {
      const clips = v.clips || [];
      const durMin = v.duracao ? Math.round(v.duracao / 60) + ' min' : '—';
      const cardCollapsed = isCollapsed('video', v.id);
      const formCollapsed = isCollapsed('form', v.id);
      const clipsCollapsed = isCollapsed('clips', v.id);
      const canCut = v.status === 'baixado' || v.status === 'cortado';
      const formHtml = videoActionsHtml(v);
      const meta = parseVideoMeta(v);
      const analise = meta.analise_status || '';
      const sugestoes = Array.isArray(meta.sugestoes_corte) ? meta.sugestoes_corte : [];

      return `
        <article class="overflow-hidden rounded-2xl border border-slate-800 bg-slate-900/50 shadow-lg shadow-black/10 transition hover:border-slate-700" data-video-card="${v.id}">
          <div class="p-4 sm:p-5">
            <div class="flex flex-col gap-4 sm:flex-row">
              <div class="h-28 w-full flex-shrink-0 overflow-hidden rounded-xl bg-slate-950 ring-1 ring-white/5 sm:h-[82px] sm:w-36">
                ${v.thumbnail ? `<img src="${escapeHtml(v.thumbnail)}" alt="" class="h-full w-full object-cover" />` : '<div class="flex h-full items-center justify-center text-xs text-slate-600">Sem capa</div>'}
              </div>
              <div class="min-w-0 flex-1">
                <div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
                  <div class="min-w-0">
                    <div class="flex flex-wrap items-center gap-1.5">
                      ${badge(v.status)}
                      ${analise === 'processando' ? badge('processando', 'IA analisando…') : ''}
                      ${analise === 'pronta' ? badge('pronta', 'IA concluída') : ''}
                      <span class="text-xs text-slate-500">${escapeHtml(v.origem || 'pexels')} · ${durMin}</span>
                      ${clips.length ? `<span class="rounded-full bg-violet-500/15 px-2 py-0.5 text-[11px] font-medium text-violet-300">${clips.length} corte(s)</span>` : ''}
                      ${v.caminho_local ? `<a href="/media/${escapeHtml(v.caminho_local)}" target="_blank" class="rounded-full border border-emerald-500/20 px-2 py-0.5 text-[11px] text-emerald-400 transition hover:bg-emerald-500/10">Ver original</a>` : ''}
                    </div>
                    <p class="mt-2 break-words text-sm font-semibold leading-snug text-white">${escapeHtml(v.titulo || v.termo_busca)}</p>
                    <p class="mt-1 text-xs text-slate-500">${escapeHtml(v.autor || '')}</p>
                  </div>
                  <div class="flex shrink-0 flex-wrap items-center gap-2 lg:justify-end">
                    ${canCut ? `
                    <button type="button" class="action-btn rounded-xl bg-gradient-to-r from-fuchsia-500 to-violet-500 px-3.5 py-2 text-xs font-bold text-white transition hover:brightness-110 disabled:cursor-wait disabled:opacity-50"
                      data-action="analyze-video" data-id="${v.id}" ${analise === 'processando' ? 'disabled' : ''}>
                      ${analise === 'processando' ? 'Analisando fala…' : (analise === 'pronta' ? 'Refazer melhores cortes' : 'Melhores cortes IA')}
                    </button>` : ''}
                    <button type="button"
                      class="collapse-btn rounded-xl border border-slate-700 px-3 py-2 text-xs font-medium text-slate-300 transition hover:border-emerald-500 hover:text-emerald-300"
                      data-collapse-group="video" data-collapse-id="${v.id}">
                      ${collapseLabel(cardCollapsed, 'Recolher', 'Expandir')}
                    </button>
                    <button type="button" class="action-btn rounded-xl border border-transparent px-3 py-2 text-xs font-medium text-rose-400 transition hover:border-rose-500/20 hover:bg-rose-500/10 hover:text-rose-300" data-action="delete-video" data-id="${v.id}">Excluir</button>
                  </div>
                </div>
                ${v.erro_mensagem ? `<p class="mt-2 rounded-lg border border-rose-500/20 bg-rose-500/10 px-3 py-2 text-xs text-rose-200">${escapeHtml(v.erro_mensagem)}</p>` : ''}
                ${analise === 'processando' ? `<div class="mt-3 flex items-center gap-2 rounded-xl border border-amber-500/20 bg-amber-500/5 px-3 py-2 text-xs text-amber-200"><span class="h-3.5 w-3.5 animate-spin rounded-full border border-amber-300/30 border-t-amber-300"></span>Ouvindo a fala e montando momentos completos de 40–90s…</div>` : ''}
              </div>
            </div>

            ${analise === 'pronta' && sugestoes.length ? `
            <div class="mt-4 rounded-xl border border-fuchsia-500/20 bg-gradient-to-r from-fuchsia-500/5 to-violet-500/5 p-3.5">
              <div class="flex flex-wrap items-center justify-between gap-2">
                <p class="text-xs font-bold text-fuchsia-200">Melhores momentos encontrados</p>
                <span class="text-[11px] text-slate-500">${sugestoes.length} sugestão(ões) · falas completas</span>
              </div>
              <div class="mt-2.5 grid gap-2 md:grid-cols-3">
                ${sugestoes.map((s, i) => {
                  const inicio = Number(s.inicio);
                  const fim = Number(s.fim);
                  const duracao = Number.isFinite(inicio) && Number.isFinite(fim) ? Math.max(0, Math.round(fim - inicio)) : 0;
                  return `<div class="min-w-0 rounded-lg border border-slate-800/80 bg-slate-950/50 px-3 py-2">
                    <div class="flex items-center justify-between gap-2">
                      <span class="text-[11px] font-bold text-fuchsia-300">#${i + 1} · ${inicio}–${fim}s</span>
                      <span class="rounded-full bg-slate-800 px-2 py-0.5 text-[10px] text-slate-400">${duracao}s</span>
                    </div>
                    <p class="mt-1.5 text-[11px] leading-relaxed text-slate-400">${escapeHtml(s.motivo || 'Momento selecionado pela análise da fala.')}</p>
                  </div>`;
                }).join('')}
              </div>
            </div>` : ''}
          </div>

          <div class="video-body space-y-3 border-t border-slate-800 bg-slate-950/20 p-3 sm:p-4 ${cardCollapsed ? 'hidden' : ''}">
            ${canCut && formHtml ? `
            <div class="overflow-hidden rounded-xl border border-slate-800 bg-slate-950/30">
              <button type="button"
                class="collapse-btn flex w-full items-center justify-between px-3.5 py-3 text-left text-xs font-medium text-slate-300 transition hover:bg-slate-900/50 hover:text-white"
                data-collapse-group="form" data-collapse-id="${v.id}">
                <span class="inline-flex items-center gap-2">
                  <span class="rounded-md bg-violet-500/15 px-2 py-1 font-semibold text-violet-300">Criar cortes</span>
                  <span class="font-normal text-slate-500">IA · manual · blocos de 90s</span>
                </span>
                <span class="text-slate-500">${collapseLabel(formCollapsed, '▾ Recolher', '▸ Expandir')}</span>
              </button>
              <div class="border-t border-slate-800 p-3 ${formCollapsed ? 'hidden' : ''}">
                ${formHtml}
              </div>
            </div>` : (formHtml ? `<div>${formHtml}</div>` : '')}

            ${clips.length ? `
            <div class="overflow-hidden rounded-xl border border-slate-800 bg-slate-950/30">
              <button type="button"
                class="collapse-btn flex w-full items-center justify-between px-3.5 py-3 text-left text-xs font-medium text-slate-300 transition hover:bg-slate-900/50 hover:text-white"
                data-collapse-group="clips" data-collapse-id="${v.id}">
                <span class="inline-flex items-center gap-2">
                  <span class="inline-flex h-6 min-w-[1.5rem] items-center justify-center rounded-md bg-violet-500/15 px-1.5 text-xs font-bold text-violet-300">${clips.length}</span>
                  <span class="font-semibold uppercase tracking-wider text-slate-300">Cortes gerados</span>
                  <span class="rounded-full border border-slate-700 px-2 py-0.5 text-[10px] font-normal text-slate-500">3 por linha</span>
                </span>
                <span class="text-slate-500">${collapseLabel(clipsCollapsed, '▾ Recolher', '▸ Expandir')}</span>
              </button>
              <div class="border-t border-slate-800 p-3 sm:p-4 ${clipsCollapsed ? 'hidden' : ''}">
                <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
                  ${clips.map((c, i) => clipHtml(c, i)).join('')}
                </div>
              </div>
            </div>` : ''}
          </div>
        </article>`;
    }

    function imagemHtml(i) {
      const canPublish = i.status === 'baixado' || i.status === 'publicado';
      return `
        <article class="flex gap-4 rounded-2xl border border-slate-800 bg-slate-900/40 p-4 transition hover:border-slate-700">
          <div class="h-[72px] w-[72px] flex-shrink-0 overflow-hidden rounded-lg bg-slate-950">
            ${i.thumbnail ? `<img src="${escapeHtml(i.thumbnail)}" alt="" class="h-full w-full object-cover" />` : ''}
          </div>
          <div class="min-w-0 flex-1 space-y-1.5">
            <div class="flex flex-wrap items-center gap-1.5">
              ${badge(i.status)}
              ${materiaStatusBadge(i.materia_status)}
              ${i.caminho_local ? `<a href="/media/${escapeHtml(i.caminho_local)}" target="_blank" class="text-xs text-emerald-400 hover:text-emerald-300">arquivo</a>` : ''}
            </div>
            <p class="truncate text-sm font-semibold text-white">"${escapeHtml(i.termo_busca)}"</p>
            <p class="text-xs text-slate-500">${escapeHtml(i.autor || '—')} · ${i.largura && i.altura ? i.largura + '×' + i.altura : 'foto'}</p>
            ${i.erro_mensagem ? `<p class="text-xs text-rose-300">${escapeHtml(i.erro_mensagem)}</p>` : ''}
            ${i.status === 'pendente' || i.status === 'erro'
              ? `<button type="button" class="action-btn mt-1 w-fit rounded-lg bg-emerald-500 px-3.5 py-1.5 text-xs font-semibold text-slate-950 transition hover:bg-emerald-400" data-action="download-imagem" data-id="${i.id}">Baixar</button>`
              : ''}
            ${canPublish ? `
            <div class="flex flex-wrap items-center gap-1.5 pt-1">
              <input type="text" class="img-tema min-w-[140px] flex-1 rounded-lg border border-slate-700 bg-slate-950 px-2.5 py-1.5 text-xs text-slate-100 placeholder:text-slate-600 focus:border-emerald-500 focus:outline-none"
                data-img-tema="${i.id}" placeholder="Tipo de matéria" value="${escapeHtml(i.prompt_materia || '')}" />
              <button type="button" class="ai-btn rounded-lg bg-violet-500 px-3 py-1.5 text-xs font-semibold text-white transition hover:bg-violet-400" data-action="materia-imagem" data-id="${i.id}">Matéria</button>
            </div>
            ${publishFormHtml('imagem', i.id, i.materia || '')}` : ''}
          </div>
        </article>`;
    }

    // —— publicações ——
    function tipoLabel(tipo) {
      const map = { reel: 'Reel', video: 'Vídeo', foto: 'Foto', texto: 'Texto' };
      return map[tipo] || tipo || 'Post';
    }

    function publicacaoRow(p) {
      const texto = String(p.texto || p.legenda_sugerida || '').replace(/\s+/g, ' ').trim();
      const resumo = texto.length > 90 ? texto.slice(0, 90) + '…' : texto;
      return `
        <tr class="bg-slate-950/30 hover:bg-slate-900/60">
          <td class="px-4 py-3 text-slate-200">${tipoLabel(p.tipo)}</td>
          <td class="px-4 py-3 text-slate-300">${escapeHtml(p.page_name || '—')}</td>
          <td class="px-4 py-3 max-w-xs text-slate-400" title="${escapeHtml(texto)}">${escapeHtml(resumo) || '—'}</td>
          <td class="px-4 py-3">${badge(p.status)}</td>
          <td class="px-4 py-3 text-slate-400">${fmtDate(p.published_at || p.created_at)}</td>
          <td class="px-4 py-3">
            ${p.fb_post_url
              ? `<a href="${escapeHtml(p.fb_post_url)}" target="_blank" rel="noopener" class="text-sky-400 hover:text-sky-300">Ver post →</a>`
              : p.erro_mensagem
                ? `<span class="text-rose-300" title="${escapeHtml(p.erro_mensagem)}">erro</span>`
                : '—'}
          </td>
        </tr>`;
    }

    function renderPublicacoes() {
      const status = document.getElementById('publicacoes-status');
      const list = document.getElementById('publicacoes-list');
      const filtro = document.getElementById('publicacoes-filter');
      renderChips(filtro, PUB_STATUSES, allPublicacoes, filterPub, 'pub');

      const filtradas = filterPub === 'todos' ? allPublicacoes : allPublicacoes.filter((p) => p.status === filterPub);
      status.textContent = filtradas.length + ' publicação(ões)';

      if (!filtradas.length) {
        list.innerHTML = emptyHtml('Nenhuma publicação por aqui ainda.', '/materias-ia', 'Ir para Matérias IA →');
        return;
      }

      list.innerHTML = `
        <div class="overflow-hidden rounded-2xl border border-slate-800">
          <table class="w-full text-left text-sm">
            <thead class="bg-slate-950/80 text-xs uppercase tracking-wide text-slate-500">
              <tr>
                <th class="px-4 py-3 font-medium">Tipo</th>
                <th class="px-4 py-3 font-medium">Página</th>
                <th class="px-4 py-3 font-medium">Conteúdo</th>
                <th class="px-4 py-3 font-medium">Status</th>
                <th class="px-4 py-3 font-medium">Quando</th>
                <th class="px-4 py-3 font-medium">Post</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-800">
              ${filtradas.map(publicacaoRow).join('')}
            </tbody>
          </table>
        </div>`;
    }

    function emptyHtml(msg, href = '/busca', label = 'Ir para busca →') {
      return `
        <div class="rounded-2xl border border-dashed border-slate-700 bg-slate-950/40 px-6 py-12 text-center">
          <p class="text-slate-300">${msg}</p>
          <a href="${href}" class="mt-3 inline-block text-sm text-emerald-400 hover:text-emerald-300">${label}</a>
        </div>`;
    }

    function renderVideos() {
      const vStatus = document.getElementById('videos-status');
      const vList = document.getElementById('videos-list');
      const vFilter = document.getElementById('videos-filter');
      renderChips(vFilter, VIDEO_STATUSES, allVideos, filterVideo, 'video');

      const filtrados = filterVideo === 'todos' ? allVideos : allVideos.filter((v) => v.status === filterVideo);
      vStatus.textContent = filtrados.length + ' de ' + allVideos.length + ' vídeo(s)';

      const edits = captureEdits(vList);
      vList.innerHTML = filtrados.length ? filtrados.map(videoHtml).join('') : emptyHtml('Nenhum vídeo nesta visão ainda.');
      restoreEdits(vList, edits);
    }

    function renderImagens() {
      const iStatus = document.getElementById('imagens-status');
      const iList = document.getElementById('imagens-list');
      const iFilter = document.getElementById('imagens-filter');
      renderChips(iFilter, IMAGEM_STATUSES, allImagens, filterImagem, 'imagem');

      const filtradas = filterImagem === 'todos' ? allImagens : allImagens.filter((i) => i.status === filterImagem);
      iStatus.textContent = filtradas.length + ' de ' + allImagens.length + ' imagem(ns)';

      const edits = captureEdits(iList);
      iList.innerHTML = filtradas.length ? filtradas.map(imagemHtml).join('') : emptyHtml('Nenhuma imagem nesta visão ainda.');
      restoreEdits(iList, edits);
    }

    function updateCounts() {
      document.getElementById('count-videos').textContent = allVideos.length ? '(' + allVideos.length + ')' : '';
      document.getElementById('count-imagens').textContent = allImagens.length ? '(' + allImagens.length + ')' : '';
      document.getElementById('count-publicacoes').textContent = allPublicacoes.length ? '(' + allPublicacoes.length + ')' : '';
    }

    async function loadFila() {
      try {
        const [vRes, iRes, pRes, pubRes] = await Promise.all([
          fetch('/api/videos'),
          fetch('/api/imagens'),
          fetch('/api/facebook/pages'),
          fetch('/api/publications'),
        ]);
        const vData = await vRes.json();
        const iData = await iRes.json();
        const pData = pRes.ok ? await pRes.json() : { pages: [] };
        const pubData = pubRes.ok ? await pubRes.json() : { publications: [] };

        fbPages = pData.pages || [];
        allVideos = vData.videos || [];
        allImagens = iData.imagens || [];
        allPublicacoes = pubData.publications || [];

        updateCounts();
        renderVideos();
        renderImagens();
        renderPublicacoes();

        const textPages = document.getElementById('text-post-pages');
        textPages.innerHTML = fbPages.length
          ? pageSelectHtml()
          : '<a href="/paginas" class="text-xs text-sky-400 hover:text-sky-300">Conecte uma página para publicar →</a>';

        lastUpdatedEl.textContent = 'Atualizado ' + new Date().toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
      } catch (err) {
        showError(err.message || 'Erro ao carregar fila');
      }
    }

    // —— abas ——
    document.querySelectorAll('.tab-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        activeTab = btn.dataset.tab;
        document.querySelectorAll('.tab-btn').forEach((b) => {
          const on = b === btn;
          b.classList.toggle('bg-emerald-500', on);
          b.classList.toggle('text-slate-950', on);
          b.classList.toggle('font-semibold', on);
          b.classList.toggle('text-slate-300', !on);
        });
        document.querySelectorAll('.tab-panel').forEach((p) => p.classList.toggle('hidden', p.id !== 'tab-' + activeTab));
      });
    });

    // —— filtros / recolher / atalhos (delegado) ——
    document.addEventListener('click', (e) => {
      const collapseBtn = e.target.closest('.collapse-btn');
      if (collapseBtn) {
        const group = collapseBtn.dataset.collapseGroup;
        const id = collapseBtn.dataset.collapseId;
        if (group && id != null) {
          setCollapsed(group, id, !isCollapsed(group, id));
          renderVideos();
        }
        return;
      }

      const preset = e.target.closest('.fim-preset');
      if (preset) {
        const form = preset.closest('.clip-form');
        if (!form) return;
        const fimInput = form.querySelector('input[name="fim"]');
        if (!fimInput) return;
        fimInput.value = preset.dataset.fim;
        fimInput.dispatchEvent(new Event('input', { bubbles: true }));
        return;
      }

      const chip = e.target.closest('.filter-chip');
      if (!chip) return;
      const group = chip.dataset.filterGroup;
      const value = chip.dataset.filterValue;
      if (group === 'video') { filterVideo = value; renderVideos(); }
      else if (group === 'imagem') { filterImagem = value; renderImagens(); }
      else if (group === 'pub') { filterPub = value; renderPublicacoes(); }
    });

    document.getElementById('collapse-all-videos').addEventListener('click', () => {
      allVideos.forEach((v) => {
        setCollapsed('video', v.id, true);
        setCollapsed('form', v.id, true);
        setCollapsed('clips', v.id, true);
      });
      renderVideos();
    });

    document.getElementById('expand-all-videos').addEventListener('click', () => {
      allVideos.forEach((v) => {
        setCollapsed('video', v.id, false);
        setCollapsed('form', v.id, false);
        setCollapsed('clips', v.id, false);
      });
      renderVideos();
    });

    // —— ações de IA (gerar matéria, transcrever, retentar) ——
    document.addEventListener('click', async (e) => {
      const aiBtn = e.target.closest('.ai-btn');
      if (aiBtn) {
        const { action, id } = aiBtn.dataset;
        let url = '';
        let body = {};

        if (action === 'transcribe-clip') {
          url = '/api/clips/' + id + '/transcribe';
        } else if (action === 'retry-clip') {
          url = '/api/clips/' + id + '/retry';
        } else if (action === 'materia-clip') {
          url = '/api/clips/' + id + '/materia';
          const temaInput = document.querySelector('[data-clip-tema="' + id + '"]');
          body.tema = temaInput ? temaInput.value.trim() : '';
        } else if (action === 'materia-imagem') {
          url = '/api/imagens/' + id + '/materia';
          const temaInput = document.querySelector('[data-img-tema="' + id + '"]');
          body.tema = temaInput ? temaInput.value.trim() : '';
          if (!body.tema) {
            showError('Informe o tipo/tema da matéria (ex.: curiosidade, dica)');
            return;
          }
        } else {
          return;
        }

        aiBtn.disabled = true;
        const prev = aiBtn.textContent;
        aiBtn.textContent = 'Enviando…';
        try {
          const res = await fetch(url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body),
          });
          const data = await res.json();
          if (!res.ok) throw new Error(data.error || 'Falha na operação de IA');
          setTimeout(loadFila, 2500);
        } catch (err) {
          showError(err.message);
        } finally {
          aiBtn.disabled = false;
          aiBtn.textContent = prev;
        }
        return;
      }

      const btn = e.target.closest('.action-btn');
      if (!btn) return;

      const { action, id } = btn.dataset;
      const prevLabel = btn.textContent;
      btn.disabled = true;

      try {
        if (action === 'delete-clip') {
          if (!confirm('Excluir este corte?')) { btn.disabled = false; return; }
          const res = await fetch('/api/clips/' + id, { method: 'DELETE' });
          const data = await res.json();
          if (!res.ok) throw new Error(data.error || 'Falha ao excluir corte');
          loadFila();
          return;
        }

        if (action === 'delete-video') {
          if (!confirm('Excluir este vídeo e todos os cortes?')) { btn.disabled = false; return; }
          const res = await fetch('/api/videos/' + id, { method: 'DELETE' });
          const data = await res.json();
          if (!res.ok) throw new Error(data.error || 'Falha ao excluir vídeo');
          loadFila();
          return;
        }

        if (action === 'analyze-video') {
          btn.textContent = 'IA analisando…';
          const aspectSelect = btn.closest('article')?.querySelector('.clip-form select[name="aspect_ratio"]');
          const res = await fetch('/api/videos/' + id + '/analyze', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              aspect_ratio: aspectSelect?.value || '9:16',
              max_cortes: 3,
              gerar: true,
            }),
          });
          const data = await res.json();
          if (!res.ok) throw new Error(data.error || 'Falha ao analisar cortes com IA');
          setCollapsed('video', id, false);
          setCollapsed('clips', id, false);
          setTimeout(loadFila, 2000);
          setTimeout(loadFila, 15000);
          return;
        }

        if (action === 'clip-auto') {
          btn.textContent = 'Gerando cortes…';
          const aspectSelect = btn.closest('article')?.querySelector('.clip-form select[name="aspect_ratio"]');
          const res = await fetch('/api/videos/' + id + '/clip-auto', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              intervalo: 90,
              aspect_ratio: aspectSelect?.value || btn.dataset.aspect || '9:16',
            }),
          });
          const data = await res.json();
          if (!res.ok) throw new Error(data.error || 'Falha ao gerar cortes automáticos');
          setTimeout(loadFila, 2000);
          return;
        }

        const url = action === 'download-video'
          ? '/api/videos/' + id + '/download'
          : '/api/imagens/' + id + '/download';

        btn.textContent = 'Enfileirado…';
        const res = await fetch(url, { method: 'POST' });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Falha ao enfileirar download');
        setTimeout(loadFila, 2500);
      } catch (err) {
        showError(err.message);
      } finally {
        btn.disabled = false;
        btn.textContent = prevLabel;
      }
    });

    document.getElementById('text-post-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target;
      const select = form.querySelector('select[name="facebook_page_id"]');
      if (!select) return showError('Conecte uma página do Facebook antes de publicar');

      const submitBtn = form.querySelector('button[type="submit"]');
      const original = submitBtn.textContent;
      submitBtn.disabled = true;
      submitBtn.textContent = 'Publicando…';

      try {
        const res = await fetch('/api/publications/text', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            facebook_page_id: Number(select.value),
            texto: form.texto.value.trim(),
            link: form.link.value.trim(),
          }),
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Falha ao publicar texto');
        form.texto.value = '';
        form.link.value = '';
        submitBtn.textContent = 'Na fila ✓';
        setTimeout(loadFila, 2000);
        setTimeout(() => { submitBtn.disabled = false; submitBtn.textContent = original; }, 4000);
      } catch (err) {
        submitBtn.disabled = false;
        submitBtn.textContent = original;
        showError(err.message);
      }
    });

    document.addEventListener('submit', async (e) => {
      const pubForm = e.target.closest('.publish-form');
      if (pubForm) {
        e.preventDefault();
        const { kind, id } = pubForm.dataset;
        const submitBtn = pubForm.querySelector('button[type="submit"]');
        if (!submitBtn || !pubForm.facebook_page_id) {
          showError('Conecte uma página do Facebook para publicar');
          return;
        }
        submitBtn.disabled = true;
        submitBtn.textContent = 'Publicando…';

        const url = kind === 'clip'
          ? '/api/clips/' + id + '/publish'
          : '/api/imagens/' + id + '/publish';

        try {
          const legenda = pubForm.legenda.value.trim();
          if (!legenda) {
            throw new Error('A matéria ainda não apareceu no campo. Clique em “Refazer matéria” ou aguarde alguns segundos e tente de novo.');
          }
          const body = {
            facebook_page_id: Number(pubForm.facebook_page_id.value),
            legenda,
          };
          if (kind === 'clip') {
            body.modo = pubForm.modo?.value || 'reel';
            body.titulo = pubForm.titulo?.value?.trim() || '';
          }
          const res = await fetch(url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body),
          });
          const data = await res.json().catch(() => ({}));
          if (!res.ok) throw new Error(data.error || 'Falha ao publicar');
          if (data.avisos && data.avisos.length) showError('Aviso: ' + data.avisos.join(' · '));
          submitBtn.textContent = 'Na fila de publicação ✓';
          setTimeout(loadFila, 4000);
        } catch (err) {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Publicar';
          showError(err.message);
        }
        return;
      }

      const form = e.target.closest('.clip-form');
      if (!form) return;
      e.preventDefault();

      const id = form.dataset.id;
      const inicio = Number(form.inicio.value);
      const fim = Number(form.fim.value);
      const duracaoCorte = fim - inicio;

      if (!Number.isFinite(inicio) || !Number.isFinite(fim) || fim <= inicio) {
        showError('Informe início e fim válidos (fim deve ser maior que início)');
        return;
      }
      if (duracaoCorte < 3) {
        showError('O corte precisa ter no mínimo 3 segundos (exigência do Facebook Reels). Ex.: início 0 e fim 15.');
        return;
      }
      const maxVideo = Number(form.dataset.max) || 1800;
      if (duracaoCorte > 1800) {
        showError('Corte máximo de 30 minutos');
        return;
      }
      if (fim > maxVideo + 1) {
        showError('Fim além da duração do vídeo (' + maxVideo + 's)');
        return;
      }

      const submitBtn = form.querySelector('button[type="submit"]');
      submitBtn.disabled = true;

      try {
        const res = await fetch('/api/videos/' + id + '/clip', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ inicio, fim, aspect_ratio: form.aspect_ratio.value }),
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Falha ao criar corte');
        if (data.aviso) showError(data.aviso);
        setTimeout(loadFila, 1500);
      } catch (err) {
        showError(err.message);
      } finally {
        submitBtn.disabled = false;
      }
    });

    refreshBtn.addEventListener('click', loadFila);
    loadFila();
    setInterval(loadFila, 15000);
  </script>
<%- include('partials/app-end') %>
