<%- include('partials/app-start') %>

  <main class="mx-auto max-w-9xl px-4 py-5 sm:px-6 sm:py-8">
    <div class="flex flex-wrap items-start justify-between gap-3">
      <div>
        <a href="/conteudo" class="text-xs font-medium text-slate-500 hover:text-emerald-300">← Voltar para Pautas</a>
        <h1 class="mt-2 text-2xl font-semibold text-white">Gerando matérias</h1>
        <p class="mt-1 text-sm text-slate-400">As pautas vão ficando prontas uma a uma. Clique para editar quando quiser.</p>
      </div>
      <div class="text-right">
        <p id="lote-progress" class="text-sm font-medium text-slate-300">—</p>
        <p id="lote-hint" class="mt-0.5 text-xs text-slate-500"></p>
      </div>
    </div>

    <div id="lote-empty" class="mt-8 hidden rounded-2xl border border-dashed border-slate-700 bg-slate-950/40 px-6 py-12 text-center">
      <p class="text-slate-300">Nenhuma pauta selecionada para o lote.</p>
      <a href="/conteudo" class="mt-3 inline-block text-sm text-emerald-400 hover:text-emerald-300">Escolher assuntos →</a>
    </div>

    <div id="lote-list" class="mt-6 space-y-2"></div>
  </main>

  <script src="/js/conteudo-lote.js"></script>
<%- include('partials/app-end') %>
