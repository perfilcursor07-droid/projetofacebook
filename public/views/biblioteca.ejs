<%- include('partials/app-start') %>
<%
  const fontesList = fontes || [];
  const alertasList = alertas || [];
  const auto = autopilot || {};
  const melhoresList = melhores || [];
  const naoLidos = Number(alertasNaoLidos || 0);
  const totalPosts = fontesList.reduce(function (acc, f) { return acc + Number(f.posts_count || 0); }, 0);
  const fontesMonitoradas = fontesList.filter(function (f) { return Boolean(f.monitorar); }).length;
  function platClass(p) {
    const k = String(p || '').toLowerCase();
    if (k === 'youtube') return 'bg-rose-500/15 text-rose-300 ring-rose-500/20';
    if (k === 'facebook') return 'bg-sky-500/15 text-sky-300 ring-sky-500/20';
    if (k === 'instagram') return 'bg-fuchsia-500/15 text-fuchsia-300 ring-fuchsia-500/20';
    if (k === 'tiktok') return 'bg-slate-100/10 text-slate-200 ring-slate-500/30';
    if (k === 'site') return 'bg-amber-500/15 text-amber-300 ring-amber-500/20';
    return 'bg-slate-800 text-slate-300 ring-slate-700';
  }
  function fmtQuando(d) {
    if (!d) return '';
    try {
      return new Date(d).toLocaleString('pt-BR', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' });
    } catch (_) {
      return '';
    }
  }
%>

  <main class="mx-auto max-w-9xl px-4 py-5 sm:px-6 sm:py-8" id="biblioteca-app"
    data-alertas-nao-lidos="<%= naoLidos %>">

    <!-- Cabeçalho -->
    <header class="relative overflow-hidden rounded-2xl border border-slate-800 bg-slate-900/60 p-5 sm:p-7">
      <div class="pointer-events-none absolute -right-20 -top-24 h-64 w-64 rounded-full bg-emerald-500/10 blur-3xl"></div>
      <div class="relative flex flex-col gap-5 lg:flex-row lg:items-center lg:justify-between">
        <div class="min-w-0">
          <div class="mb-2 flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.18em] text-emerald-400">
            <span class="h-1.5 w-1.5 rounded-full bg-emerald-400"></span>
            Central de conteúdo
          </div>
          <h1 class="text-2xl font-semibold tracking-tight text-white sm:text-3xl">Biblioteca de fontes</h1>
          <p class="mt-2 max-w-2xl text-sm leading-relaxed text-slate-400">
            Acompanhe canais, perfis e sites em um só lugar. Gerencie suas fontes, confira novidades e transforme posts em conteúdo.
          </p>
        </div>
        <nav class="flex flex-wrap items-center gap-2" aria-label="Ações da biblioteca">
          <a href="#bib-adicionar-fonte"
            class="inline-flex items-center gap-2 rounded-lg bg-emerald-500 px-3.5 py-2.5 text-sm font-semibold text-slate-950 transition hover:bg-emerald-400">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 5v14M5 12h14" /></svg>
            Adicionar fonte
          </a>
          <a href="#bib-secao-alertas"
            class="relative inline-flex items-center gap-2 rounded-lg border border-slate-700 bg-slate-950/40 px-3.5 py-2.5 text-sm text-slate-300 transition hover:border-emerald-500/50 hover:text-emerald-300">
            Alertas
            <span id="bib-badge" class="<%= naoLidos ? '' : 'hidden' %> inline-flex min-w-[1.25rem] items-center justify-center rounded-full bg-emerald-500 px-1.5 py-0.5 text-[10px] font-bold text-slate-950"><%= naoLidos %></span>
          </a>
          <a href="/minhas-materias"
            class="rounded-lg border border-slate-700 bg-slate-950/40 px-3.5 py-2.5 text-sm text-slate-300 transition hover:border-slate-500 hover:text-white">
            Minhas matérias
          </a>
        </nav>
      </div>
    </header>

    <!-- Resumo -->
    <section class="mt-4 grid grid-cols-2 gap-3 lg:grid-cols-4" aria-label="Resumo da biblioteca">
      <div class="rounded-xl border border-slate-800 bg-slate-900/40 p-4">
        <div class="flex items-center justify-between gap-3">
          <p class="text-[11px] font-medium uppercase tracking-wider text-slate-500">Fontes salvas</p>
          <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-slate-800 text-slate-400">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><circle cx="12" cy="12" r="3" /><path d="M19.4 15a1.7 1.7 0 0 0 .34 1.88l.06.06-2.83 2.83-.06-.06A1.7 1.7 0 0 0 15 19.4a1.7 1.7 0 0 0-1 .6 1.7 1.7 0 0 0-.4 1.1V21H9.6v-.09A1.7 1.7 0 0 0 8.55 19.4a1.7 1.7 0 0 0-1.88.34l-.06.06-2.83-2.83.06-.06A1.7 1.7 0 0 0 4.2 15a1.7 1.7 0 0 0-.6-1 1.7 1.7 0 0 0-1.1-.4H2.4V9.6h.09A1.7 1.7 0 0 0 4 8.55a1.7 1.7 0 0 0-.34-1.88l-.06-.06 2.83-2.83.06.06A1.7 1.7 0 0 0 8.4 4.2a1.7 1.7 0 0 0 1-.6A1.7 1.7 0 0 0 9.8 2.5V2.4h4v.09A1.7 1.7 0 0 0 14.85 4a1.7 1.7 0 0 0 1.88-.34l.06-.06 2.83 2.83-.06.06A1.7 1.7 0 0 0 19.2 8.4a1.7 1.7 0 0 0 .6 1 1.7 1.7 0 0 0 1.1.4h.1v4h-.09A1.7 1.7 0 0 0 19.4 15Z" /></svg>
          </span>
        </div>
        <p class="mt-3 text-2xl font-semibold tabular-nums text-white"><%= fontesList.length %></p>
      </div>
      <div class="rounded-xl border border-slate-800 bg-slate-900/40 p-4">
        <div class="flex items-center justify-between gap-3">
          <p class="text-[11px] font-medium uppercase tracking-wider text-slate-500">Monitorando</p>
          <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-emerald-500/10 text-emerald-400">
            <span class="relative flex h-2.5 w-2.5"><span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-40"></span><span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-emerald-400"></span></span>
          </span>
        </div>
        <p class="mt-3 text-2xl font-semibold tabular-nums text-white"><%= fontesMonitoradas %></p>
      </div>
      <div class="rounded-xl border border-slate-800 bg-slate-900/40 p-4">
        <div class="flex items-center justify-between gap-3">
          <p class="text-[11px] font-medium uppercase tracking-wider text-slate-500">Posts encontrados</p>
          <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-sky-500/10 text-sky-400">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" /><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2Z" /></svg>
          </span>
        </div>
        <p class="mt-3 text-2xl font-semibold tabular-nums text-white"><%= totalPosts %></p>
      </div>
      <div class="rounded-xl border <%= naoLidos ? 'border-emerald-500/30 bg-emerald-500/5' : 'border-slate-800 bg-slate-900/40' %> p-4">
        <div class="flex items-center justify-between gap-3">
          <p class="text-[11px] font-medium uppercase tracking-wider text-slate-500">Alertas novos</p>
          <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-amber-500/10 text-amber-400">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M18 8a6 6 0 0 0-12 0c0 7-3 7-3 9h18c0-2-3-2-3-9M13.7 21h-3.4" /></svg>
          </span>
        </div>
        <p class="mt-3 text-2xl font-semibold tabular-nums <%= naoLidos ? 'text-emerald-300' : 'text-white' %>"><%= naoLidos %></p>
      </div>
    </section>

    <% if (!auto.ativo) { %>
      <!-- Recomendações editoriais para fluxo manual -->
      <section id="bib-melhores" class="mt-6 overflow-hidden rounded-2xl border border-violet-500/20 bg-slate-900/50">
        <div class="flex flex-col gap-4 border-b border-slate-800 p-4 sm:flex-row sm:items-center sm:justify-between sm:p-5">
          <div class="flex min-w-0 items-start gap-3">
            <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-violet-500/10 text-violet-300">
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="m12 3 1.8 5.2L19 10l-5.2 1.8L12 17l-1.8-5.2L5 10l5.2-1.8L12 3Z" /><path d="m19 16 .8 2.2L22 19l-2.2.8L19 22l-.8-2.2L16 19l2.2-.8L19 16Z" /></svg>
            </span>
            <div>
              <div class="flex flex-wrap items-center gap-2">
                <h2 class="text-sm font-semibold text-white">Melhores para publicar</h2>
                <span class="rounded-md bg-slate-800 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-slate-400">modo manual</span>
              </div>
              <p class="mt-1 max-w-2xl text-xs leading-relaxed text-slate-500">A IA compara os conteúdos de todas as fontes e mostra todas as sugestões com pontuação 50/100 ou maior. Você escolhe o que preparar; nada é publicado automaticamente.</p>
            </div>
          </div>
          <div class="flex flex-col gap-2 sm:min-w-[14rem] sm:flex-row sm:items-end">
            <% if ((pages || []).length) { %>
              <label class="min-w-0 flex-1">
                <span class="text-[10px] font-medium uppercase tracking-wide text-slate-600">Página de destino</span>
                <select id="bib-melhores-page" class="mt-1 w-full rounded-lg border border-slate-700 bg-slate-950 px-2.5 py-2 text-xs text-white focus:border-violet-500 focus:outline-none">
                  <option value="">Selecionar depois</option>
                  <% (pages || []).forEach(function (p) { %>
                    <option value="<%= p.id %>" <%= Number(auto.facebook_page_id) === Number(p.id) ? 'selected' : '' %>><%= p.page_name %></option>
                  <% }) %>
                </select>
              </label>
            <% } %>
            <button type="button" id="bib-analisar-melhores" class="shrink-0 rounded-lg border border-violet-500/40 bg-violet-500/10 px-3 py-2 text-xs font-semibold text-violet-200 transition hover:bg-violet-500/20">
              <%= melhoresList.length ? 'Atualizar análise' : 'Analisar agora' %>
            </button>
          </div>
        </div>

        <% if (!melhoresList.length) { %>
          <div class="px-5 py-10 text-center">
            <p class="text-sm font-medium text-slate-300">Nenhuma análise manual disponível</p>
            <p class="mx-auto mt-1 max-w-lg text-xs leading-relaxed text-slate-500">Escaneie suas fontes e clique em <strong class="font-medium text-slate-400">Analisar agora</strong>. A IA mostrará as pautas com pontuação 50/100 ou maior, sem iniciar nenhuma publicação.</p>
          </div>
        <% } else { %>
          <div class="relative">
            <div class="pointer-events-none absolute inset-y-0 left-0 z-10 w-6 bg-gradient-to-r from-slate-950/80 to-transparent sm:w-8"></div>
            <div class="pointer-events-none absolute inset-y-0 right-0 z-10 w-8 bg-gradient-to-l from-slate-950/90 to-transparent sm:w-12"></div>
            <div id="bib-melhores-track"
              class="flex snap-x snap-mandatory gap-3 overflow-x-auto scroll-smooth px-4 py-4 sm:px-5 [scrollbar-width:thin] [&::-webkit-scrollbar]:h-1.5 [&::-webkit-scrollbar-thumb]:rounded-full [&::-webkit-scrollbar-thumb]:bg-slate-700">
              <% melhoresList.forEach(function (p, index) { %>
                <% const isVideo = p.media_type === 'video' || /instagram\.com\/(reel|reels|tv)\//i.test(String(p.url || '')); %>
                <article
                  class="flex w-[16.5rem] shrink-0 snap-start flex-col rounded-xl border border-slate-800 bg-slate-950/80 p-3.5 sm:w-[18rem]"
                  data-melhor-post="<%= p.id %>">
                  <div class="flex items-center justify-between gap-2">
                    <div class="flex min-w-0 items-center gap-2">
                      <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-violet-500/15 text-[11px] font-bold text-violet-200"><%= index + 1 %></span>
                      <span class="truncate text-[10px] font-semibold uppercase tracking-wide text-slate-500"><%= p.fonte_nome || p.fonte_plataforma %></span>
                    </div>
                    <span class="shrink-0 rounded-full bg-emerald-500/10 px-2 py-0.5 text-[10px] font-bold tabular-nums text-emerald-300"><%= Number(p.viral_score || 0) %>/100</span>
                  </div>
                  <% if (p.thumbnail) { %>
                    <div class="relative mt-3 aspect-video overflow-hidden rounded-lg bg-slate-900">
                      <img src="<%= p.thumbnail %>" alt="" loading="lazy" class="h-full w-full object-cover" referrerpolicy="no-referrer" />
                      <% if (isVideo) { %>
                        <span class="absolute bottom-2 left-2 rounded-md bg-slate-950/85 px-2 py-1 text-[10px] font-semibold text-white backdrop-blur">▶ Reel</span>
                      <% } %>
                    </div>
                  <% } %>
                  <h3 class="mt-3 line-clamp-3 text-sm font-semibold leading-snug text-white"><%= p.titulo || 'Conteúdo sem título' %></h3>
                  <p class="mt-2 line-clamp-2 text-xs leading-relaxed text-violet-200/70"><%= p.viral_reason || 'Selecionado pela análise editorial da IA.' %></p>
                  <div class="mt-auto grid grid-cols-2 gap-2 pt-3">
                    <button type="button" class="bib-preparar-melhor rounded-lg border border-violet-500/40 bg-violet-500/10 px-3 py-2 text-xs font-semibold text-violet-200 transition hover:bg-violet-500/20" data-id="<%= p.id %>" data-media="<%= isVideo ? 'video' : 'post' %>" title="Gerar e abrir para revisão antes de publicar">
                      Preparar
                    </button>
                    <button type="button" class="bib-publicar-melhor rounded-lg bg-emerald-500 px-3 py-2 text-xs font-semibold text-slate-950 transition hover:bg-emerald-400" data-id="<%= p.id %>" data-media="<%= isVideo ? 'video' : 'post' %>" title="Gerar e publicar diretamente na página selecionada">
                      Publicar
                    </button>
                    <a href="<%= p.url %>" target="_blank" rel="noopener" class="col-span-2 rounded-lg border border-slate-800 px-3 py-1.5 text-center text-[11px] text-slate-500 transition hover:border-slate-700 hover:text-white">
                      Ver conteúdo original ↗
                    </a>
                  </div>
                </article>
              <% }) %>
            </div>
          </div>
          <div class="flex flex-wrap items-center justify-between gap-2 border-t border-slate-800 px-4 py-3 text-[11px] text-slate-600 sm:px-5">
            <span>Análise atualizada em <%= fmtQuando(melhoresList[0].viral_analyzed_at) %>. Pontuação ≥ 50/100 — recomendação editorial, não garantia de alcance.</span>
            <span class="shrink-0 text-slate-500">← deslize para o lado →</span>
          </div>
        <% } %>
      </section>
    <% } %>

    <!-- Área principal -->
    <div class="mt-6 grid items-start gap-6 xl:grid-cols-[minmax(0,1.55fr)_minmax(22rem,0.8fr)]">
      <div class="min-w-0 space-y-6">
        <!-- Adicionar fonte -->
        <section id="bib-adicionar-fonte" class="scroll-mt-6 overflow-hidden rounded-2xl border border-slate-800 bg-slate-900/40">
          <div class="border-b border-slate-800 px-4 py-4 sm:px-5">
            <div class="flex items-start gap-3">
              <span class="mt-0.5 flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-emerald-500/10 text-emerald-400">
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 5v14M5 12h14" /></svg>
              </span>
              <div>
                <h2 class="text-sm font-semibold text-white">Adicionar uma nova fonte</h2>
                <p class="mt-1 text-xs leading-relaxed text-slate-500">Cole a URL de um perfil, canal ou site de notícias. A plataforma será identificada automaticamente.</p>
              </div>
            </div>
          </div>
          <form id="bib-form" class="grid gap-4 p-4 sm:grid-cols-2 sm:p-5 lg:grid-cols-12 lg:items-end">
            <label class="block sm:col-span-2 lg:col-span-7">
              <span class="text-xs font-medium text-slate-400">URL do perfil, canal ou site <span class="text-emerald-400">*</span></span>
              <input id="bib-url" name="url" required
                placeholder="https://instagram.com/perfil ou youtube.com/@canal"
                class="mt-1.5 w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2.5 text-sm text-white placeholder:text-slate-600 focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500/30" />
            </label>
            <label class="block lg:col-span-5">
              <span class="text-xs font-medium text-slate-400">Nome de identificação <span class="font-normal text-slate-600">(opcional)</span></span>
              <input id="bib-nome" name="nome" maxlength="200" placeholder="Ex.: Canal de notícias"
                class="mt-1.5 w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2.5 text-sm text-white placeholder:text-slate-600 focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500/30" />
            </label>
            <label class="block sm:col-span-2 lg:col-span-7">
              <span class="text-xs font-medium text-slate-400">Página do Facebook <span class="font-normal text-slate-600">(opcional)</span></span>
              <select id="bib-page" name="facebook_page_id"
                class="mt-1.5 w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2.5 text-sm text-white focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500/30">
                <option value="">Vincular depois</option>
                <% (pages || []).forEach(function (p) { %>
                  <option value="<%= p.id %>"><%= p.page_name %></option>
                <% }) %>
              </select>
            </label>
            <label class="flex min-h-[42px] items-center gap-2.5 rounded-lg border border-slate-800 bg-slate-950/40 px-3 lg:col-span-2">
              <input id="bib-monitorar" type="checkbox" class="rounded border-slate-600 bg-slate-950 text-emerald-500 focus:ring-emerald-500/30" />
              <span class="text-xs text-slate-300">Monitorar fonte</span>
            </label>
            <button type="submit" class="w-full rounded-lg bg-emerald-500 px-4 py-2.5 text-sm font-semibold text-slate-950 transition hover:bg-emerald-400 lg:col-span-3">
              Salvar fonte
            </button>
            <p id="bib-form-msg" class="hidden text-sm sm:col-span-2 lg:col-span-12"></p>
          </form>
        </section>

        <!-- Fontes -->
        <section aria-labelledby="bib-fontes-titulo">
          <div class="mb-3 flex items-end justify-between gap-3">
            <div>
              <p class="text-[11px] font-medium uppercase tracking-[0.16em] text-slate-600">Coleção</p>
              <h2 id="bib-fontes-titulo" class="mt-1 text-base font-semibold text-white">Suas fontes</h2>
            </div>
            <span class="rounded-full border border-slate-800 bg-slate-900/50 px-2.5 py-1 text-xs tabular-nums text-slate-500"><%= fontesList.length %> salva<%= fontesList.length === 1 ? '' : 's' %></span>
          </div>

          <div id="bib-fontes" class="space-y-3">
            <% if (!fontesList.length) { %>
              <div class="rounded-2xl border border-dashed border-slate-700 bg-slate-900/20 px-5 py-14 text-center">
                <span class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-slate-800/80 text-slate-500">
                  <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" /><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2Z" /></svg>
                </span>
                <p class="mt-4 text-sm font-medium text-slate-300">Sua biblioteca está vazia</p>
                <p class="mx-auto mt-1 max-w-sm text-xs leading-relaxed text-slate-500">Adicione acima o link de um canal, perfil ou site para começar a acompanhar novos conteúdos.</p>
                <a href="#bib-adicionar-fonte" class="mt-4 inline-flex text-xs font-medium text-emerald-400 hover:text-emerald-300">Adicionar primeira fonte →</a>
              </div>
            <% } %>

            <% fontesList.forEach(function (f) { %>
              <article class="bib-fonte group overflow-hidden rounded-2xl border border-slate-800 bg-slate-900/40 transition hover:border-slate-700 hover:bg-slate-900/60" data-id="<%= f.id %>" data-plataforma="<%= f.plataforma %>">
                <div class="p-4 sm:p-5">
                  <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
                    <a href="/biblioteca/fontes/<%= f.id %>" class="min-w-0 flex-1 rounded-lg outline-none focus-visible:ring-2 focus-visible:ring-emerald-500/50">
                      <div class="flex flex-wrap items-center gap-2">
                        <span class="inline-flex items-center rounded-md px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide ring-1 ring-inset <%= platClass(f.plataforma) %>"><%= f.plataforma %></span>
                        <% if (f.monitorar) { %>
                          <span class="inline-flex items-center gap-1.5 rounded-md bg-emerald-500/10 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-emerald-300 ring-1 ring-inset ring-emerald-500/25">
                            <span class="h-1.5 w-1.5 rounded-full bg-emerald-400"></span>
                            monitorando
                          </span>
                        <% } else { %>
                          <span class="rounded-md bg-slate-800 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-slate-500">pausada</span>
                        <% } %>
                      </div>
                      <h3 class="mt-2 truncate text-base font-semibold text-white transition group-hover:text-emerald-300"><%= f.nome %></h3>
                      <p class="mt-1 truncate text-xs text-slate-500"><%= f.url %></p>
                      <div class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-1 text-xs text-slate-500">
                        <span><strong class="font-medium tabular-nums text-slate-300"><%= Number(f.posts_count || 0) %></strong> post<%= Number(f.posts_count || 0) === 1 ? '' : 's' %></span>
                        <% if (f.ultimo_erro) { %>
                          <span class="text-rose-300">Falha no último scan</span>
                        <% } else if (f.ultimo_scan) { %>
                          <span>Atualizada em <%= fmtQuando(f.ultimo_scan) %></span>
                        <% } else { %>
                          <span>Aguardando primeiro scan</span>
                        <% } %>
                      </div>
                      <% if (f.ultimo_erro) { %>
                        <p class="mt-2 rounded-lg bg-rose-500/5 px-3 py-2 text-xs leading-relaxed text-rose-300"><%= f.ultimo_erro %></p>
                      <% } %>
                    </a>
                    <a href="/biblioteca/fontes/<%= f.id %>" class="inline-flex shrink-0 items-center justify-center gap-1.5 rounded-lg border border-emerald-500/40 bg-emerald-500/10 px-3 py-2 text-xs font-semibold text-emerald-300 transition hover:bg-emerald-500/20">
                      Ver posts
                      <span aria-hidden="true">→</span>
                    </a>
                  </div>
                </div>
                <div class="flex flex-wrap items-center gap-2 border-t border-slate-800/80 bg-slate-950/20 px-4 py-2.5 sm:px-5">
                  <button type="button" class="bib-scan rounded-md px-2.5 py-1.5 text-xs font-medium text-slate-400 transition hover:bg-emerald-500/10 hover:text-emerald-300" data-id="<%= f.id %>">Escanear agora</button>
                  <button type="button" class="bib-toggle-mon rounded-md px-2.5 py-1.5 text-xs font-medium text-slate-400 transition hover:bg-sky-500/10 hover:text-sky-300" data-id="<%= f.id %>" data-on="<%= f.monitorar ? '1' : '0' %>">
                    <%= f.monitorar ? 'Pausar monitoramento' : 'Iniciar monitoramento' %>
                  </button>
                  <span class="hidden h-4 w-px bg-slate-800 sm:block"></span>
                  <button type="button" class="bib-del ml-auto rounded-md px-2.5 py-1.5 text-xs font-medium text-rose-400/80 transition hover:bg-rose-500/10 hover:text-rose-300" data-id="<%= f.id %>">Excluir</button>
                </div>
              </article>
            <% }) %>
          </div>
        </section>
      </div>

      <!-- Alertas globais -->
      <aside id="bib-secao-alertas" class="scroll-mt-6 overflow-hidden rounded-2xl border border-slate-800 bg-slate-900/40 xl:sticky xl:top-6">
        <div class="border-b border-slate-800 px-4 py-4 sm:px-5">
          <div class="flex items-start justify-between gap-3">
            <div class="min-w-0">
              <div class="flex items-center gap-2">
                <h2 class="text-sm font-semibold text-white">Alertas recentes</h2>
                <% if (naoLidos) { %>
                  <span class="rounded-full bg-emerald-500/15 px-2 py-0.5 text-[10px] font-semibold text-emerald-300"><%= naoLidos %> novo<%= naoLidos === 1 ? '' : 's' %></span>
                <% } %>
              </div>
              <p class="mt-1 text-xs text-slate-500">Novidades de todas as fontes monitoradas.</p>
            </div>
            <button type="button" id="bib-mark-all" class="shrink-0 text-xs font-medium text-slate-500 transition hover:text-emerald-400 <%= alertasList.length ? '' : 'invisible' %>">
              Marcar lidos
            </button>
          </div>
        </div>

        <div id="bib-alertas" class="max-h-[42rem] divide-y divide-slate-800/80 overflow-y-auto">
          <% if (!alertasList.length) { %>
            <div class="px-5 py-14 text-center">
              <span class="mx-auto flex h-11 w-11 items-center justify-center rounded-full bg-slate-800/70 text-slate-500">
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M18 8a6 6 0 0 0-12 0c0 7-3 7-3 9h18c0-2-3-2-3-9M13.7 21h-3.4" /></svg>
              </span>
              <p class="mt-3 text-sm font-medium text-slate-400">Nenhum alerta por enquanto</p>
              <p class="mt-1 text-xs leading-relaxed text-slate-600">As novidades aparecerão aqui quando uma fonte monitorada publicar algo.</p>
            </div>
          <% } %>

          <% alertasList.forEach(function (a) { %>
            <% const dest = a.fonte_id ? '/biblioteca/fontes/' + a.fonte_id : null; %>
            <a
              href="<%= dest || '#bib-secao-alertas' %>"
              class="group flex gap-3 px-4 py-4 transition hover:bg-slate-800/30 sm:px-5 <%= a.lido ? 'opacity-55' : '' %> <%= dest ? '' : 'pointer-events-none' %>"
              data-alerta="<%= a.id %>">
              <div class="mt-1.5 shrink-0">
                <% if (a.lido) { %>
                  <span class="block h-2 w-2 rounded-full bg-slate-700" title="Lido"></span>
                <% } else { %>
                  <span class="block h-2 w-2 rounded-full bg-emerald-400 shadow-[0_0_0_3px_rgba(52,211,153,0.15)]" title="Não lido"></span>
                <% } %>
              </div>
              <div class="min-w-0 flex-1">
                <div class="flex flex-wrap items-center gap-2">
                  <% if (a.fonte_plataforma) { %>
                    <span class="inline-flex items-center rounded px-1.5 py-0.5 text-[10px] font-semibold uppercase tracking-wide ring-1 ring-inset <%= platClass(a.fonte_plataforma) %>"><%= a.fonte_plataforma %></span>
                  <% } %>
                  <% if (a.fonte_nome) { %>
                    <span class="max-w-[9rem] truncate text-[11px] text-slate-500"><%= a.fonte_nome %></span>
                  <% } %>
                  <time class="ml-auto shrink-0 text-[11px] tabular-nums text-slate-600"><%= fmtQuando(a.created_at) %></time>
                </div>
                <h3 class="mt-1.5 line-clamp-2 text-sm font-medium leading-snug text-white transition group-hover:text-emerald-300"><%= a.titulo %></h3>
                <% if (a.resumo) { %>
                  <p class="mt-1 line-clamp-2 text-xs leading-relaxed text-slate-400"><%= a.resumo %></p>
                <% } %>
              </div>
            </a>
          <% }) %>
        </div>
      </aside>
    </div>

    <!-- Piloto automático -->
    <section id="bib-autopilot" class="mt-6 overflow-hidden rounded-2xl border border-emerald-500/20 bg-slate-900/40">
      <details class="group" <%= auto.ativo ? 'open' : '' %>>
        <summary class="flex cursor-pointer list-none items-center justify-between gap-4 p-4 transition hover:bg-slate-800/20 sm:p-5 [&::-webkit-details-marker]:hidden">
          <div class="flex min-w-0 items-start gap-3">
            <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-emerald-500/10 text-emerald-400">
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83" /><circle cx="12" cy="12" r="3" /></svg>
            </span>
            <div class="min-w-0">
              <div class="flex flex-wrap items-center gap-2">
                <h2 class="text-sm font-semibold text-white">Piloto automático</h2>
                <% if (auto.ativo) { %>
                  <span class="inline-flex items-center gap-1.5 rounded-md bg-emerald-500/15 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-emerald-300 ring-1 ring-inset ring-emerald-500/30">
                    <span class="h-1.5 w-1.5 rounded-full bg-emerald-400"></span> ativo
                  </span>
                <% } else { %>
                  <span class="rounded-md bg-slate-800 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-slate-500">desligado</span>
                <% } %>
              </div>
              <p class="mt-1 max-w-2xl text-xs leading-relaxed text-slate-500">Configure a IA para selecionar os melhores posts, criar matérias e publicar automaticamente.</p>
            </div>
          </div>
          <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg border border-slate-700 text-slate-500 transition group-open:rotate-180 group-hover:text-white">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m6 9 6 6 6-6" /></svg>
          </span>
        </summary>

        <div class="border-t border-slate-800 p-4 sm:p-5">
          <div class="rounded-xl border border-slate-800 bg-slate-950/30 p-4 text-xs leading-relaxed text-slate-500">
            A IA analisa os posts de <strong class="font-medium text-slate-300">todas as fontes</strong>, escolhe os que têm mais chance de viralizar no Facebook e usa o modelo definido em <a href="/minha-marca" class="font-medium text-emerald-400 hover:text-emerald-300">Minha marca</a> para criar e publicar a matéria.
          </div>

          <form id="bib-auto-form" class="mt-5 grid gap-4 sm:grid-cols-2 lg:grid-cols-12 lg:items-end">
            <label class="flex items-center gap-2.5 rounded-lg border border-slate-800 bg-slate-950/40 px-3 py-2.5 sm:col-span-2 lg:col-span-12">
              <input id="bib-auto-ativo" type="checkbox" class="rounded border-slate-600 bg-slate-950 text-emerald-500 focus:ring-emerald-500/30" <%= auto.ativo ? 'checked' : '' %> />
              <span class="text-sm font-medium text-slate-200">Ativar piloto automático</span>
            </label>

            <label class="block sm:col-span-2 lg:col-span-5">
              <span class="text-xs font-medium text-slate-400">Página do Facebook</span>
              <select id="bib-auto-page" required
                class="mt-1.5 w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2.5 text-sm text-white focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500/30">
                <option value="">Selecione uma página</option>
                <% (pages || []).forEach(function (p) { %>
                  <option value="<%= p.id %>" <%= Number(auto.facebook_page_id) === Number(p.id) ? 'selected' : '' %>><%= p.page_name %></option>
                <% }) %>
              </select>
            </label>

            <label class="block lg:col-span-2">
              <span class="text-xs font-medium text-slate-400">Matérias por ciclo</span>
              <input id="bib-auto-posts" type="number" min="1" max="5" step="1" value="<%= Number(auto.posts_por_ciclo) || 1 %>"
                class="mt-1.5 w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2.5 text-sm text-white focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500/30" />
              <span class="mt-1 block text-[10px] text-slate-600">Entre 1 e 5</span>
            </label>

            <label class="block lg:col-span-2">
              <span class="text-xs font-medium text-slate-400">Intervalo em minutos</span>
              <input id="bib-auto-intervalo" type="number" min="5" max="1440" step="1" value="<%= Number(auto.intervalo_minutos) || 30 %>"
                class="mt-1.5 w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2.5 text-sm text-white focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500/30" />
              <span class="mt-1 block text-[10px] text-slate-600">De 5 a 1.440 min</span>
            </label>

            <button type="submit" class="w-full rounded-lg bg-emerald-500 px-4 py-2.5 text-sm font-semibold text-slate-950 transition hover:bg-emerald-400 lg:col-span-3">
              Salvar configuração
            </button>
            <p id="bib-auto-msg" class="hidden text-sm sm:col-span-2 lg:col-span-12"></p>
          </form>

          <div class="mt-5 grid gap-px overflow-hidden rounded-xl border border-slate-800 bg-slate-800 sm:grid-cols-2 lg:grid-cols-4">
            <div class="bg-slate-950/70 p-3.5">
              <p class="text-[10px] font-medium uppercase tracking-wider text-slate-600">Último ciclo</p>
              <p class="mt-1.5 text-xs text-slate-300"><%= auto.ultimo_tick ? fmtQuando(auto.ultimo_tick) : '—' %></p>
            </div>
            <div class="bg-slate-950/70 p-3.5">
              <p class="text-[10px] font-medium uppercase tracking-wider text-slate-600">Próxima execução</p>
              <p class="mt-1.5 text-xs text-slate-300"><%= auto.ativo && auto.proxima_execucao ? fmtQuando(auto.proxima_execucao) : (auto.ativo ? 'Em breve' : '—') %></p>
            </div>
            <div class="bg-slate-950/70 p-3.5">
              <p class="text-[10px] font-medium uppercase tracking-wider text-slate-600">Total publicado</p>
              <p class="mt-1.5 text-xs tabular-nums text-slate-300"><%= Number(auto.total_publicados || 0) %></p>
            </div>
            <div class="bg-slate-950/70 p-3.5">
              <p class="text-[10px] font-medium uppercase tracking-wider text-slate-600">Último status</p>
              <% if (auto.ultimo_erro) { %>
                <p class="mt-1.5 line-clamp-2 text-xs text-rose-300" title="<%= auto.ultimo_erro %>"><%= auto.ultimo_erro %></p>
              <% } else if (auto.ativo) { %>
                <p class="mt-1.5 text-xs text-emerald-300/80">OK — aguardando ciclo</p>
              <% } else { %>
                <p class="mt-1.5 text-xs text-slate-500">Desligado</p>
              <% } %>
            </div>
          </div>
        </div>
      </details>
    </section>
  </main>

  <div id="bib-busy" class="fixed inset-0 z-50 hidden flex items-center justify-center bg-slate-950/80 p-6 backdrop-blur-sm">
    <div class="w-full max-w-sm rounded-2xl border border-slate-700 bg-slate-900 p-6 text-center shadow-2xl">
      <div class="mx-auto h-10 w-10 animate-spin rounded-full border-2 border-emerald-400/30 border-t-emerald-300"></div>
      <p id="bib-busy-text" class="mt-4 text-sm text-slate-300">Processando…</p>
    </div>
  </div>

  <script>
    window.__BIB_PAGES__ = <%- JSON.stringify((pages || []).map(function (p) { return { id: p.id, name: p.page_name }; })) %>;
  </script>
  <script src="/js/biblioteca.js"></script>
<%- include('partials/app-end') %>
