<%
  const selectedContentTab = typeof contentTab !== 'undefined' ? contentTab : 'ia';
  const contentTabs = [
    { key: 'ia', href: '/conteudo', label: 'Pautas com IA', hint: 'Pesquisar e gerar' },
    { key: 'media', href: '/busca', label: 'Vídeo e imagem', hint: 'Buscar ou importar' },
    { key: 'production', href: '/fila', label: 'Produção', hint: 'Cortar · publicar' },
    { key: 'matters', href: '/minhas-materias', label: 'Matérias salvas', hint: 'Revisar e editar' },
  ];
%>
<section class="mb-5 overflow-hidden rounded-xl border border-slate-800 bg-slate-900/40" aria-label="Área de criação de conteúdo">
  <nav class="grid grid-cols-2 gap-1.5 p-2 sm:grid-cols-4 sm:gap-2 sm:p-2.5" aria-label="Etapas da criação">
    <% contentTabs.forEach((tab) => { const active = selectedContentTab === tab.key; %>
      <a href="<%= tab.href %>" <%= active ? 'aria-current="page"' : '' %>
        class="rounded-lg border px-3 py-2.5 transition sm:px-3.5 sm:py-3 <%= active
          ? 'border-emerald-400/40 bg-emerald-500 text-slate-950'
          : 'border-slate-800 bg-slate-950/40 text-slate-300 hover:border-slate-600 hover:bg-slate-900 hover:text-white' %>">
        <span class="block text-sm font-semibold leading-tight"><%= tab.label %></span>
        <span class="mt-0.5 block text-[11px] leading-snug <%= active ? 'text-slate-900/65' : 'text-slate-500' %>"><%= tab.hint %></span>
      </a>
    <% }) %>
  </nav>
</section>
