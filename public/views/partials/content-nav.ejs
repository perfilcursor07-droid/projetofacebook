<%
  const selectedContentTab = typeof contentTab !== 'undefined' ? contentTab : 'ia';
  const contentTabs = [
    { key: 'ia', href: '/conteudo', label: 'Pautas IA' },
    { key: 'media', href: '/busca', label: 'Vídeo/imagem' },
    { key: 'production', href: '/fila', label: 'Produção' },
    { key: 'matters', href: '/minhas-materias', label: 'Matérias' },
  ];
%>
<nav class="mb-4 flex gap-1 overflow-x-auto rounded-xl border border-slate-800 bg-slate-900/40 p-1" aria-label="Área de criação de conteúdo">
  <% contentTabs.forEach((tab) => { const active = selectedContentTab === tab.key; %>
    <a href="<%= tab.href %>" <%= active ? 'aria-current="page"' : '' %>
      class="shrink-0 rounded-lg px-3 py-1.5 text-xs font-medium transition sm:text-sm <%= active ? 'bg-emerald-500 text-slate-950' : 'text-slate-400 hover:bg-slate-800 hover:text-white' %>">
      <%= tab.label %>
    </a>
  <% }) %>
</nav>
