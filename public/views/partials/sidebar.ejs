<%
  const path = typeof currentPath !== 'undefined' ? currentPath : '';
  const loggedUser = typeof user !== 'undefined' ? user : null;
  function navActive(href) {
    return path === href || (href !== '/' && path.startsWith(href));
  }
  function contentAreaActive() {
    return path === '/conteudo' || path === '/busca' || path === '/fila' ||
      path === '/minhas-materias' || path.startsWith('/materias-ia');
  }
  function itemClass(href, groupedContent = false) {
    return (groupedContent ? contentAreaActive() : navActive(href))
      ? 'bg-emerald-500/15 text-emerald-300'
      : 'text-slate-400 hover:bg-slate-800/80 hover:text-white';
  }
%>
<aside id="app-sidebar" class="app-sidebar fixed inset-y-0 left-0 z-50 flex w-60 flex-col border-r border-slate-800 bg-slate-950 transition-transform duration-200 md:z-40 md:translate-x-0 md:transition-[width]">
  <div class="flex h-16 items-center justify-between gap-2 border-b border-slate-800 px-3">
    <a href="/dashboard" class="sidebar-brand truncate px-2 text-lg tracking-tight text-emerald-400"><strong>ViralizeAI</strong></a>
    <div class="flex items-center gap-1">
      <button type="button" id="sidebar-close" title="Fechar menu"
        class="sidebar-close-mobile inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-lg text-slate-400 transition hover:bg-slate-800 hover:text-white md:hidden"
        aria-label="Fechar menu">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M6 6l12 12M18 6L6 18"/>
        </svg>
      </button>
      <button type="button" id="sidebar-toggle" title="Recolher menu"
        class="sidebar-toggle-desktop hidden h-9 w-9 shrink-0 items-center justify-center rounded-lg text-slate-400 transition hover:bg-slate-800 hover:text-white md:inline-flex"
        aria-label="Recolher menu" aria-expanded="true">
        <svg id="sidebar-toggle-icon" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M15 6l-6 6 6 6"/>
        </svg>
      </button>
    </div>
  </div>

  <nav class="flex-1 space-y-1 overflow-y-auto px-2 py-4 text-sm" id="app-sidebar-nav">
    <p class="sidebar-label mb-2 px-3 text-[10px] font-semibold uppercase tracking-wider text-slate-600">Menu</p>
    <a href="/dashboard" title="Dashboard" class="sidebar-link flex items-center gap-3 rounded-lg px-3 py-2.5 transition <%= itemClass('/dashboard') %>">
      <svg class="h-4 w-4 shrink-0 opacity-80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="9" rx="1"/><rect x="14" y="3" width="7" height="5" rx="1"/><rect x="14" y="12" width="7" height="9" rx="1"/><rect x="3" y="16" width="7" height="5" rx="1"/></svg>
      <span class="sidebar-text">Dashboard</span>
    </a>
    <a href="/conteudo" title="Criar conteúdo" class="sidebar-link flex items-center gap-3 rounded-lg px-3 py-2.5 transition <%= itemClass('/conteudo', true) %>">
      <svg class="h-4 w-4 shrink-0 opacity-80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 3v18M4 8h16M4 16h10"/></svg>
      <span class="sidebar-text">Criar conteúdo</span>
    </a>
    <a href="/biblioteca" title="Biblioteca de fontes" class="sidebar-link flex items-center gap-3 rounded-lg px-3 py-2.5 transition <%= itemClass('/biblioteca') %>">
      <svg class="h-4 w-4 shrink-0 opacity-80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/><path d="M8 7h8M8 11h6"/></svg>
      <span class="sidebar-text">Biblioteca</span>
    </a>
    <a href="/paginas" title="Páginas" class="sidebar-link flex items-center gap-3 rounded-lg px-3 py-2.5 transition <%= itemClass('/paginas') %>">
      <svg class="h-4 w-4 shrink-0 opacity-80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16v16H4z"/><path d="M8 8h8M8 12h8M8 16h5"/></svg>
      <span class="sidebar-text">Páginas</span>
    </a>
    <a href="/cookies" title="Cookies do YouTube" class="sidebar-link flex items-center gap-3 rounded-lg px-3 py-2.5 transition <%= itemClass('/cookies') %>">
      <svg class="h-4 w-4 shrink-0 opacity-80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 1 1-9-9c0 2 1.5 3.5 3.5 3.5S19 8 19 10c0 1 .8 2 2 2Z"/><circle cx="8.5" cy="10.5" r=".8"/><circle cx="12" cy="15" r=".8"/><circle cx="15" cy="11" r=".8"/></svg>
      <span class="sidebar-text">Cookies YouTube</span>
    </a>
    <a href="/minha-marca" title="Minha marca" class="sidebar-link flex items-center gap-3 rounded-lg px-3 py-2.5 transition <%= itemClass('/minha-marca') %>">
      <svg class="h-4 w-4 shrink-0 opacity-80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 5h16v14H4z"/><path d="m4 15 4-4 3 3 3-4 6 6"/><circle cx="9" cy="8" r="1"/></svg>
      <span class="sidebar-text">Minha marca</span>
    </a>
    <% if (loggedUser && loggedUser.nivel_acesso === 'administrador') { %>
      <p class="sidebar-label mb-2 mt-5 px-3 text-[10px] font-semibold uppercase tracking-wider text-slate-600">Administração</p>
      <a href="/usuarios" title="Usuários" class="sidebar-link flex items-center gap-3 rounded-lg px-3 py-2.5 transition <%= itemClass('/usuarios') %>">
        <svg class="h-4 w-4 shrink-0 opacity-80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        <span class="sidebar-text">Usuários</span>
      </a>
    <% } %>
  </nav>

  <div class="border-t border-slate-800 p-3">
    <% if (loggedUser) { %>
      <div class="sidebar-user mb-3 truncate px-2 text-xs text-slate-500"><%= loggedUser.nome %></div>
      <a href="/api/auth/logout" title="Sair"
        class="sidebar-link flex items-center gap-2 rounded-lg px-3 py-2 text-sm text-slate-400 transition hover:bg-rose-500/10 hover:text-rose-300">
        <svg class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><path d="M16 17l5-5-5-5"/><path d="M21 12H9"/></svg>
        <span class="sidebar-text">Sair</span>
      </a>
    <% } %>
    <div class="sidebar-credit mt-3 space-y-0.5 px-2 text-[10px] leading-snug text-slate-600">
      <p>Desenvolvido por Erick Vinicius</p>
      <p>Versão 1.0</p>
    </div>
  </div>
</aside>
