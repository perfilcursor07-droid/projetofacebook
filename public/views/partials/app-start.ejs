<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> — ViralizeAI</title>
  <link rel="stylesheet" href="/css/app.css" />
  <script>
    (function () {
      try {
        if (window.matchMedia('(min-width: 768px)').matches &&
            localStorage.getItem('ViralizeAI.sidebarCollapsed') === '1') {
          document.documentElement.classList.add('sidebar-collapsed');
        }
      } catch (_) {}
    })();
  </script>
</head>
<body class="min-h-screen bg-slate-950 text-slate-100">
  <div class="pointer-events-none fixed inset-0 -z-10 overflow-hidden">
    <div class="absolute -left-20 top-20 h-72 w-72 rounded-full bg-emerald-500/5 blur-3xl"></div>
    <div class="absolute right-0 top-0 h-80 w-80 rounded-full bg-sky-500/5 blur-3xl"></div>
  </div>

  <%- include('sidebar') %>

  <div id="sidebar-backdrop" class="fixed inset-0 z-40 hidden bg-slate-950/70 backdrop-blur-sm md:hidden" aria-hidden="true"></div>

  <div id="app-content" class="app-content min-h-screen transition-[padding] duration-200 md:pl-60">
    <header class="sticky top-0 z-30 flex h-14 items-center gap-3 border-b border-slate-800/80 bg-slate-950/90 px-4 backdrop-blur md:hidden">
      <button type="button" id="sidebar-open" class="inline-flex h-10 w-10 items-center justify-center rounded-lg border border-slate-700 text-slate-200 transition hover:border-slate-500 hover:bg-slate-900" aria-label="Abrir menu" aria-controls="app-sidebar" aria-expanded="false">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M4 7h16M4 12h16M4 17h16"/>
        </svg>
      </button>
      <a href="/dashboard" class="truncate text-base font-semibold tracking-tight text-emerald-400">ViralizeAI</a>
    </header>
