<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> — ViralizeAI</title>
  <link rel="stylesheet" href="/css/app.css" />
  <script>
    (function () {
      try {
        if (localStorage.getItem('ViralizeAI.sidebarCollapsed') === '1') {
          document.documentElement.classList.add('sidebar-collapsed');
        }
      } catch (_) {}
    })();
  </script>
</head>
<body class="min-h-screen bg-slate-950 text-slate-100">
  <div class="pointer-events-none fixed inset-0 -z-10 overflow-hidden">
    <div class="absolute -left-20 top-20 h-72 w-72 rounded-full bg-emerald-500/5 blur-3xl"></div>
    <div class="absolute right-0 top-0 h-80 w-80 rounded-full bg-sky-500/5 blur-3xl"></div>
  </div>

  <%- include('sidebar') %>

  <div id="app-content" class="app-content min-h-screen pl-60 transition-all duration-200">
