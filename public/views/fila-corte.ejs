<%- include('partials/app-start') %>
<%
  const canEdit = clip.status === 'pronto' || clip.status === 'publicado';
  const videoUrl = clip.caminho_arquivo ? '/media/' + String(clip.caminho_arquivo).replace(/^\/+/, '') : '';
  const inicio = Number(clip.inicio_segundo);
  const fim = Number(clip.fim_segundo);
  const dur = Number.isFinite(inicio) && Number.isFinite(fim) ? Math.max(0, Math.round(fim - inicio)) : null;
  const ratio = clip.aspect_ratio || '9:16';
  const materiaOk = Boolean(materia) && clip.materia_status === 'pronta';
%>

  <main class="mx-auto max-w-6xl px-4 py-5 sm:px-6 sm:py-8">
    <div class="flex flex-wrap items-start justify-between gap-3">
      <div>
        <a href="/fila" class="text-xs font-medium text-slate-500 hover:text-emerald-300">← Voltar para Produção</a>
        <h1 class="mt-2 text-2xl font-semibold text-white">Revisar e publicar</h1>
        <p class="mt-1 text-sm text-slate-400 truncate max-w-xl"><%= video.titulo || video.termo_busca || 'Corte' %></p>
      </div>
      <div class="flex flex-wrap items-center gap-2 text-xs text-slate-500">
        <span><%= dur != null ? dur + 's' : '—' %></span>
        <span>·</span>
        <span><%= ratio %></span>
        <% if (clip.status === 'publicado') { %>
          <span class="rounded-full bg-emerald-500/15 px-2.5 py-0.5 font-medium text-emerald-300">Publicado</span>
        <% } else if (materiaOk) { %>
          <span class="rounded-full bg-emerald-500/15 px-2.5 py-0.5 font-medium text-emerald-300">Pronto</span>
        <% } else { %>
          <span class="rounded-full bg-amber-500/15 px-2.5 py-0.5 font-medium text-amber-200">Preparando…</span>
        <% } %>
      </div>
    </div>

    <p id="clip-status" class="mt-4 text-sm text-slate-400"></p>
    <% if (clip.erro_mensagem) { %>
      <div class="mt-3 rounded-xl border border-rose-500/30 bg-rose-500/10 px-4 py-3 text-sm text-rose-200"><%= clip.erro_mensagem %></div>
    <% } %>

    <% if (!canEdit) { %>
      <div class="mt-6 rounded-2xl border border-amber-500/25 bg-amber-500/10 p-6 text-center">
        <p class="text-sm text-amber-100">Este corte ainda está processando.</p>
        <a href="/fila" class="mt-3 inline-block text-sm text-sky-300 hover:underline">Voltar e aguardar →</a>
      </div>
    <% } else { %>
      <div class="mt-6 grid gap-6 lg:grid-cols-[minmax(0,1fr)_300px]">
        <section class="rounded-2xl border border-slate-800 bg-slate-900/60 p-5">
          <div class="flex flex-wrap items-center justify-between gap-2">
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Matéria</p>
            <button type="button" id="btn-materia" class="rounded-lg bg-violet-500 px-3 py-1.5 text-xs font-semibold text-white hover:bg-violet-400">
              <%= materia ? 'Refazer matéria' : 'Gerar matéria' %>
            </button>
          </div>
          <input id="clip-tema" type="text" placeholder="Tema opcional"
            class="mt-3 w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 text-xs text-slate-100 placeholder:text-slate-600 focus:border-emerald-500 focus:outline-none" />
          <textarea id="clip-materia" rows="14"
            class="mt-3 w-full rounded-xl border border-slate-700 bg-slate-950 px-3 py-3 text-sm leading-relaxed text-slate-100 focus:border-emerald-500 focus:outline-none"
            placeholder="A matéria aparece aqui…"><%= materia || '' %></textarea>

          <details class="mt-4 rounded-xl border border-slate-800 bg-slate-950/40">
            <summary class="cursor-pointer px-3 py-2.5 text-xs text-slate-400 hover:text-slate-200">Capa e título (opcional)</summary>
            <div class="space-y-3 border-t border-slate-800 px-3 py-3">
              <input id="clip-capa-titulo" type="text" maxlength="120" value="<%= clip.capa_titulo || '' %>"
                placeholder="Título da capa"
                class="w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 text-sm font-semibold text-white focus:border-emerald-500 focus:outline-none" />
              <div class="flex flex-wrap gap-2">
                <button type="button" id="btn-capa" class="rounded-lg border border-sky-500/40 bg-sky-500/15 px-3 py-1.5 text-xs font-semibold text-sky-200 hover:bg-sky-500/25">
                  <%= clip.capa_status === 'pronta' ? 'Refazer capa' : 'Gerar capa' %>
                </button>
                <% if (clip.capa_status === 'pronta') { %>
                  <button type="button" id="btn-remover-capa" class="rounded-lg border border-slate-700 px-3 py-1.5 text-xs text-slate-300">Remover capa</button>
                <% } %>
              </div>
            </div>
          </details>
        </section>

        <aside class="space-y-4">
          <div class="rounded-2xl border border-slate-800 bg-slate-900/60 p-3">
            <div class="mb-2 flex items-center justify-between">
              <span class="text-xs font-semibold uppercase tracking-wide text-violet-300">Reel</span>
              <span class="rounded-full bg-slate-800 px-2 py-0.5 text-[10px] text-slate-400"><%= ratio %></span>
            </div>
            <% if (videoUrl) { %>
              <video id="clip-video" class="block aspect-[9/16] max-h-[420px] w-full rounded-xl border border-slate-700 bg-black object-contain" controls playsinline
                src="<%= videoUrl %>?t=<%= Date.now() %>"></video>
            <% } else { %>
              <div class="flex min-h-[240px] items-center justify-center rounded-xl border border-dashed border-slate-700 text-xs text-slate-500">Sem arquivo</div>
            <% } %>
          </div>

          <div class="rounded-2xl border border-[#1877F2]/30 bg-slate-900/60 p-4">
            <p class="text-xs font-semibold uppercase tracking-wide text-[#1877F2]">Publicar</p>
            <label class="mt-3 block text-sm">
              <span class="text-slate-400">Página</span>
              <select id="clip-page" class="mt-1.5 w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-white">
                <option value="">Carregando…</option>
              </select>
            </label>
            <label class="mt-3 block text-sm">
              <span class="text-slate-400">Formato</span>
              <select id="clip-modo" class="mt-1.5 w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-white">
                <option value="reel" selected>Reel</option>
                <option value="video">Vídeo no feed</option>
              </select>
            </label>
            <button type="button" id="btn-publicar"
              class="mt-4 w-full rounded-xl bg-[#1877F2] px-4 py-3 text-sm font-bold text-white hover:bg-[#166FE5] disabled:opacity-50">
              Publicar no Facebook
            </button>
          </div>
        </aside>
      </div>
    <% } %>
  </main>

  <div id="publish-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-slate-950/85 p-6 backdrop-blur-sm">
    <div class="w-full max-w-sm rounded-2xl border border-slate-700 bg-slate-900 p-8 text-center">
      <div id="publish-spin" class="mx-auto h-12 w-12 animate-spin rounded-full border-2 border-[#1877F2]/30 border-t-[#1877F2]"></div>
      <div id="publish-ok" class="mx-auto hidden h-12 w-12 items-center justify-center rounded-full bg-emerald-500/15 text-2xl text-emerald-300">✓</div>
      <h2 id="publish-title" class="mt-5 text-lg font-semibold text-white">Publicando…</h2>
      <p id="publish-text" class="mt-2 text-sm text-slate-400">Enviando o Reel para o Facebook.</p>
      <a id="publish-link" href="/fila" class="mt-4 hidden inline-block text-sm text-sky-400 hover:underline">Voltar à Produção →</a>
    </div>
  </div>

  <script>
    window.__CLIP_EDIT__ = {
      id: <%= clip.id %>,
      canEdit: <%= canEdit ? 'true' : 'false' %>,
      materiaStatus: <%- JSON.stringify(clip.materia_status || '') %>,
      capaStatus: <%- JSON.stringify(clip.capa_status || '') %>,
    };
  </script>
  <script src="/js/fila-corte.js"></script>
<%- include('partials/app-end') %>
