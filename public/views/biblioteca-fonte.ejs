<%- include('partials/app-start') %>
<%
  const f = fonte || {};
  const postsList = posts || [];
  function platClass(p) {
    const k = String(p || '').toLowerCase();
    if (k === 'youtube') return 'bg-rose-500/15 text-rose-300 ring-rose-500/20';
    if (k === 'facebook') return 'bg-sky-500/15 text-sky-300 ring-sky-500/20';
    if (k === 'instagram') return 'bg-fuchsia-500/15 text-fuchsia-300 ring-fuchsia-500/20';
    if (k === 'tiktok') return 'bg-slate-100/10 text-slate-200 ring-slate-500/30';
    if (k === 'site') return 'bg-amber-500/15 text-amber-300 ring-amber-500/20';
    return 'bg-slate-800 text-slate-300 ring-slate-700';
  }
  function fmtQuando(d) {
    if (!d) return '';
    try {
      return new Date(d).toLocaleString('pt-BR', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' });
    } catch (_) {
      return '';
    }
  }
  function statusPost(p) {
    if (p.ja_publicado) {
      return { text: 'Publicada', cls: 'bg-emerald-500/15 text-emerald-300 ring-1 ring-inset ring-emerald-500/25' };
    }
    const k = String(p.status || '').toLowerCase();
    if (k === 'novo') return { text: 'Novo', cls: 'bg-sky-500/15 text-sky-300' };
    if (k === 'visto') return { text: 'Visto', cls: 'bg-slate-800 text-slate-400' };
    if (k === 'gerado_texto') return { text: 'Matéria gerada', cls: 'bg-violet-500/15 text-violet-300' };
    if (k === 'gerado_video') return { text: 'Vídeo gerado', cls: 'bg-violet-500/15 text-violet-300' };
    if (k === 'ignorado') return { text: 'Ignorado', cls: 'bg-slate-800 text-slate-500' };
    return { text: p.status || '—', cls: 'bg-slate-800 text-slate-400' };
  }
%>

  <main class="mx-auto max-w-9xl px-4 py-5 sm:px-6 sm:py-8" id="biblioteca-fonte-app"
    data-fonte-id="<%= f.id %>">

    <div class="mb-5">
      <a href="/biblioteca" class="inline-flex items-center gap-1 text-sm text-slate-400 hover:text-emerald-300">
        ← Voltar à biblioteca
      </a>
    </div>

    <div class="flex flex-col gap-4 border-b border-slate-800/80 pb-6 sm:flex-row sm:items-start sm:justify-between">
      <div class="min-w-0">
        <div class="flex flex-wrap items-center gap-2">
          <span class="inline-flex items-center rounded-md px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide ring-1 ring-inset <%= platClass(f.plataforma) %>"><%= f.plataforma %></span>
          <% if (f.monitorar) { %>
            <span class="inline-flex items-center gap-1 rounded-md bg-emerald-500/10 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-emerald-300 ring-1 ring-inset ring-emerald-500/25">
              <span class="h-1.5 w-1.5 rounded-full bg-emerald-400"></span>
              monitorando
            </span>
          <% } %>
        </div>
        <h1 class="mt-2 text-2xl font-semibold tracking-tight text-white"><%= f.nome %></h1>
        <a href="<%= f.url %>" target="_blank" rel="noopener" class="mt-1 block truncate text-sm text-slate-500 hover:text-emerald-400"><%= f.url %></a>
        <% if (f.ultimo_erro) { %>
          <p class="mt-2 text-xs text-rose-300"><%= f.ultimo_erro %></p>
        <% } else if (f.ultimo_scan) { %>
          <p class="mt-2 text-xs text-slate-600">Último scan · <%= fmtQuando(f.ultimo_scan) %></p>
        <% } %>
      </div>
      <div class="flex flex-wrap gap-2 shrink-0">
        <button type="button" id="bib-fonte-scan"
          class="rounded-lg border border-emerald-500/40 bg-emerald-500/15 px-3 py-2 text-sm font-semibold text-emerald-200 hover:bg-emerald-500/25">
          Escanear agora
        </button>
        <button type="button" id="bib-fonte-toggle-mon" data-on="<%= f.monitorar ? '1' : '0' %>"
          class="rounded-lg border border-slate-700 px-3 py-2 text-sm text-slate-300 hover:border-sky-500/50 hover:text-sky-300">
          <%= f.monitorar ? 'Pausar monitoramento' : 'Ativar monitoramento' %>
        </button>
      </div>
    </div>

    <section class="mt-6 rounded-xl border border-slate-800 bg-slate-900/40 p-4">
      <label class="block text-sm">
        <span class="text-slate-400">Página FB para gerar matéria (opcional)</span>
        <select id="bib-page" name="facebook_page_id"
          class="mt-1.5 w-full max-w-md rounded-lg border border-slate-700 bg-slate-950 px-3 py-2.5 text-sm text-white focus:border-emerald-500 focus:outline-none">
            <option value="">— selecionar —</option>
          <% (pages || []).forEach(function (p) {
            const sel = Number(f.facebook_page_id) === Number(p.id)
              || (!f.facebook_page_id && Number(defaultPageId) === Number(p.id));
          %>
            <option value="<%= p.id %>" <%= sel ? 'selected' : '' %>><%= p.page_name %><%= Number(defaultPageId) === Number(p.id) ? ' · padrão' : '' %></option>
          <% }) %>
        </select>
      </label>
    </section>

    <section class="mt-8">
      <div class="mb-3 flex flex-wrap items-baseline justify-between gap-3">
        <div>
          <h2 class="text-base font-semibold text-white">Posts detectados</h2>
          <p class="mt-0.5 text-xs text-slate-500">Conteúdo encontrado nesta fonte. Gere matéria a partir de cada item.</p>
        </div>
        <span class="text-xs text-slate-500"><%= postsList.length %> de <%= Number(f.posts_count || postsList.length) %> item(ns)</span>
      </div>

      <div id="bib-posts-lista" class="overflow-hidden rounded-2xl border border-slate-800 bg-slate-900/40">
        <% if (!postsList.length) { %>
          <div class="px-4 py-14 text-center">
            <p class="text-sm text-slate-400">Nenhum post detectado nesta fonte.</p>
            <p class="mt-1 text-xs text-slate-600">Clique em <strong class="font-medium text-slate-400">Escanear agora</strong> para buscar publicações recentes.</p>
          </div>
        <% } else { %>
          <div class="divide-y divide-slate-800/80">
            <% postsList.forEach(function (p) {
              const st = statusPost(p);
            %>
              <article class="flex flex-col gap-3 px-4 py-4 transition hover:bg-slate-800/25 sm:flex-row sm:items-center sm:justify-between <%= p.ja_publicado ? 'opacity-80' : '' %>" data-post="<%= p.id %>" id="post-<%= p.id %>">
                <div class="min-w-0 flex-1">
                  <p class="text-sm font-medium leading-snug text-white"><%= p.titulo || 'Sem título' %></p>
                  <% if (p.resumo) { %>
                    <p class="mt-1 text-xs leading-relaxed text-slate-400 line-clamp-2"><%= p.resumo %></p>
                  <% } %>
                  <div class="mt-2 flex flex-wrap items-center gap-2">
                    <span class="rounded px-1.5 py-0.5 text-[10px] font-semibold uppercase tracking-wide <%= st.cls %>"><%= st.text %></span>
                    <% if (p.publicado_em || p.created_at) { %>
                      <span class="text-[11px] text-slate-600"><%= fmtQuando(p.publicado_em || p.created_at) %></span>
                    <% } %>
                  </div>
                </div>
                <div class="flex flex-wrap gap-1.5 sm:shrink-0">
                  <% if (p.ja_publicado && p.matter_id) { %>
                    <a href="/materias-ia/<%= p.matter_id %>" class="rounded-lg border border-emerald-500/40 bg-emerald-500/10 px-3 py-1.5 text-xs font-medium text-emerald-300 hover:bg-emerald-500/20">Ver matéria</a>
                  <% } else if (p.matter_id && String(p.status) === 'gerado_texto') { %>
                    <a href="/materias-ia/<%= p.matter_id %>" class="rounded-lg border border-violet-500/40 bg-violet-500/10 px-3 py-1.5 text-xs font-medium text-violet-300 hover:bg-violet-500/20">Abrir matéria</a>
                    <button type="button" class="bib-gen-texto rounded-lg border border-emerald-500/40 bg-emerald-500/10 px-3 py-1.5 text-xs font-medium text-emerald-300 hover:bg-emerald-500/20" data-id="<%= p.id %>">Gerar Matéria</button>
                  <% } else if (!p.ja_publicado) { %>
                    <button type="button" class="bib-gen-texto rounded-lg border border-emerald-500/40 bg-emerald-500/10 px-3 py-1.5 text-xs font-medium text-emerald-300 hover:bg-emerald-500/20" data-id="<%= p.id %>">Gerar Matéria</button>
                  <% } %>
                  <% if (p.url) { %>
                    <a href="<%= p.url %>" target="_blank" rel="noopener" class="rounded-lg border border-slate-700 px-3 py-1.5 text-xs font-medium text-slate-400 hover:text-white">Abrir original</a>
                  <% } %>
                </div>
              </article>
            <% }) %>
          </div>
        <% } %>
      </div>
    </section>
  </main>

  <div id="bib-busy" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-slate-950/80 p-6 backdrop-blur-sm">
    <div class="w-full max-w-sm rounded-2xl border border-slate-700 bg-slate-900 p-6 text-center">
      <div class="mx-auto h-10 w-10 animate-spin rounded-full border-2 border-emerald-400/30 border-t-emerald-300"></div>
      <p id="bib-busy-text" class="mt-4 text-sm text-slate-300">Processando…</p>
    </div>
  </div>

  <script src="/js/biblioteca.js"></script>
<%- include('partials/app-end') %>
