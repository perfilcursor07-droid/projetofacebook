<%- include('partials/app-start') %>

  <main class="mx-auto max-w-9xl px-4 py-5 sm:px-6 sm:py-8">
    <div class="flex flex-wrap items-start justify-between gap-4">
      <div>
        <p class="text-xs font-semibold uppercase tracking-wider text-emerald-400">Identidade visual</p>
        <h1 class="mt-1 text-2xl font-semibold text-white">Minha marca</h1>
        <p class="mt-2 max-w-2xl text-sm text-slate-400">Configure logo, tipografia e cores aplicadas automaticamente às artes das Matérias IA.</p>
      </div>
      <a href="/conteudo" class="rounded-lg border border-slate-700 px-4 py-2 text-sm text-slate-300 hover:border-emerald-500 hover:text-emerald-300">Voltar para criar conteúdo</a>
    </div>

    <% if (saved) { %>
      <div class="mt-5 rounded-xl border border-emerald-500/30 bg-emerald-500/10 px-4 py-3 text-sm text-emerald-200">Identidade visual salva com sucesso.</div>
    <% } %>
    <% if (error) { %>
      <div class="mt-5 rounded-xl border border-rose-500/30 bg-rose-500/10 px-4 py-3 text-sm text-rose-200"><%= error %></div>
    <% } %>

    <form action="/minha-marca" method="POST" enctype="multipart/form-data" class="mt-7 grid gap-6 lg:grid-cols-[minmax(0,1fr)_360px]">
      <section class="rounded-2xl border border-slate-800 bg-slate-900/60 p-6">
        <h2 class="text-base font-semibold text-white">Dados da marca</h2>
        <div class="mt-5 grid gap-4 sm:grid-cols-2">
          <label class="block sm:col-span-2">
            <span class="text-sm text-slate-400">Logomarca</span>
            <input id="logo-input" type="file" name="logo" accept="image/png,image/jpeg,image/webp"
              class="mt-1.5 block w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-300 file:mr-3 file:rounded-md file:border-0 file:bg-emerald-500 file:px-3 file:py-1.5 file:font-semibold file:text-slate-950" />
            <span class="mt-1 block text-xs text-slate-500">PNG, JPG ou WebP, até 3 MB. Prefira PNG com fundo transparente.</span>
          </label>
          <label class="block sm:col-span-2">
            <span class="text-sm text-slate-400">Nome exibido</span>
            <input name="marca_nome" maxlength="120" value="<%= profile.marca_nome || profile.nome || '' %>" required
              class="mt-1.5 w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2.5 text-white focus:border-emerald-500 focus:outline-none" />
          </label>
          <label class="block">
            <span class="text-sm text-slate-400">Categoria</span>
            <input name="marca_categoria" maxlength="80" value="<%= profile.marca_categoria || 'ÚLTIMAS' %>"
              class="mt-1.5 w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2.5 text-white focus:border-emerald-500 focus:outline-none" />
          </label>
          <label class="block">
            <span class="text-sm text-slate-400">Texto do rodapé</span>
            <input name="marca_rodape" maxlength="160" value="<%= profile.marca_rodape || '' %>" placeholder="@sua_pagina"
              class="mt-1.5 w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2.5 text-white focus:border-emerald-500 focus:outline-none" />
          </label>
          <label class="block">
            <span class="text-sm text-slate-400">Cor principal</span>
            <div class="mt-1.5 flex gap-2 rounded-lg border border-slate-700 bg-slate-950 p-2">
              <input type="color" name="marca_cor_primaria" value="<%= profile.marca_cor_primaria || '#facc15' %>" class="h-8 w-full cursor-pointer border-0 bg-transparent" />
            </div>
          </label>
          <label class="block">
            <span class="text-sm text-slate-400">Cor secundária</span>
            <div class="mt-1.5 flex gap-2 rounded-lg border border-slate-700 bg-slate-950 p-2">
              <input type="color" name="marca_cor_secundaria" value="<%= profile.marca_cor_secundaria || '#fb923c' %>" class="h-8 w-full cursor-pointer border-0 bg-transparent" />
            </div>
          </label>
        </div>

        <div class="mt-7 border-t border-slate-800 pt-6">
          <h3 class="text-sm font-semibold text-white">Tipografia do título</h3>
          <p class="mt-1 text-xs text-slate-500">Padrão: Serithai Condensed. Escolha também a cor bold e o tamanho do título nas artes.</p>

          <p class="mt-4 text-xs font-semibold uppercase tracking-wider text-slate-500">Fonte principal</p>
          <div class="mt-2 grid gap-2 sm:grid-cols-2">
            <% brandFonts.forEach((font) => { %>
              <label class="cursor-pointer">
                <input type="radio" name="marca_fonte" value="<%= font.id %>" class="peer sr-only js-brand-font"
                  <%= (profile.marca_fonte || defaultBrandFont) === font.id ? 'checked' : '' %> />
                <span class="block rounded-xl border-2 border-slate-700 bg-slate-950 px-3 py-3 transition peer-checked:border-emerald-400 peer-checked:ring-2 peer-checked:ring-emerald-400/25 hover:border-slate-500">
                  <span class="block text-[10px] font-semibold uppercase tracking-wide text-slate-500"><%= font.name %><% if (font.id === defaultBrandFont) { %> · padrão<% } %></span>
                  <span class="mt-1 block text-xl leading-none text-white" style="font-family: <%= font.cssFamily %>; font-weight: <%= font.previewWeight %>;">TÍTULO DA NOTÍCIA</span>
                </span>
              </label>
            <% }) %>
          </div>

          <p class="mt-5 text-xs font-semibold uppercase tracking-wider text-slate-500">Cor bold do título</p>
          <div class="mt-2 flex flex-wrap gap-2">
            <% titleColors.forEach((c) => {
              const swatch = c.id === 'primaria' ? (profile.marca_cor_primaria || '#facc15')
                : c.id === 'secundaria' ? (profile.marca_cor_secundaria || '#fb923c')
                : c.value;
            %>
              <label class="cursor-pointer">
                <input type="radio" name="marca_titulo_cor" value="<%= c.id %>" class="peer sr-only js-title-color"
                  <%= (profile.marca_titulo_cor || defaultTitleColor) === c.id ? 'checked' : '' %> />
                <span class="inline-flex items-center gap-2 rounded-lg border-2 border-slate-700 bg-slate-950 px-3 py-2 text-xs text-slate-300 transition peer-checked:border-emerald-400 peer-checked:text-white hover:border-slate-500">
                  <span class="h-4 w-4 rounded-full border border-white/20" style="background: <%= swatch %>"></span>
                  <%= c.name %>
                </span>
              </label>
            <% }) %>
          </div>

          <p class="mt-5 text-xs font-semibold uppercase tracking-wider text-slate-500">Tamanho do título</p>
          <div class="mt-2 rounded-xl border border-slate-700 bg-slate-950 px-4 py-3">
            <div class="flex items-center justify-between gap-3 text-xs text-slate-400">
              <span><%= titleSizeMin %></span>
              <span class="font-semibold text-white">Tamanho: <span id="title-size-value"><%= Number(profile.marca_titulo_tamanho) >= titleSizeMin && Number(profile.marca_titulo_tamanho) <= titleSizeMax ? Number(profile.marca_titulo_tamanho) : defaultTitleSize %></span>px <span class="font-normal text-slate-500">(padrão <%= defaultTitleSize %>)</span></span>
              <span><%= titleSizeMax %></span>
            </div>
            <input id="title-size-input" type="range" name="marca_titulo_tamanho" min="<%= titleSizeMin %>" max="<%= titleSizeMax %>" step="1"
              value="<%= Number(profile.marca_titulo_tamanho) >= titleSizeMin && Number(profile.marca_titulo_tamanho) <= titleSizeMax ? Number(profile.marca_titulo_tamanho) : defaultTitleSize %>"
              class="js-title-size mt-3 w-full accent-emerald-500" />
          </div>

          <div class="mt-5 overflow-hidden rounded-xl border border-slate-700 bg-gradient-to-br from-slate-700 via-slate-900 to-black p-4">
            <p class="text-[10px] font-semibold uppercase tracking-wider text-slate-400">Prévia do título</p>
            <p id="title-preview" class="mt-3 text-center text-2xl font-black uppercase leading-tight text-white">
              Título da notícia em destaque
            </p>
          </div>
        </div>

        <div class="mt-7 border-t border-slate-800 pt-6">
          <h3 class="text-sm font-semibold text-white">Modelo da arte</h3>
          <p class="mt-1 text-xs text-slate-500">Escolha um padrão para as próximas artes e para as que forem regeneradas.</p>
          <div class="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4">
            <% artModels.forEach((model) => { %>
              <label class="cursor-pointer" title="<%= model.description %>">
                <input type="radio" name="marca_modelo_arte" value="<%= model.id %>" class="peer sr-only"
                  <%= (profile.marca_modelo_arte || defaultArtModel) === model.id ? 'checked' : '' %> />
                <span class="block overflow-hidden rounded-xl border-2 border-slate-600 bg-slate-950 transition peer-checked:border-emerald-400 peer-checked:ring-2 peer-checked:ring-emerald-400/25 hover:border-slate-400">
                  <span class="relative flex aspect-[4/5] flex-col overflow-hidden bg-gradient-to-br from-slate-600 via-slate-900 to-black p-2">
                    <span class="pointer-events-none absolute inset-x-0 bottom-0 h-3/5 bg-gradient-to-t from-black via-black/50 to-transparent"></span>
                    <span class="relative z-10 mx-auto mt-0.5 rounded bg-white/90 px-2 py-0.5 text-[8px] font-bold leading-none text-slate-900">MARCA</span>
                    <span class="relative z-10 mt-auto space-y-1">
                      <% if (model.id === 'faixa_classica') { %>
                        <span class="block text-center text-[8px] font-bold tracking-wide text-white">ÚLTIMAS</span>
                        <span class="mx-auto block h-1 w-full rounded bg-gradient-to-r from-yellow-400 to-orange-400"></span>
                        <span class="block pb-1 text-center text-[9px] font-black leading-tight text-white">TÍTULO DA<br />NOTÍCIA</span>
                      <% } else if (model.id === 'bloco_inferior') { %>
                        <span class="-mx-2 -mb-2 space-y-1 bg-black/80 px-2 pb-2 pt-2">
                          <span class="block h-1 w-full bg-gradient-to-r from-yellow-400 to-orange-400"></span>
                          <span class="block text-[8px] font-bold text-white">ÚLTIMAS</span>
                          <span class="block text-[9px] font-black leading-tight text-white">TÍTULO DA<br />NOTÍCIA</span>
                        </span>
                      <% } else if (model.id === 'minimalista') { %>
                        <span class="inline-block rounded-full bg-yellow-400 px-2 py-0.5 text-[8px] font-black text-slate-950">ÚLTIMAS</span>
                        <span class="block h-1 w-8 rounded bg-orange-400"></span>
                        <span class="block pb-1 text-[9px] font-black leading-tight text-white">TÍTULO DA<br />NOTÍCIA</span>
                      <% } else if (model.id === 'barra_lateral') { %>
                        <span class="flex gap-1.5 pb-1">
                          <span class="w-1 shrink-0 self-stretch rounded bg-gradient-to-b from-yellow-400 to-orange-400"></span>
                          <span class="min-w-0">
                            <span class="block text-[8px] font-bold text-white">ÚLTIMAS</span>
                            <span class="mt-1 block text-[9px] font-black leading-tight text-white">TÍTULO DA<br />NOTÍCIA</span>
                          </span>
                        </span>
                      <% } else if (model.id === 'faixa_topo') { %>
                        <span class="space-y-1 rounded-lg bg-black/60 p-1.5">
                          <span class="block rounded-md bg-gradient-to-r from-yellow-400 to-orange-400 py-1 text-center text-[8px] font-black text-slate-950">ÚLTIMAS</span>
                          <span class="block text-center text-[9px] font-black leading-tight text-white">TÍTULO DA<br />NOTÍCIA</span>
                        </span>
                      <% } else if (model.id === 'moldura_editorial') { %>
                        <span class="pointer-events-none absolute inset-1.5 rounded-md border-2 border-yellow-400"></span>
                        <span class="pointer-events-none absolute inset-2.5 rounded border border-white/40"></span>
                        <span class="relative block text-center text-[8px] font-bold text-white">ÚLTIMAS</span>
                        <span class="relative mx-auto block h-1 w-4/5 rounded bg-gradient-to-r from-yellow-400 to-orange-400"></span>
                        <span class="relative block pb-1 text-center text-[9px] font-black leading-tight text-white">TÍTULO DA<br />NOTÍCIA</span>
                      <% } else if (model.id === 'impacto_central') { %>
                        <span class="space-y-1 rounded-xl bg-black/70 p-1.5">
                          <span class="flex items-center justify-center gap-1">
                            <span class="h-1.5 w-1.5 rounded-full bg-yellow-400"></span>
                            <span class="text-[8px] font-bold text-white">ÚLTIMAS</span>
                            <span class="h-1.5 w-1.5 rounded-full bg-orange-400"></span>
                          </span>
                          <span class="mx-auto block h-1 w-3/4 rounded bg-gradient-to-r from-yellow-400 to-orange-400"></span>
                          <span class="block text-center text-[9px] font-black leading-tight text-white">TÍTULO DA<br />NOTÍCIA</span>
                        </span>
                      <% } else if (model.id === 'canto_solido') { %>
                        <span class="-ml-2 inline-block bg-gradient-to-r from-yellow-400 to-orange-400 py-1 pl-2 pr-3 text-[8px] font-black text-slate-950" style="clip-path: polygon(0 0, 100% 0, 88% 100%, 0 100%)">ÚLTIMAS</span>
                        <span class="block h-1 w-8 rounded bg-yellow-400"></span>
                        <span class="block pb-1 text-[9px] font-black leading-tight text-white">TÍTULO DA<br />NOTÍCIA</span>
                      <% } else { %>
                        <span class="block text-center text-[8px] font-bold tracking-wide text-white">ÚLTIMAS</span>
                        <span class="mx-auto block h-1 w-full rounded bg-gradient-to-r from-yellow-400 to-orange-400"></span>
                        <span class="block pb-1 text-center text-[9px] font-black leading-tight text-white">TÍTULO DA<br />NOTÍCIA</span>
                      <% } %>
                    </span>
                  </span>
                  <span class="block truncate border-t border-slate-700 px-2 py-1.5 text-center text-xs font-semibold text-white"><%= model.name %></span>
                </span>
              </label>
            <% }) %>
          </div>
        </div>

        <% if (profile.logo_path) { %>
          <label data-remove-logo class="mt-5 flex cursor-pointer items-start gap-3 rounded-xl border border-rose-500/30 bg-rose-500/10 p-3 text-sm text-rose-200 sm:col-span-2">
            <input id="remove-logo-input" type="checkbox" name="remover_logo" value="1" class="mt-0.5 rounded border-rose-400/50 bg-slate-950 text-rose-500" />
            <span><strong class="block font-semibold">Remover logomarca</strong><span class="mt-0.5 block text-xs text-slate-400">Ao salvar, a logo atual será apagada e deixará de aparecer nas próximas artes.</span></span>
          </label>
        <% } %>

        <div class="mt-6 flex justify-end">
          <button type="submit" class="rounded-lg bg-emerald-500 px-5 py-2.5 text-sm font-semibold text-slate-950 hover:bg-emerald-400">Salvar identidade visual</button>
        </div>
      </section>

      <aside class="rounded-2xl border border-slate-800 bg-slate-900/60 p-5">
        <p class="text-xs font-semibold uppercase tracking-wider text-slate-500">Prévia da logo</p>
        <div class="mt-4 flex aspect-[4/3] items-center justify-center overflow-hidden rounded-xl border border-slate-700 bg-gradient-to-br from-slate-800 to-slate-950 p-6">
          <img id="logo-preview" src="<%= profile.logo_path ? '/media/' + profile.logo_path.replace(/\\/g, '/') : '' %>" alt="Prévia da logomarca"
            class="<%= profile.logo_path ? '' : 'hidden' %> max-h-full max-w-full object-contain" />
          <p id="logo-empty" class="<%= profile.logo_path ? 'hidden' : '' %> text-center text-sm text-slate-500">Nenhuma logomarca configurada.</p>
        </div>
        <p class="mt-4 text-xs leading-relaxed text-slate-500">A arte final usa o formato do feed do Facebook (1080×1350 · 4:5), que preenche a largura sem faixas laterais. Vídeos/Reels continuam em 9:16.</p>
      </aside>
    </form>
  </main>

  <script>
    (function loadBrandFonts() {
      const href = <%- JSON.stringify(googleFontsHref || '') %>;
      if (!href) return;
      const link = document.createElement('link');
      link.rel = 'stylesheet';
      link.href = href;
      document.head.appendChild(link);
    })();

    const logoInput = document.getElementById('logo-input');
    const logoPreview = document.getElementById('logo-preview');
    const logoEmpty = document.getElementById('logo-empty');
    const removeLogoInput = document.getElementById('remove-logo-input');
    const brandNameInput = document.querySelector('input[name="marca_nome"]');
    const titlePreview = document.getElementById('title-preview');
    const currentLogoUrl = <%- JSON.stringify(profile.logo_path ? '/media/' + profile.logo_path.replace(/\\/g, '/') : '').replace(/</g, '\\u003c') %>;
    const brandFonts = <%- JSON.stringify(brandFonts).replace(/</g, '\\u003c') %>;
    const defaultTitleSize = <%= Number(defaultTitleSize) || 43 %>;
    const titleSizeInput = document.getElementById('title-size-input');
    const titleSizeValue = document.getElementById('title-size-value');
    let previewObjectUrl = null;

    // Nome da conta não é nome da marca: o campo pode permanecer vazio.
    brandNameInput.required = false;
    brandNameInput.value = <%- JSON.stringify(profile.marca_nome || '').replace(/</g, '\\u003c') %>;
    brandNameInput.placeholder = 'Opcional — deixe vazio para não exibir nome';

    const removeLogoCard = document.querySelector('[data-remove-logo]');
    if (removeLogoCard) logoInput.closest('label').insertAdjacentElement('afterend', removeLogoCard);

    function selectedValue(name) {
      const el = document.querySelector(`input[name="${name}"]:checked`);
      return el ? el.value : null;
    }

    function resolvePreviewColor(colorId) {
      const primary = document.querySelector('input[name="marca_cor_primaria"]')?.value || '#facc15';
      const secondary = document.querySelector('input[name="marca_cor_secundaria"]')?.value || '#fb923c';
      if (colorId === 'primaria') return primary;
      if (colorId === 'secundaria') return secondary;
      if (colorId === 'preto') return '#111827';
      if (colorId === 'amarelo') return '#facc15';
      if (colorId === 'laranja') return '#fb923c';
      return '#ffffff';
    }

    function currentTitleSize() {
      const n = Number(titleSizeInput?.value);
      return Number.isFinite(n) ? n : defaultTitleSize;
    }

    function updateTitlePreview() {
      if (!titlePreview) return;
      const fontId = selectedValue('marca_fonte') || 'serithai_condensed';
      const colorId = selectedValue('marca_titulo_cor') || 'branco';
      const sizePx = currentTitleSize();
      const font = brandFonts.find((f) => f.id === fontId) || brandFonts[0];
      if (titleSizeValue) titleSizeValue.textContent = String(sizePx);
      // prévia na tela ~0.7× o px da arte (1080)
      titlePreview.style.fontFamily = font.cssFamily;
      titlePreview.style.fontWeight = String(font.previewWeight || 900);
      titlePreview.style.color = resolvePreviewColor(colorId);
      titlePreview.style.fontSize = `${Math.max(18, Math.round(sizePx * 0.7))}px`;
    }

    document.querySelectorAll('.js-brand-font, .js-title-color').forEach((el) => {
      el.addEventListener('change', updateTitlePreview);
    });
    titleSizeInput?.addEventListener('input', updateTitlePreview);
    document.querySelectorAll('input[name="marca_cor_primaria"], input[name="marca_cor_secundaria"]').forEach((el) => {
      el.addEventListener('input', updateTitlePreview);
    });
    updateTitlePreview();

    function releaseLogoPreview() {
      if (previewObjectUrl) URL.revokeObjectURL(previewObjectUrl);
      previewObjectUrl = null;
    }

    function showLogo(src) {
      logoPreview.src = src;
      logoPreview.classList.remove('hidden');
      logoEmpty.classList.add('hidden');
    }

    function showNoLogo(message) {
      logoPreview.removeAttribute('src');
      logoPreview.classList.add('hidden');
      logoEmpty.textContent = message;
      logoEmpty.classList.remove('hidden');
    }

    logoInput.addEventListener('change', () => {
      releaseLogoPreview();
      const file = logoInput.files && logoInput.files[0];
      if (!file) {
        if (removeLogoInput?.checked) showNoLogo('A logomarca será removida ao salvar.');
        else if (currentLogoUrl) showLogo(currentLogoUrl);
        else showNoLogo('Nenhuma logomarca configurada.');
        return;
      }
      if (removeLogoInput) removeLogoInput.checked = false;
      previewObjectUrl = URL.createObjectURL(file);
      showLogo(previewObjectUrl);
    });

    removeLogoInput?.addEventListener('change', () => {
      releaseLogoPreview();
      if (removeLogoInput.checked) {
        logoInput.value = '';
        showNoLogo('A logomarca será removida ao salvar.');
      } else if (currentLogoUrl) {
        showLogo(currentLogoUrl);
      } else {
        showNoLogo('Nenhuma logomarca configurada.');
      }
    });

    window.addEventListener('beforeunload', releaseLogoPreview);
  </script>
<%- include('partials/app-end') %>
