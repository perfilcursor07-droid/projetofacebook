<%- include('partials/app-start') %>

  <main class="mx-auto max-w-6xl px-6 py-8">
    <div class="flex flex-wrap items-start justify-between gap-4">
      <div>
        <p class="text-xs font-semibold uppercase tracking-wider text-emerald-400">Identidade visual</p>
        <h1 class="mt-1 text-2xl font-semibold text-white">Minha marca</h1>
        <p class="mt-2 max-w-2xl text-sm text-slate-400">Configure a logo e as cores aplicadas automaticamente às artes das Matérias IA.</p>
      </div>
      <a href="/materias-ia" class="rounded-lg border border-slate-700 px-4 py-2 text-sm text-slate-300 hover:border-emerald-500 hover:text-emerald-300">Voltar para Matérias IA</a>
    </div>

    <% if (saved) { %>
      <div class="mt-5 rounded-xl border border-emerald-500/30 bg-emerald-500/10 px-4 py-3 text-sm text-emerald-200">Identidade visual salva com sucesso.</div>
    <% } %>
    <% if (error) { %>
      <div class="mt-5 rounded-xl border border-rose-500/30 bg-rose-500/10 px-4 py-3 text-sm text-rose-200"><%= error %></div>
    <% } %>

    <form action="/minha-marca" method="POST" enctype="multipart/form-data" class="mt-7 grid gap-6 lg:grid-cols-[minmax(0,1fr)_360px]">
      <section class="rounded-2xl border border-slate-800 bg-slate-900/60 p-6">
        <h2 class="text-base font-semibold text-white">Dados da marca</h2>
        <div class="mt-5 grid gap-4 sm:grid-cols-2">
          <label class="block sm:col-span-2">
            <span class="text-sm text-slate-400">Logomarca</span>
            <input id="logo-input" type="file" name="logo" accept="image/png,image/jpeg,image/webp"
              class="mt-1.5 block w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-300 file:mr-3 file:rounded-md file:border-0 file:bg-emerald-500 file:px-3 file:py-1.5 file:font-semibold file:text-slate-950" />
            <span class="mt-1 block text-xs text-slate-500">PNG, JPG ou WebP, até 3 MB. Prefira PNG com fundo transparente.</span>
          </label>
          <label class="block sm:col-span-2">
            <span class="text-sm text-slate-400">Nome exibido</span>
            <input name="marca_nome" maxlength="120" value="<%= profile.marca_nome || profile.nome || '' %>" required
              class="mt-1.5 w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2.5 text-white focus:border-emerald-500 focus:outline-none" />
          </label>
          <label class="block">
            <span class="text-sm text-slate-400">Categoria</span>
            <input name="marca_categoria" maxlength="80" value="<%= profile.marca_categoria || 'ÚLTIMAS' %>"
              class="mt-1.5 w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2.5 text-white focus:border-emerald-500 focus:outline-none" />
          </label>
          <label class="block">
            <span class="text-sm text-slate-400">Texto do rodapé</span>
            <input name="marca_rodape" maxlength="160" value="<%= profile.marca_rodape || '' %>" placeholder="@sua_pagina"
              class="mt-1.5 w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2.5 text-white focus:border-emerald-500 focus:outline-none" />
          </label>
          <label class="block">
            <span class="text-sm text-slate-400">Cor principal</span>
            <div class="mt-1.5 flex gap-2 rounded-lg border border-slate-700 bg-slate-950 p-2">
              <input type="color" name="marca_cor_primaria" value="<%= profile.marca_cor_primaria || '#facc15' %>" class="h-8 w-full cursor-pointer border-0 bg-transparent" />
            </div>
          </label>
          <label class="block">
            <span class="text-sm text-slate-400">Cor secundária</span>
            <div class="mt-1.5 flex gap-2 rounded-lg border border-slate-700 bg-slate-950 p-2">
              <input type="color" name="marca_cor_secundaria" value="<%= profile.marca_cor_secundaria || '#fb923c' %>" class="h-8 w-full cursor-pointer border-0 bg-transparent" />
            </div>
          </label>
        </div>

        <div class="mt-7 border-t border-slate-800 pt-6">
          <h3 class="text-sm font-semibold text-white">Modelo da arte</h3>
          <p class="mt-1 text-xs text-slate-500">Escolha um padrão para as próximas artes e para as que forem regeneradas.</p>
          <div class="mt-4 grid gap-4 sm:grid-cols-2">
            <% artModels.forEach((model) => { %>
              <label class="cursor-pointer">
                <input type="radio" name="marca_modelo_arte" value="<%= model.id %>" class="peer sr-only"
                  <%= (profile.marca_modelo_arte || defaultArtModel) === model.id ? 'checked' : '' %> />
                <span class="block rounded-xl border border-slate-700 bg-slate-950/70 p-3 transition peer-checked:border-emerald-400 peer-checked:ring-2 peer-checked:ring-emerald-400/20 hover:border-slate-500">
                  <span class="relative block aspect-[4/5] overflow-hidden rounded-lg bg-gradient-to-br from-slate-700 via-slate-900 to-black">
                    <span class="absolute left-1/2 top-3 w-2/5 -translate-x-1/2 rounded bg-white/90 py-1 text-center text-[7px] font-bold text-slate-900">MARCA</span>
                    <% if (model.id === 'faixa_classica') { %>
                      <span class="absolute inset-x-3 bottom-[36%] text-center text-[7px] font-bold text-white">ÚLTIMAS</span>
                      <span class="absolute inset-x-3 bottom-[32%] h-1 rounded bg-gradient-to-r from-yellow-400 to-orange-400"></span>
                      <span class="absolute inset-x-3 bottom-[14%] text-center text-[8px] font-black leading-tight text-white">TÍTULO DA NOTÍCIA<br />EM DESTAQUE</span>
                    <% } else if (model.id === 'bloco_inferior') { %>
                      <span class="absolute inset-x-0 bottom-0 h-[48%] bg-black/75"></span>
                      <span class="absolute inset-x-0 bottom-[47%] h-1 bg-gradient-to-r from-yellow-400 to-orange-400"></span>
                      <span class="absolute left-3 bottom-[34%] text-[7px] font-bold text-white">ÚLTIMAS</span>
                      <span class="absolute inset-x-3 bottom-[15%] text-[8px] font-black leading-tight text-white">TÍTULO DA NOTÍCIA<br />EM DESTAQUE</span>
                    <% } else if (model.id === 'minimalista') { %>
                      <span class="absolute left-3 bottom-[38%] rounded bg-yellow-400 px-2 py-1 text-[7px] font-black text-slate-950">ÚLTIMAS</span>
                      <span class="absolute left-3 bottom-[31%] h-1 w-1/4 rounded bg-orange-400"></span>
                      <span class="absolute inset-x-3 bottom-[13%] text-[8px] font-black leading-tight text-white">TÍTULO DA NOTÍCIA<br />EM DESTAQUE</span>
                    <% } else { %>
                      <span class="absolute bottom-[12%] left-3 top-[42%] w-1 rounded bg-gradient-to-b from-yellow-400 to-orange-400"></span>
                      <span class="absolute left-6 bottom-[36%] text-[7px] font-bold text-white">ÚLTIMAS</span>
                      <span class="absolute left-6 right-3 bottom-[15%] text-[8px] font-black leading-tight text-white">TÍTULO DA NOTÍCIA<br />EM DESTAQUE</span>
                    <% } %>
                  </span>
                  <span class="mt-3 block text-sm font-semibold text-white"><%= model.name %></span>
                  <span class="mt-1 block text-xs leading-relaxed text-slate-500"><%= model.description %></span>
                </span>
              </label>
            <% }) %>
          </div>
        </div>

        <% if (profile.logo_path) { %>
          <label class="mt-5 flex items-center gap-2 text-sm text-slate-400">
            <input type="checkbox" name="remover_logo" value="1" class="rounded border-slate-600 bg-slate-950 text-rose-500" />
            Remover a logomarca atual
          </label>
        <% } %>

        <div class="mt-6 flex justify-end">
          <button type="submit" class="rounded-lg bg-emerald-500 px-5 py-2.5 text-sm font-semibold text-slate-950 hover:bg-emerald-400">Salvar identidade visual</button>
        </div>
      </section>

      <aside class="rounded-2xl border border-slate-800 bg-slate-900/60 p-5">
        <p class="text-xs font-semibold uppercase tracking-wider text-slate-500">Prévia da logo</p>
        <div class="mt-4 flex aspect-[4/3] items-center justify-center overflow-hidden rounded-xl border border-slate-700 bg-gradient-to-br from-slate-800 to-slate-950 p-6">
          <img id="logo-preview" src="<%= profile.logo_path ? '/media/' + profile.logo_path.replace(/\\/g, '/') : '' %>" alt="Prévia da logomarca"
            class="<%= profile.logo_path ? '' : 'hidden' %> max-h-full max-w-full object-contain" />
          <p id="logo-empty" class="<%= profile.logo_path ? 'hidden' : '' %> text-center text-sm text-slate-500">Envie uma logo para visualizar aqui.</p>
        </div>
        <p class="mt-4 text-xs leading-relaxed text-slate-500">A arte final utiliza formato vertical 4:5, com foto, título sobreposto, categoria, cores e sua logomarca.</p>
      </aside>
    </form>
  </main>

  <script>
    const logoInput = document.getElementById('logo-input');
    const logoPreview = document.getElementById('logo-preview');
    const logoEmpty = document.getElementById('logo-empty');
    logoInput.addEventListener('change', () => {
      const file = logoInput.files && logoInput.files[0];
      if (!file) return;
      logoPreview.src = URL.createObjectURL(file);
      logoPreview.classList.remove('hidden');
      logoEmpty.classList.add('hidden');
    });
  </script>
<%- include('partials/app-end') %>
