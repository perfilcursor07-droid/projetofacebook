<%- include('partials/app-start') %>
<%
  const statusLabels = {
    rascunho: 'Rascunho',
    pronto: 'Pronta',
    agendado: 'Agendada',
    publicado: 'Publicada',
    erro: 'Erro',
  };
  const statusClass = {
    rascunho: 'bg-slate-800 text-slate-300',
    pronto: 'bg-sky-500/15 text-sky-300',
    agendado: 'bg-amber-500/15 text-amber-300',
    publicado: 'bg-emerald-500/15 text-emerald-300',
    erro: 'bg-rose-500/15 text-rose-300',
  };
  const st = matter.status || 'rascunho';
  const canEdit = st !== 'publicado';
  const canRepublish = st === 'publicado';
  const isReel = matter.tipo_publicacao === 'reel';
  const imageUrl = matter.imagem_url || '';
  const videoUrl = matter.video_path ? '/media/' + String(matter.video_path).replace(/^\/+/, '') : '';
  const reelProcessing = isReel && (!videoUrl || String(matter.materia || '').startsWith('⏳'));
  const canReloadBrand =
    !isReel &&
    (Boolean(matter.imagem_fonte_url) ||
      (!matter.imagem_path && /^https?:\/\//i.test(String(imageUrl))));
%>

  <main class="mx-auto max-w-9xl px-4 py-5 sm:px-6 sm:py-8">
    <%- include('partials/content-nav', { contentTab: 'matters' }) %>

    <div class="flex flex-wrap items-start justify-between gap-4">
      <div>
        <a href="/minhas-materias" class="text-xs font-medium text-slate-500 hover:text-emerald-300">← Voltar para matérias salvas</a>
        <h1 class="mt-2 text-2xl font-semibold text-white">Editar matéria</h1>
        <p class="mt-1 text-sm text-slate-400">Revise o texto, salve as alterações e publique quando quiser.</p>
      </div>
      <span class="rounded-full px-3 py-1 text-xs font-medium <%= statusClass[st] || statusClass.rascunho %>"><%= statusLabels[st] || st %></span>
    </div>

    <% if (success) { %><div class="mt-5 rounded-xl border border-emerald-500/30 bg-emerald-500/10 px-4 py-3 text-sm text-emerald-200"><%= success %></div><% } %>
    <% if (error) { %><div class="mt-5 rounded-xl border border-rose-500/30 bg-rose-500/10 px-4 py-3 text-sm text-rose-200"><%= error %></div><% } %>
    <p id="matter-status" class="mt-4 text-sm text-slate-400"></p>

    <div class="mt-6 grid gap-6 lg:grid-cols-[minmax(0,1fr)_300px]">
      <section class="rounded-2xl border border-slate-800 bg-slate-900/60 p-5">
        <!-- Nova matéria a partir do link (sem sair da tela) -->
        <div id="matter-nova-link" class="hidden space-y-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-emerald-400/80">Nova matéria a partir do link</p>
            <p class="mt-1 text-sm text-slate-400">Cole o próximo link. A matéria atual permanece salva — você só começa outra daqui.</p>
          </div>
          <label class="block text-sm">
            <span class="text-slate-400">Link (foto do Facebook, notícia ou Reel)</span>
            <input id="matter-nova-link-url" type="url" inputmode="url"
              placeholder="https://…"
              class="mt-1.5 w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2.5 text-slate-100 focus:border-emerald-500 focus:outline-none" />
          </label>
          <details class="rounded-xl border border-amber-500/25 bg-amber-500/5">
            <summary class="cursor-pointer px-3 py-2.5 text-xs font-medium text-amber-100 hover:text-white">
              Se o Facebook bloquear a leitura — cole a legenda aqui
            </summary>
            <div class="space-y-3 border-t border-amber-500/20 px-3 py-3">
              <textarea id="matter-nova-link-texto" rows="3" placeholder="Cole a legenda completa do post…"
                class="w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-100 placeholder:text-slate-600 focus:border-emerald-500 focus:outline-none"></textarea>
              <input id="matter-nova-link-imagem" type="url" placeholder="URL da imagem (opcional)"
                class="w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-100 placeholder:text-slate-600 focus:border-emerald-500 focus:outline-none" />
            </div>
          </details>
          <div class="grid gap-3 sm:grid-cols-2">
            <label class="block text-sm">
              <span class="text-slate-400">Página do Facebook</span>
              <select id="matter-nova-link-page" class="mia-page-select mt-1.5 w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2.5 text-slate-100">
                <option value="">Carregando…</option>
              </select>
            </label>
            <label class="block text-sm">
              <span class="text-slate-400">Tipo de publicação</span>
              <select id="matter-nova-link-tipo" class="mt-1.5 w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2.5 text-slate-100">
                <option value="auto" selected>Automático (detecta Reel)</option>
                <option value="foto">Foto + legenda</option>
                <option value="texto">Texto</option>
                <option value="reel">Reel (vídeo)</option>
              </select>
            </label>
          </div>
          <div class="flex flex-wrap gap-2">
            <button type="button" id="btn-gerar-nova-link"
              class="rounded-lg bg-emerald-500 px-4 py-2.5 text-sm font-semibold text-slate-950 hover:bg-emerald-400">
              Gerar a partir do link
            </button>
            <button type="button" id="btn-cancelar-nova-link"
              class="rounded-lg border border-slate-600 px-4 py-2.5 text-sm text-slate-300 hover:border-slate-400 hover:text-white">
              Voltar à matéria
            </button>
          </div>
          <p id="matter-nova-link-status" class="text-sm text-slate-400"></p>
        </div>

        <div id="matter-edit-atual">
        <label class="mt-0 block text-sm">
          <span class="text-slate-400">Título</span>
          <input id="matter-titulo" <%= canEdit ? '' : 'readonly' %> value="<%= matter.titulo || '' %>"
            class="mt-1.5 w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2.5 text-base font-semibold text-white focus:border-emerald-500 focus:outline-none <%= canEdit ? '' : 'opacity-80' %>" />
        </label>
        <div class="mt-2 flex flex-wrap items-center gap-2">
          <% if (canEdit) { %>
            <label class="flex items-center gap-1.5 text-xs text-slate-400">
              <span class="shrink-0">Tom</span>
              <select id="matter-titulo-tom" class="rounded-lg border border-slate-700 bg-slate-950 px-2 py-1.5 text-xs text-slate-200 focus:border-violet-500 focus:outline-none">
                <option value="natural" selected>Natural</option>
                <option value="polemico">Mais polêmico</option>
                <option value="direto">Direto</option>
                <option value="curiosidade">Curiosidade</option>
                <option value="emocional">Emocional</option>
                <option value="factual">Factual</option>
              </select>
            </label>
            <button type="button" id="btn-sugerir-titulo"
              class="rounded-lg border border-violet-500/40 bg-violet-500/15 px-3 py-1.5 text-xs font-semibold text-violet-200 hover:bg-violet-500/25">
              Sugerir outro título
            </button>
          <% } %>
          <button type="button" id="btn-limpar-nova-materia"
            class="rounded-lg border border-slate-600 bg-slate-950 px-3 py-1.5 text-xs font-semibold text-slate-200 hover:border-emerald-500/50 hover:text-emerald-300"
            title="Limpar e começar outra matéria a partir de um novo link, sem sair desta tela">
            Limpar
          </button>
        </div>
        <% if (canEdit) { %>
          <p class="mt-1.5 text-[11px] leading-snug text-slate-500">A IA gera outra manchete no tom escolhido. Clique de novo até gostar — em Reels a capa no início do vídeo também é regenerada (modelo Minha marca).</p>
        <% } %>

        <label class="mt-4 block text-sm">
          <span class="flex flex-wrap items-center justify-between gap-2">
            <span class="text-slate-400">Matéria / legenda (Facebook)</span>
            <button type="button" id="btn-copiar-legenda"
              class="rounded-md border border-slate-700 bg-slate-900 px-2.5 py-1 text-[11px] font-semibold text-slate-300 hover:border-emerald-500/50 hover:text-emerald-300">
              Copiar legenda
            </button>
          </span>
          <textarea id="matter-materia" rows="14" <%= canEdit ? '' : 'readonly' %>
            class="mt-1.5 w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-3 text-sm leading-relaxed text-slate-100 focus:border-emerald-500 focus:outline-none <%= canEdit ? '' : 'opacity-80' %>"><%= matter.materia || '' %></textarea>
          <p class="mt-1.5 text-[11px] leading-snug text-slate-500">Separe parágrafos com linha em branco. Alvo da IA: ~1700–2100 caracteres (máximo útil Face/Insta). Fonte longa = condensar; fonte curta = completar.</p>
        </label>

        <label class="mt-4 block text-sm">
          <span class="text-slate-400">Fonte / crédito (na legenda)</span>
          <textarea id="matter-fonte-credito" rows="2" <%= canEdit ? '' : 'readonly' %>
            placeholder="Ex.: Fonte: G1&#10;(Foto: Reprodução)"
            class="mt-1.5 w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2.5 text-sm leading-relaxed text-slate-100 placeholder:text-slate-600 focus:border-emerald-500 focus:outline-none <%= canEdit ? '' : 'opacity-80' %>"><%= matter.fonte_credito || '' %></textarea>
          <p class="mt-1.5 text-[11px] leading-snug text-slate-500">Aparece no post depois do texto e antes das hashtags. Nas matérias novas a IA já preenche com o veículo e “(Foto: Reprodução)”.</p>
        </label>

        <% if (canEdit) { %>
          <div class="mt-4 rounded-xl border border-slate-800 bg-slate-950/60 p-3">
            <label class="block text-sm">
              <span class="text-slate-400">Informações extras (opcional)</span>
              <textarea id="matter-info-extra" rows="4"
                placeholder="Cole fatos, nomes, números ou contexto que faltam no texto…"
                class="mt-1.5 w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2.5 text-sm leading-relaxed text-slate-100 placeholder:text-slate-600 focus:border-sky-500 focus:outline-none"></textarea>
            </label>
            <button type="button" id="btn-reescrever-info"
              class="mt-2.5 rounded-lg border border-sky-500/40 bg-sky-500/15 px-3 py-2 text-xs font-semibold text-sky-200 hover:bg-sky-500/25">
              Reescrever texto com informações incluídas
            </button>
            <p class="mt-1.5 text-[11px] leading-snug text-slate-500">A IA reforça a matéria com o que você colou, sem inventar fora disso.</p>
          </div>
        <% } %>

        <% if (hashtags && hashtags.length) { %>
          <div class="mt-4">
            <p class="text-xs uppercase tracking-wide text-slate-500">Hashtags sugeridas</p>
            <p id="matter-hashtags-line" class="mt-1.5 text-sm text-slate-400"><%= hashtags.map((h) => '#' + String(h).replace(/^#/, '')).join(' ') %></p>
          </div>
        <% } else { %>
          <div class="mt-4 hidden" id="matter-hashtags-wrap">
            <p class="text-xs uppercase tracking-wide text-slate-500">Hashtags sugeridas</p>
            <p id="matter-hashtags-line" class="mt-1.5 text-sm text-slate-400"></p>
          </div>
        <% } %>

        <%
          const fonteUrl = String(matter.fonte_url || '').trim();
          const fonteTitulo = String(matter.fonte_titulo || '').trim();
          let fonteHost = '';
          if (fonteUrl) {
            try { fonteHost = new URL(fonteUrl).hostname.replace(/^www\./i, ''); } catch (_) {}
          }
        %>
        <% if (fonteUrl || fonteTitulo) { %>
          <div class="mt-4 rounded-xl border border-slate-800 bg-slate-950/50 px-3 py-3" id="matter-fonte-wrap">
            <p class="text-xs uppercase tracking-wide text-slate-500">Fonte da matéria</p>
            <% if (fonteTitulo) { %>
              <p class="mt-1.5 text-sm text-slate-300" id="matter-fonte-titulo"><%= fonteTitulo %></p>
            <% } %>
            <% if (fonteUrl) { %>
              <a id="matter-fonte-link" href="<%= fonteUrl %>" target="_blank" rel="noopener"
                class="mt-1 inline-flex items-center gap-1 text-sm text-sky-400 hover:text-sky-300 break-all">
                <%= fonteHost || 'Abrir fonte' %> →
              </a>
              <p class="mt-1 text-[11px] text-slate-600 break-all"><%= fonteUrl %></p>
            <% } else { %>
              <p class="mt-1.5 text-sm text-slate-500">Sem link da fonte salvo nesta matéria.</p>
            <% } %>
          </div>
        <% } else { %>
          <div class="mt-4 hidden rounded-xl border border-slate-800 bg-slate-950/50 px-3 py-3" id="matter-fonte-wrap">
            <p class="text-xs uppercase tracking-wide text-slate-500">Fonte da matéria</p>
            <p class="mt-1.5 text-sm text-slate-300" id="matter-fonte-titulo"></p>
            <a id="matter-fonte-link" href="#" target="_blank" rel="noopener"
              class="mt-1 hidden inline-flex items-center gap-1 text-sm text-sky-400 hover:text-sky-300 break-all"></a>
          </div>
        <% } %>

        <% if (canEdit) { %>
          <div class="mt-5 flex flex-wrap gap-2">
            <button type="button" id="btn-salvar" class="rounded-lg border border-emerald-500/50 bg-emerald-500/15 px-4 py-2.5 text-sm font-semibold text-emerald-200 hover:bg-emerald-500/25">Salvar alterações</button>
          </div>
        <% } %>
        </div><!-- /matter-edit-atual -->
      </section>

      <aside class="space-y-4">
        <% if (isReel) { %>
          <div id="matter-reel-wrap" class="rounded-2xl border border-slate-800 bg-slate-900/60 p-3">
            <div class="mb-2 flex items-center justify-between gap-2">
              <span class="text-xs font-semibold uppercase tracking-wide text-violet-300">Reel</span>
              <span class="rounded-full bg-slate-800 px-2 py-0.5 text-[10px] text-slate-400">9:16 · capa no início</span>
            </div>
            <% if (videoUrl) { %>
              <video id="matter-reel-video" class="block w-full rounded-xl border border-slate-700 bg-black" controls playsinline
                src="<%= videoUrl %>?t=<%= Date.now() %>" poster="<%= imageUrl || '' %>"></video>
            <% } else { %>
              <div id="matter-reel-placeholder" class="flex min-h-[280px] flex-col items-center justify-center gap-3 rounded-xl border border-dashed border-slate-700 bg-slate-950 px-4 py-8 text-center">
                <span class="inline-block h-8 w-8 animate-spin rounded-full border-2 border-violet-400/30 border-t-violet-300"></span>
                <p class="text-sm text-slate-300">Processando o Reel…</p>
                <p class="text-[11px] text-slate-500">Baixando · transcrevendo · legenda · capa Minha marca</p>
              </div>
            <% } %>
            <% if (matter.error_message) { %>
              <p class="mt-2 text-xs text-amber-200"><%= matter.error_message %></p>
            <% } %>
          </div>
        <% } else { %>
          <div id="matter-img-wrap" class="<%= imageUrl ? '' : 'hidden' %> rounded-2xl border border-slate-800 bg-slate-900/60 p-3">
            <div class="mb-2 flex items-center justify-between gap-2">
              <span class="text-xs font-semibold uppercase tracking-wide text-emerald-300">Arte</span>
              <div class="flex items-center gap-2">
                <a id="btn-baixar-arte" href="<%= imageUrl || '#' %>" download="arte-materia-<%= matter.id %>.jpg"
                  class="<%= imageUrl ? '' : 'hidden' %> rounded-md border border-slate-700 bg-slate-900 px-2.5 py-1 text-[11px] font-semibold text-slate-300 hover:border-emerald-500/50 hover:text-emerald-300">
                  Baixar imagem
                </a>
                <span class="rounded-full bg-slate-800 px-2 py-0.5 text-[10px] text-slate-400">1080 × 1350 · 4:5</span>
              </div>
            </div>
            <img id="matter-img" src="<%= imageUrl %>" alt="Arte da matéria" class="block h-auto w-full rounded-xl border border-slate-700 bg-slate-950 object-contain" />
          </div>
        <% } %>

        <% if (canEdit && !isReel) { %>
          <div class="rounded-2xl border border-slate-800 bg-slate-900/60 p-3">
            <p class="text-[11px] font-semibold uppercase tracking-wide text-slate-500">Outras sugestões</p>
            <div id="matter-img-suggest-loading" class="mt-2 hidden items-center gap-2 rounded-lg border border-amber-500/40 bg-amber-500/15 px-3 py-2">
              <span class="inline-block h-3.5 w-3.5 shrink-0 animate-spin rounded-full border-2 border-amber-300/30 border-t-amber-300"></span>
              <p class="text-xs font-medium text-amber-100">Aguarde, alterando a arte…</p>
            </div>
            <p id="matter-img-suggest-meta" class="mt-1 line-clamp-2 text-[11px] text-slate-500">Buscando fotos relacionadas…</p>
            <div id="matter-img-suggest-strip" class="mt-2 flex max-h-[7.5rem] flex-wrap gap-1.5 overflow-y-auto">
              <div class="h-16 w-12 shrink-0 animate-pulse rounded-md bg-slate-800" style="width:48px;height:64px"></div>
              <div class="h-16 w-12 shrink-0 animate-pulse rounded-md bg-slate-800" style="width:48px;height:64px"></div>
              <div class="h-16 w-12 shrink-0 animate-pulse rounded-md bg-slate-800" style="width:48px;height:64px"></div>
              <div class="h-16 w-12 shrink-0 animate-pulse rounded-md bg-slate-800" style="width:48px;height:64px"></div>
              <div class="h-16 w-12 shrink-0 animate-pulse rounded-md bg-slate-800" style="width:48px;height:64px"></div>
              <div class="h-16 w-12 shrink-0 animate-pulse rounded-md bg-slate-800" style="width:48px;height:64px"></div>
            </div>
          </div>
        <% } %>

        <% if (canEdit && !isReel) { %>
          <div class="rounded-2xl border border-slate-800 bg-slate-900/60 p-4">
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Trocar imagem</p>
            <p class="mt-2 text-xs leading-relaxed text-slate-400">Escolha uma foto. Depois de confirmar, a identidade visual configurada em <a href="/minha-marca" class="text-emerald-300 hover:underline">Minha marca</a> será aplicada automaticamente.</p>

            <% if (canReloadBrand) { %>
              <div class="mt-3 rounded-lg border border-emerald-500/25 bg-emerald-500/10 p-3">
                <p class="text-xs font-semibold text-emerald-200">Aplicar ou atualizar Minha marca</p>
                <p class="mt-1 text-xs leading-relaxed text-slate-400">Gera a arte 4:5 com título, cores e logo configurados em Minha marca, usando a foto atual.</p>
                <button type="button" id="btn-recarregar-marca" class="mt-2 w-full rounded-lg border border-emerald-500/50 px-3 py-2 text-xs font-semibold text-emerald-200 hover:bg-emerald-500/15">↻ Aplicar modelo da minha marca</button>
              </div>
            <% } else { %>
              <p class="mt-3 rounded-lg border border-amber-500/20 bg-amber-500/10 p-3 text-xs text-amber-200">Para aplicar sua marca, escolha uma imagem abaixo.</p>
              <% if (matter.fonte_url) { %>
                <button type="button" id="btn-buscar-imagem-fonte"
                  class="mt-2 w-full rounded-lg border border-sky-500/40 bg-sky-500/10 px-3 py-2 text-xs font-semibold text-sky-200 hover:bg-sky-500/20">
                  Buscar imagem da fonte
                </button>
              <% } %>
            <% } %>

            <div class="mt-3 rounded-lg border border-violet-500/25 bg-violet-500/10 p-3">
              <p class="text-xs font-semibold text-violet-200">Sugestões da IA</p>
              <p class="mt-1 text-[11px] leading-relaxed text-slate-400">
                A primeira miniatura é a foto do post/fonte. As outras são sugestões — clique para trocar a arte.
              </p>
              <button type="button" id="btn-sugerir-imagens"
                class="mt-2 w-full rounded-lg border border-violet-500/50 px-3 py-2 text-xs font-semibold text-violet-200 hover:bg-violet-500/15">
                Buscar novas sugestões
              </button>
            </div>

            <label class="mt-3 block cursor-pointer rounded-lg border border-dashed border-slate-600 px-3 py-2.5 text-center text-sm font-medium text-slate-300 hover:border-emerald-500 hover:text-emerald-200">
              Escolher outra imagem
              <input id="matter-image-input" type="file" accept="image/png,image/jpeg,image/webp" class="sr-only" />
            </label>

            <div id="matter-image-preview-wrap" class="mt-3 hidden">
              <img id="matter-image-preview" src="" alt="Pré-visualização da imagem escolhida" class="block max-h-72 w-full rounded-lg border border-slate-700 bg-slate-950 object-contain" />
              <p class="mt-2 text-xs text-slate-500">Esta é a foto original. Confirme para gerar a arte com título e marca.</p>
              <div class="mt-3 flex gap-2">
                <button type="button" id="btn-confirmar-imagem" class="flex-1 rounded-lg bg-emerald-500 px-3 py-2 text-xs font-semibold text-slate-950 hover:bg-emerald-400">Sim, usar esta imagem</button>
                <button type="button" id="btn-cancelar-imagem" class="rounded-lg border border-slate-600 px-3 py-2 text-xs text-slate-300 hover:border-slate-400">Cancelar</button>
              </div>
            </div>
          </div>
        <% } %>

        <div class="rounded-2xl border border-slate-800 bg-slate-900/60 p-4">
          <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Publicação</p>

          <label class="mt-3 block text-sm">
            <span class="text-slate-400">Página do Facebook</span>
            <select id="matter-page" class="mt-1.5 w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-white">
              <option value="">Carregando…</option>
            </select>
          </label>

          <label class="mt-3 block text-sm">
            <span class="text-slate-400">Tipo</span>
            <select id="matter-tipo" class="mt-1.5 w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-white" <%= isReel ? 'disabled' : '' %>>
              <% if (isReel) { %>
                <option value="reel" selected>Reel (vídeo)</option>
              <% } else { %>
                <option value="foto" <%= matter.tipo_publicacao !== 'texto' ? 'selected' : '' %>>Foto + legenda</option>
                <option value="texto" <%= matter.tipo_publicacao === 'texto' ? 'selected' : '' %>>Texto</option>
              <% } %>
            </select>
          </label>

          <% if (canEdit) { %>
            <button type="button" id="btn-publicar" class="mt-4 w-full rounded-lg bg-[#1877F2] px-4 py-2.5 text-sm font-semibold text-white hover:bg-[#166FE5]" <%= reelProcessing ? 'disabled' : '' %>>
              <%= isReel ? 'Publicar como Reels' : 'Publicar na Página' %>
            </button>

            <button type="button" id="btn-variacao-tema"
              class="mt-2 w-full rounded-lg border border-violet-500/40 px-4 py-2.5 text-sm font-medium text-violet-200 transition hover:bg-violet-500/15"
              <%= reelProcessing ? 'disabled' : '' %>>
              Nova matéria neste tema
            </button>
            <p class="mt-1.5 text-[11px] leading-snug text-slate-500">Busca infos novas (Brave) e reescreve sem plagiar — ideal quando o post viraliza.</p>

            <div class="mt-4 border-t border-slate-800 pt-4">
              <label class="block text-xs text-slate-400">Agendar (horário de Araguaína −03)
                <input id="matter-schedule" type="datetime-local" class="mt-1.5 w-full rounded-lg border border-slate-700 bg-slate-950 px-2 py-2 text-xs text-slate-200" />
              </label>
              <button type="button" id="btn-agendar" class="mt-2 w-full rounded-lg border border-slate-600 px-3 py-2 text-xs text-slate-300 hover:border-slate-400">Agendar publicação</button>
            </div>
          <% } else if (canRepublish) { %>
            <% if (matter.published_at) { %>
              <p class="mt-3 text-xs text-slate-500">Publicada em <%= new Date(matter.published_at).toLocaleString('pt-BR') %></p>
            <% } %>
            <button type="button" id="btn-publicar" data-republicar="1" class="mt-4 w-full rounded-lg bg-[#1877F2] px-4 py-2.5 text-sm font-semibold text-white hover:bg-[#166FE5]">Republicar na Página</button>
            <p class="mt-1.5 text-[11px] leading-snug text-slate-500">Cria um novo post no Facebook com o texto e a arte atuais (não edita o post antigo).</p>
            <button type="button" id="btn-variacao-tema"
              class="mt-3 w-full rounded-lg border border-violet-500/40 px-4 py-2.5 text-sm font-medium text-violet-200 transition hover:bg-violet-500/15">
              Nova matéria neste tema
            </button>
            <button type="button" id="btn-matter-views"
              class="mt-2 w-full rounded-lg border border-slate-700 px-3 py-2 text-xs text-slate-400 hover:border-sky-500/40 hover:text-sky-300">
              Atualizar visualizações no Facebook
            </button>
          <% } else if (matter.published_at) { %>
            <p class="mt-3 text-xs text-slate-500">Publicada em <%= new Date(matter.published_at).toLocaleString('pt-BR') %></p>
            <button type="button" id="btn-variacao-tema"
              class="mt-3 w-full rounded-lg border border-violet-500/40 px-4 py-2.5 text-sm font-medium text-violet-200 transition hover:bg-violet-500/15">
              Nova matéria neste tema
            </button>
            <button type="button" id="btn-matter-views"
              class="mt-2 w-full rounded-lg border border-slate-700 px-3 py-2 text-xs text-slate-400 hover:border-sky-500/40 hover:text-sky-300">
              Atualizar visualizações no Facebook
            </button>
          <% } %>
        </div>
      </aside>
    </div>
  </main>

  <div id="publish-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-slate-950/85 p-6 backdrop-blur-sm" role="dialog" aria-modal="true" aria-labelledby="publish-modal-title">
    <div class="w-full max-w-sm rounded-2xl border border-slate-700 bg-slate-900 p-8 text-center shadow-xl shadow-black/40">
      <div id="publish-modal-spin" class="mx-auto h-12 w-12 animate-spin rounded-full border-2 border-[#1877F2]/30 border-t-[#1877F2]"></div>
      <div id="publish-modal-ok" class="mx-auto hidden flex h-12 w-12 items-center justify-center rounded-full bg-emerald-500/15 text-2xl text-emerald-300">✓</div>
      <h2 id="publish-modal-title" class="mt-5 text-lg font-semibold text-white">Publicando…</h2>
      <p id="publish-modal-text" class="mt-2 text-sm leading-relaxed text-slate-400">Enviando a matéria para a Página do Facebook.</p>
      <a id="publish-modal-link" href="#" target="_blank" rel="noopener" class="mt-4 hidden inline-block text-sm text-sky-400 hover:underline">Ver post no Facebook →</a>
    </div>
  </div>

  <script>
    window.__MATTER_EDIT__ = {
      id: <%= matter.id %>,
      pageId: <%= matter.facebook_page_id ? Number(matter.facebook_page_id) : 'null' %>,
      canEdit: <%= canEdit ? 'true' : 'false' %>,
      canRepublish: <%= canRepublish ? 'true' : 'false' %>,
      isReel: <%= isReel ? 'true' : 'false' %>,
      reelProcessing: <%= reelProcessing ? 'true' : 'false' %>,
      videoUrl: <%- JSON.stringify(videoUrl || null) %>,
      listUrl: '/minhas-materias',
    };
  </script>
  <script src="/js/materia-ia-editar.js"></script>
<%- include('partials/app-end') %>
