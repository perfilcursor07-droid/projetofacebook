<%- include('partials/app-start') %>
<%
  const statusLabels = {
    rascunho: 'Rascunho',
    pronto: 'Pronta',
    agendado: 'Agendada',
    publicado: 'Publicada',
    erro: 'Erro',
  };
  const statusClass = {
    rascunho: 'bg-slate-800 text-slate-300',
    pronto: 'bg-sky-500/15 text-sky-300',
    agendado: 'bg-amber-500/15 text-amber-300',
    publicado: 'bg-emerald-500/15 text-emerald-300',
    erro: 'bg-rose-500/15 text-rose-300',
  };
  const st = matter.status || 'rascunho';
  const canEdit = st !== 'publicado';
  const canRepublish = st === 'publicado';
  const imageUrl = matter.imagem_url || '';
%>

  <main class="mx-auto max-w-9xl px-4 py-5 sm:px-6 sm:py-8">
    <%- include('partials/content-nav', { contentTab: 'matters' }) %>

    <div class="flex flex-wrap items-start justify-between gap-4">
      <div>
        <a href="/minhas-materias" class="text-xs font-medium text-slate-500 hover:text-emerald-300">← Voltar para matérias salvas</a>
        <h1 class="mt-2 text-2xl font-semibold text-white">Editar matéria</h1>
        <p class="mt-1 text-sm text-slate-400">Revise o texto, salve as alterações e publique quando quiser.</p>
      </div>
      <span class="rounded-full px-3 py-1 text-xs font-medium <%= statusClass[st] || statusClass.rascunho %>"><%= statusLabels[st] || st %></span>
    </div>

    <% if (success) { %><div class="mt-5 rounded-xl border border-emerald-500/30 bg-emerald-500/10 px-4 py-3 text-sm text-emerald-200"><%= success %></div><% } %>
    <% if (error) { %><div class="mt-5 rounded-xl border border-rose-500/30 bg-rose-500/10 px-4 py-3 text-sm text-rose-200"><%= error %></div><% } %>
    <p id="matter-status" class="mt-4 text-sm text-slate-400"></p>

    <div class="mt-6 grid gap-6 lg:grid-cols-[minmax(0,1fr)_300px]">
      <section class="rounded-2xl border border-slate-800 bg-slate-900/60 p-5">
        <% if (matter.fonte_titulo) { %>
          <p class="text-xs text-slate-500">
            Com base em: <%= matter.fonte_titulo %>
            <% if (matter.fonte_url) { %>
              · <a href="<%= matter.fonte_url %>" target="_blank" rel="noopener" class="text-sky-400 hover:text-sky-300">Abrir fonte →</a>
            <% } %>
          </p>
        <% } %>

        <label class="mt-4 block text-sm">
          <span class="text-slate-400">Título</span>
          <input id="matter-titulo" <%= canEdit ? '' : 'readonly' %> value="<%= matter.titulo || '' %>"
            class="mt-1.5 w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2.5 text-base font-semibold text-white focus:border-emerald-500 focus:outline-none <%= canEdit ? '' : 'opacity-80' %>" />
        </label>

        <label class="mt-4 block text-sm">
          <span class="text-slate-400">Matéria / legenda (Facebook)</span>
          <textarea id="matter-materia" rows="14" <%= canEdit ? '' : 'readonly' %>
            class="mt-1.5 w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-3 text-sm leading-relaxed text-slate-100 focus:border-emerald-500 focus:outline-none <%= canEdit ? '' : 'opacity-80' %>"><%= matter.materia || '' %></textarea>
        </label>

        <% if (hashtags && hashtags.length) { %>
          <div class="mt-4">
            <p class="text-xs uppercase tracking-wide text-slate-500">Hashtags sugeridas</p>
            <p class="mt-1.5 text-sm text-slate-400"><%= hashtags.map((h) => '#' + String(h).replace(/^#/, '')).join(' ') %></p>
          </div>
        <% } %>

        <% if (canEdit) { %>
          <div class="mt-5 flex flex-wrap gap-2">
            <button type="button" id="btn-salvar" class="rounded-lg border border-emerald-500/50 bg-emerald-500/15 px-4 py-2.5 text-sm font-semibold text-emerald-200 hover:bg-emerald-500/25">Salvar alterações</button>
          </div>
        <% } %>
      </section>

      <aside class="space-y-4">
        <div id="matter-img-wrap" class="<%= imageUrl ? '' : 'hidden' %> rounded-2xl border border-slate-800 bg-slate-900/60 p-3">
          <div class="mb-2 flex items-center justify-between gap-2">
            <span class="text-xs font-semibold uppercase tracking-wide text-emerald-300">Arte</span>
            <span class="rounded-full bg-slate-800 px-2 py-0.5 text-[10px] text-slate-400">1080 × 1350 · 4:5</span>
          </div>
          <img id="matter-img" src="<%= imageUrl %>" alt="Arte da matéria" class="block h-auto w-full rounded-xl border border-slate-700 bg-slate-950 object-contain" />
        </div>

        <% if (canEdit) { %>
          <div class="rounded-2xl border border-slate-800 bg-slate-900/60 p-4">
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Trocar imagem</p>
            <p class="mt-2 text-xs leading-relaxed text-slate-400">Escolha uma foto. Depois de confirmar, a identidade visual configurada em <a href="/minha-marca" class="text-emerald-300 hover:underline">Minha marca</a> será aplicada automaticamente.</p>

            <% if (matter.imagem_fonte_url) { %>
              <div class="mt-3 rounded-lg border border-emerald-500/25 bg-emerald-500/10 p-3">
                <p class="text-xs font-semibold text-emerald-200">Alterou o modelo, logo ou cores?</p>
                <p class="mt-1 text-xs leading-relaxed text-slate-400">Recarregue a arte com a configuração atual da sua marca, mantendo a mesma foto.</p>
                <button type="button" id="btn-recarregar-marca" class="mt-2 w-full rounded-lg border border-emerald-500/50 px-3 py-2 text-xs font-semibold text-emerald-200 hover:bg-emerald-500/15">↻ Recarregar modelo da minha marca</button>
              </div>
            <% } else { %>
              <p class="mt-3 rounded-lg border border-amber-500/20 bg-amber-500/10 p-3 text-xs text-amber-200">Para aplicar novamente sua marca, escolha outra imagem uma vez.</p>
            <% } %>

            <label class="mt-3 block cursor-pointer rounded-lg border border-dashed border-slate-600 px-3 py-2.5 text-center text-sm font-medium text-slate-300 hover:border-emerald-500 hover:text-emerald-200">
              Escolher outra imagem
              <input id="matter-image-input" type="file" accept="image/png,image/jpeg,image/webp" class="sr-only" />
            </label>

            <div id="matter-image-preview-wrap" class="mt-3 hidden">
              <img id="matter-image-preview" src="" alt="Pré-visualização da imagem escolhida" class="block max-h-72 w-full rounded-lg border border-slate-700 bg-slate-950 object-contain" />
              <p class="mt-2 text-xs text-slate-500">Esta é a foto original. Confirme para gerar a arte com título e marca.</p>
              <div class="mt-3 flex gap-2">
                <button type="button" id="btn-confirmar-imagem" class="flex-1 rounded-lg bg-emerald-500 px-3 py-2 text-xs font-semibold text-slate-950 hover:bg-emerald-400">Sim, usar esta imagem</button>
                <button type="button" id="btn-cancelar-imagem" class="rounded-lg border border-slate-600 px-3 py-2 text-xs text-slate-300 hover:border-slate-400">Cancelar</button>
              </div>
            </div>
          </div>
        <% } %>

        <div class="rounded-2xl border border-slate-800 bg-slate-900/60 p-4">
          <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Publicação</p>

          <label class="mt-3 block text-sm">
            <span class="text-slate-400">Página do Facebook</span>
            <select id="matter-page" class="mt-1.5 w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-white">
              <option value="">Carregando…</option>
            </select>
          </label>

          <label class="mt-3 block text-sm">
            <span class="text-slate-400">Tipo</span>
            <select id="matter-tipo" class="mt-1.5 w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-white">
              <option value="foto" <%= matter.tipo_publicacao !== 'texto' ? 'selected' : '' %>>Foto + legenda</option>
              <option value="texto" <%= matter.tipo_publicacao === 'texto' ? 'selected' : '' %>>Texto</option>
            </select>
          </label>

          <% if (canEdit) { %>
            <button type="button" id="btn-publicar" class="mt-4 w-full rounded-lg bg-[#1877F2] px-4 py-2.5 text-sm font-semibold text-white hover:bg-[#166FE5]">Publicar na Página</button>

            <div class="mt-4 border-t border-slate-800 pt-4">
              <label class="block text-xs text-slate-400">Agendar
                <input id="matter-schedule" type="datetime-local" class="mt-1.5 w-full rounded-lg border border-slate-700 bg-slate-950 px-2 py-2 text-xs text-slate-200" />
              </label>
              <button type="button" id="btn-agendar" class="mt-2 w-full rounded-lg border border-slate-600 px-3 py-2 text-xs text-slate-300 hover:border-slate-400">Agendar publicação</button>
            </div>
          <% } else if (canRepublish) { %>
            <% if (matter.published_at) { %>
              <p class="mt-3 text-xs text-slate-500">Publicada em <%= new Date(matter.published_at).toLocaleString('pt-BR') %></p>
            <% } %>
            <button type="button" id="btn-publicar" data-republicar="1" class="mt-4 w-full rounded-lg bg-[#1877F2] px-4 py-2.5 text-sm font-semibold text-white hover:bg-[#166FE5]">Republicar na Página</button>
            <p class="mt-1.5 text-[11px] leading-snug text-slate-500">Cria um novo post no Facebook com o texto e a arte atuais (não edita o post antigo).</p>
          <% } else if (matter.published_at) { %>
            <p class="mt-3 text-xs text-slate-500">Publicada em <%= new Date(matter.published_at).toLocaleString('pt-BR') %></p>
          <% } %>
        </div>
      </aside>
    </div>
  </main>

  <div id="publish-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-slate-950/85 p-6 backdrop-blur-sm" role="dialog" aria-modal="true" aria-labelledby="publish-modal-title">
    <div class="w-full max-w-sm rounded-2xl border border-slate-700 bg-slate-900 p-8 text-center shadow-xl shadow-black/40">
      <div id="publish-modal-spin" class="mx-auto h-12 w-12 animate-spin rounded-full border-2 border-[#1877F2]/30 border-t-[#1877F2]"></div>
      <div id="publish-modal-ok" class="mx-auto hidden flex h-12 w-12 items-center justify-center rounded-full bg-emerald-500/15 text-2xl text-emerald-300">✓</div>
      <h2 id="publish-modal-title" class="mt-5 text-lg font-semibold text-white">Publicando…</h2>
      <p id="publish-modal-text" class="mt-2 text-sm leading-relaxed text-slate-400">Enviando a matéria para a Página do Facebook.</p>
      <a id="publish-modal-link" href="#" target="_blank" rel="noopener" class="mt-4 hidden inline-block text-sm text-sky-400 hover:underline">Ver post no Facebook →</a>
    </div>
  </div>

  <script>
    window.__MATTER_EDIT__ = {
      id: <%= matter.id %>,
      pageId: <%= matter.facebook_page_id ? Number(matter.facebook_page_id) : 'null' %>,
      canEdit: <%= canEdit ? 'true' : 'false' %>,
      canRepublish: <%= canRepublish ? 'true' : 'false' %>,
      listUrl: '/minhas-materias',
    };
  </script>
  <script src="/js/materia-ia-editar.js"></script>
<%- include('partials/app-end') %>
