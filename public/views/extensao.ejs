<%- include('partials/app-start') %>
<%
  const mattersList = typeof matters !== 'undefined' && Array.isArray(matters) ? matters : [];
  const pagesList = typeof pages !== 'undefined' && Array.isArray(pages) ? pages : [];
  const filaCount = typeof naFila === 'number' ? naFila : 0;
  const statusLabels = {
    rascunho: 'Rascunho',
    pronto: 'Na fila',
    agendado: 'Agendada',
    erro: 'Erro',
  };
  const statusClass = {
    rascunho: 'bg-slate-800 text-slate-300',
    pronto: 'bg-sky-500/15 text-sky-300',
    agendado: 'bg-amber-500/15 text-amber-300',
    erro: 'bg-rose-500/15 text-rose-300',
  };
%>

  <main class="mx-auto max-w-5xl px-4 py-5 sm:px-6 sm:py-8">
    <div>
      <p class="text-xs font-semibold uppercase tracking-wider text-sky-400">Publicação alternativa</p>
      <h1 class="mt-1 text-2xl font-semibold text-white">Extensão de Publicação</h1>
      <p class="mt-2 max-w-2xl text-sm text-slate-400">
        Marque as matérias (texto / foto) que quer publicar, baixe a extensão e publique pela sessão do Facebook — sem Graph API.
      </p>
    </div>

    <div class="mt-5 rounded-xl border border-amber-500/30 bg-amber-500/10 px-4 py-3 text-sm text-amber-100">
      A extensão publica <strong>texto e foto</strong> no composer do Facebook. Vídeos/Reels continuam em
      <a href="/fila" class="underline hover:text-white">/fila</a> (Graph API).
    </div>

    <% if (success) { %><div class="mt-5 rounded-xl border border-emerald-500/30 bg-emerald-500/10 px-4 py-3 text-sm text-emerald-200"><%= success %></div><% } %>
    <% if (error) { %><div class="mt-5 rounded-xl border border-rose-500/30 bg-rose-500/10 px-4 py-3 text-sm text-rose-200"><%= error %></div><% } %>

    <section class="mt-7 rounded-2xl border border-slate-800 bg-slate-900/60 p-5">
      <div class="flex flex-wrap items-end justify-between gap-3">
        <div>
          <h2 class="text-base font-semibold text-white">1. Marcar postagens para a extensão</h2>
          <p class="mt-1 text-xs text-slate-500">
            Selecione as matérias · <%= mattersList.length %> disponíveis ·
            <span class="text-sky-300"><%= filaCount %> já na fila</span>
          </p>
        </div>
        <a href="/minhas-materias" class="text-xs text-sky-400 hover:underline">Ver todas as matérias →</a>
      </div>

      <% if (!pagesList.length) { %>
        <p class="mt-4 rounded-xl border border-dashed border-slate-700 px-4 py-6 text-center text-sm text-slate-400">
          Conecte uma Página em <a href="/paginas" class="text-sky-400 hover:underline">/paginas</a> antes de enfileirar.
        </p>
      <% } else if (!mattersList.length) { %>
        <p class="mt-4 rounded-xl border border-dashed border-slate-700 px-4 py-6 text-center text-sm text-slate-400">
          Nenhuma matéria para publicar.
          <a href="/conteudo" class="mt-2 block text-sky-400 hover:underline">Criar conteúdo →</a>
        </p>
      <% } else { %>
        <div class="mt-4 flex flex-wrap items-end gap-3">
          <label class="block min-w-[200px] flex-1 text-sm">
            <span class="text-slate-400">Página do Facebook</span>
            <select id="queue-page"
              class="mt-1.5 w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2.5 text-white focus:border-sky-500 focus:outline-none">
              <% pagesList.forEach((p) => { %>
                <option value="<%= p.id %>"><%= p.page_name %></option>
              <% }) %>
            </select>
          </label>
          <div class="flex flex-wrap gap-2">
            <button type="button" id="btn-queue-selected"
              class="rounded-lg bg-sky-500 px-4 py-2.5 text-sm font-semibold text-slate-950 hover:bg-sky-400">
              Enviar selecionadas para fila
            </button>
            <button type="button" id="btn-dequeue-selected"
              class="rounded-lg border border-slate-600 px-4 py-2.5 text-sm text-slate-300 hover:border-slate-400">
              Tirar da fila
            </button>
          </div>
        </div>

        <div class="mt-3 flex flex-wrap items-center gap-3 text-xs text-slate-500">
          <label class="inline-flex items-center gap-2 cursor-pointer">
            <input type="checkbox" id="check-all" class="rounded border-slate-600 bg-slate-950" />
            Selecionar todas
          </label>
          <span id="queue-status"></span>
        </div>

        <ul id="queue-list" class="mt-3 divide-y divide-slate-800 overflow-hidden rounded-xl border border-slate-800 bg-slate-950/40">
          <% mattersList.forEach((item) => {
            const st = item.status || 'rascunho';
            const preview = String(item.materia || '').replace(/\s+/g, ' ').trim();
            const tipo = item.tipo_publicacao === 'foto' ? 'Foto' : 'Texto';
          %>
            <li class="flex flex-wrap items-start gap-3 px-3 py-3 hover:bg-slate-900/60" data-id="<%= item.id %>">
              <label class="mt-1 flex shrink-0 cursor-pointer">
                <input type="checkbox" class="js-matter-check rounded border-slate-600 bg-slate-950"
                  value="<%= item.id %>"
                  data-status="<%= st %>" />
              </label>
              <% if (item.imagem_url) { %>
                <img src="<%= item.imagem_url %>" alt=""
                  class="h-14 w-14 shrink-0 rounded-lg object-cover border border-slate-800" />
              <% } else { %>
                <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-lg border border-slate-800 bg-slate-900 text-[10px] uppercase text-slate-600"><%= tipo %></div>
              <% } %>
              <div class="min-w-0 flex-1">
                <div class="flex flex-wrap items-center gap-2">
                  <span class="rounded-full px-2 py-0.5 text-[10px] font-medium <%= statusClass[st] || statusClass.rascunho %>"><%= statusLabels[st] || st %></span>
                  <span class="text-[10px] uppercase tracking-wide text-slate-600"><%= tipo %></span>
                  <% if (item.page_name) { %><span class="text-[11px] text-slate-600"><%= item.page_name %></span><% } %>
                </div>
                <a href="/materias-ia/<%= item.id %>" class="mt-1 block text-sm font-semibold text-white hover:text-sky-200">
                  <%= item.titulo || 'Sem título' %>
                </a>
                <% if (preview) { %>
                  <p class="mt-0.5 line-clamp-2 text-xs text-slate-500"><%= preview.slice(0, 160) %><%= preview.length > 160 ? '…' : '' %></p>
                <% } %>
              </div>
            </li>
          <% }) %>
        </ul>
      <% } %>
    </section>

    <section class="mt-6 rounded-2xl border border-slate-800 bg-slate-900/60 p-5">
      <h2 class="text-base font-semibold text-white">2. Gerar token</h2>
      <p class="mt-1 text-xs text-slate-500">O token completo só aparece uma vez. Guarde com segurança.</p>
      <form id="form-token" class="mt-4 flex flex-wrap items-end gap-3">
        <label class="block min-w-[220px] flex-1 text-sm">
          <span class="text-slate-400">Nome do dispositivo</span>
          <input name="nome_dispositivo" maxlength="150" value="Chrome — Extensão"
            class="mt-1.5 w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2.5 text-white focus:border-sky-500 focus:outline-none" />
        </label>
        <button type="submit" class="rounded-lg bg-sky-500 px-4 py-2.5 text-sm font-semibold text-slate-950 hover:bg-sky-400">Gerar token</button>
      </form>
      <div id="token-once" class="mt-4 hidden rounded-xl border border-emerald-500/30 bg-emerald-500/10 p-4">
        <p class="text-xs font-semibold uppercase tracking-wide text-emerald-300">Copie agora — não será mostrado de novo</p>
        <code id="token-value" class="mt-2 block break-all rounded-lg bg-slate-950 px-3 py-3 text-sm text-emerald-200"></code>
        <button type="button" id="btn-copy-token" class="mt-3 rounded-lg border border-emerald-500/40 px-3 py-1.5 text-xs text-emerald-200 hover:bg-emerald-500/15">Copiar token</button>
      </div>
      <p id="token-status" class="mt-3 text-sm text-slate-400"></p>
    </section>

    <section class="mt-6 rounded-2xl border border-slate-800 bg-slate-900/60 p-5">
      <h2 class="text-base font-semibold text-white">3. Dispositivos conectados</h2>
      <div id="tokens-list" class="mt-4 space-y-2">
        <% if (!tokens.length) { %>
          <p class="text-sm text-slate-500">Nenhum token gerado ainda.</p>
        <% } else { %>
          <% tokens.forEach((t) => { %>
            <div class="flex flex-wrap items-center justify-between gap-3 rounded-xl border border-slate-800 bg-slate-950/50 px-4 py-3 text-sm" data-token-id="<%= t.id %>">
              <div>
                <p class="font-medium text-white"><%= t.nome_dispositivo %></p>
                <p class="mt-0.5 text-xs text-slate-500">
                  Criado <%= t.criado_em ? new Date(t.criado_em).toLocaleString('pt-BR') : '—' %>
                  <% if (t.ultimo_uso_em) { %> · último uso <%= new Date(t.ultimo_uso_em).toLocaleString('pt-BR') %><% } %>
                  · <%= t.revogado_em ? 'revogado' : 'ativo' %>
                </p>
              </div>
              <% if (!t.revogado_em) { %>
                <button type="button" class="js-revoke rounded-lg border border-rose-500/40 px-3 py-1.5 text-xs text-rose-300 hover:bg-rose-500/15" data-id="<%= t.id %>">Revogar</button>
              <% } else { %>
                <span class="rounded-full bg-slate-800 px-2.5 py-1 text-[10px] uppercase text-slate-500">Revogado</span>
              <% } %>
            </div>
          <% }) %>
        <% } %>
      </div>
    </section>

    <section class="mt-6 rounded-2xl border border-slate-800 bg-slate-900/60 p-5">
      <h2 class="text-base font-semibold text-white">4. Baixar e instalar a extensão</h2>
      <p class="mt-1 text-sm text-slate-400">
        Baixe o ZIP no PC que vai publicar, descompacte e carregue a pasta no Chrome ou Edge.
      </p>
      <a href="/extensao/baixar"
        class="mt-4 inline-flex items-center gap-2 rounded-lg bg-sky-500 px-4 py-2.5 text-sm font-semibold text-slate-950 hover:bg-sky-400">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 3v12"/><path d="m7 10 5 5 5-5"/><path d="M5 21h14"/></svg>
        Baixar extensão (.zip)
      </a>
      <ol class="mt-5 list-decimal space-y-2 pl-5 text-sm text-slate-300">
        <li>Baixe e <strong>descompacte</strong> o ZIP (pasta <code class="text-sky-300">viralizeai-extensao-facebook</code>).</li>
        <li>Abra <code class="text-sky-300">chrome://extensions</code> → modo desenvolvedor → carregar a pasta.</li>
        <li>Cole o token e a URL: <code class="text-sky-300"><%= apiBase %></code></li>
        <li>Na extensão, marque as pendentes e publique (ou use automático).</li>
      </ol>
    </section>
  </main>

  <script src="/js/extensao.js"></script>
<%- include('partials/app-end') %>
