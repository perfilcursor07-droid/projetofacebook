<%- include('partials/app-start') %>

  <main class="mx-auto max-w-9xl px-4 py-10">
    <h1 class="text-2xl font-semibold text-white">Cookies do YouTube</h1>
    <p class="mt-2 text-slate-400">
      Quando a importação do YouTube falhar com "sessão expirada", envie aqui um novo arquivo de cookies.
      O sistema filtra automaticamente só os cookies do YouTube e salva no lugar certo.
    </p>

    <section class="mt-6 rounded-xl border border-slate-800 bg-slate-900/60 p-5">
      <h2 class="font-medium text-white">Status atual</h2>
      <div id="status-box" class="mt-3 text-sm text-slate-400">Carregando…</div>
      <button type="button" id="test-btn"
        class="mt-4 rounded-lg border border-slate-700 px-4 py-2 text-sm text-slate-200 hover:border-emerald-500 hover:text-emerald-300 disabled:opacity-50">
        Testar cookies agora
      </button>
      <p id="test-result" class="mt-3 text-sm"></p>
    </section>

    <section class="mt-6 rounded-xl border border-slate-800 bg-slate-900/60 p-5">
      <h2 class="font-medium text-white">Enviar novo arquivo</h2>
      <form id="upload-form" class="mt-4 space-y-3">
        <input type="file" name="arquivo" id="cookie-file" accept=".txt"
          class="w-full text-sm text-slate-300 file:mr-3 file:rounded-lg file:border-0 file:bg-slate-700 file:px-3 file:py-2 file:text-sm file:text-slate-100 hover:file:bg-slate-600" />
        <p class="text-xs text-slate-500">Ou cole o conteúdo do cookies.txt abaixo:</p>
        <textarea name="conteudo" id="cookie-text" rows="5" spellcheck="false"
          placeholder="# Netscape HTTP Cookie File&#10;.youtube.com&#9;TRUE&#9;/&#9;TRUE&#9;…"
          class="w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 font-mono text-xs text-slate-200 placeholder:text-slate-600 focus:border-emerald-500 focus:outline-none"></textarea>
        <button type="submit" id="upload-btn"
          class="rounded-lg bg-emerald-500 px-5 py-2.5 text-sm font-medium text-slate-950 hover:bg-emerald-400 disabled:opacity-50">
          Salvar cookies
        </button>
      </form>
      <p id="upload-status" class="mt-3 text-sm"></p>
      <p class="mt-2 text-xs text-amber-300/80">
        Segurança: pode enviar o export completo — o sistema descarta tudo que não for do youtube.com antes de salvar.
      </p>
    </section>

    <section class="mt-6 rounded-xl border border-slate-800 bg-slate-900/60 p-5">
      <h2 class="font-medium text-white">Passo a passo para gerar o cookies.txt</h2>
      <ol class="mt-4 list-decimal space-y-3 pl-5 text-sm text-slate-300">
        <li>
          Instale a extensão <strong class="text-white">Get cookies.txt LOCALLY</strong> no Chrome/Edge
          (formato Netscape).
        </li>
        <li>
          Abra uma <strong class="text-white">janela anônima</strong> (Ctrl+Shift+N) e permita a extensão nela
          (em <span class="font-mono text-xs">chrome://extensions</span> → detalhes → "Permitir em anônimo").
        </li>
        <li>
          Na janela anônima, entre em <span class="font-mono text-xs">youtube.com</span> e
          <strong class="text-white">faça login</strong> — de preferência com uma conta secundária, não a principal.
        </li>
        <li>
          Ainda logado, visite
          <span class="font-mono text-xs">https://www.youtube.com/robots.txt</span>
          (evita que o YouTube invalide os cookies na exportação).
        </li>
        <li>
          Clique na extensão e use <strong class="text-white">Export</strong> (site atual). Salve o arquivo
          <span class="font-mono text-xs">.txt</span>.
        </li>
        <li>
          <strong class="text-white">Feche a janela anônima sem deslogar</strong> e não use essa conta no
          navegador — se usar, os cookies expiram rápido.
        </li>
        <li>Envie o arquivo no formulário acima e clique em <strong class="text-white">Testar cookies agora</strong>.</li>
      </ol>
    </section>
  </main>

  <script>
    const statusBox = document.getElementById('status-box');
    const testBtn = document.getElementById('test-btn');
    const testResult = document.getElementById('test-result');
    const form = document.getElementById('upload-form');
    const uploadBtn = document.getElementById('upload-btn');
    const uploadStatus = document.getElementById('upload-status');

    function fmtDate(iso) {
      try { return new Date(iso).toLocaleString('pt-BR'); } catch { return iso; }
    }

    async function loadStatus() {
      try {
        const res = await fetch('/api/youtube-cookies/status');
        const data = await res.json();
        if (!data.configured) {
          statusBox.innerHTML = '<span class="text-amber-300">' + data.message + '</span>';
          return;
        }
        if (!data.exists) {
          statusBox.innerHTML = 'Nenhum arquivo salvo ainda em <span class="font-mono text-xs">' + data.path + '</span>.';
          return;
        }
        const auth = data.hasAuthCookies
          ? '<span class="text-emerald-400">sessão logada ✓</span>'
          : '<span class="text-rose-400">sem cookies de login — refaça a exportação logado</span>';
        statusBox.innerHTML =
          data.cookieCount + ' cookie(s) do YouTube · ' + auth +
          '<br>Atualizado em ' + fmtDate(data.updatedAt) +
          ' · <span class="font-mono text-xs">' + data.path + '</span>';
      } catch {
        statusBox.textContent = 'Erro ao carregar status.';
      }
    }

    testBtn.addEventListener('click', async () => {
      testBtn.disabled = true;
      testResult.className = 'mt-3 text-sm text-slate-400';
      testResult.textContent = 'Consultando o YouTube (pode levar ~20s)…';
      try {
        const res = await fetch('/api/youtube-cookies/test', { method: 'POST' });
        const data = await res.json();
        if (data.ok) {
          testResult.className = 'mt-3 text-sm text-emerald-400';
          testResult.textContent = '✓ ' + data.message + ' ("' + data.titulo + '")';
        } else {
          testResult.className = 'mt-3 text-sm text-rose-400';
          testResult.textContent = '✗ ' + (data.error || 'Falha no teste');
        }
      } catch {
        testResult.className = 'mt-3 text-sm text-rose-400';
        testResult.textContent = '✗ Erro de rede ao testar.';
      } finally {
        testBtn.disabled = false;
      }
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const file = document.getElementById('cookie-file').files[0];
      const text = document.getElementById('cookie-text').value.trim();
      if (!file && !text) {
        uploadStatus.className = 'mt-3 text-sm text-rose-400';
        uploadStatus.textContent = 'Escolha um arquivo ou cole o conteúdo.';
        return;
      }

      uploadBtn.disabled = true;
      uploadStatus.className = 'mt-3 text-sm text-slate-400';
      uploadStatus.textContent = 'Enviando…';

      try {
        let res;
        if (file) {
          const fd = new FormData();
          fd.append('arquivo', file);
          res = await fetch('/api/youtube-cookies', { method: 'POST', body: fd });
        } else {
          res = await fetch('/api/youtube-cookies', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ conteudo: text }),
          });
        }
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Falha ao salvar');
        uploadStatus.className = 'mt-3 text-sm text-emerald-400';
        uploadStatus.textContent = '✓ ' + data.message;
        form.reset();
        loadStatus();
      } catch (err) {
        uploadStatus.className = 'mt-3 text-sm text-rose-400';
        uploadStatus.textContent = '✗ ' + err.message;
      } finally {
        uploadBtn.disabled = false;
      }
    });

    loadStatus();
  </script>
<%- include('partials/app-end') %>
