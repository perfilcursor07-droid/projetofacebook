{
  "name": "clipador",
  "version": "1.0.0",
  "description": "Plataforma para buscar, cortar com IA e publicar vídeos no Facebook",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "migrate": "knex migrate:latest",
    "migrate:rollback": "knex migrate:rollback",
    "migrate:make": "knex migrate:make",
    "seed": "knex seed:run",
    "build:css": "tailwindcss -i ./src/assets/input.css -o ./public/css/app.css --minify",
    "watch:css": "tailwindcss -i ./src/assets/input.css -o ./public/css/app.css --watch"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.7",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "form-data": "^4.0.6",
    "knex": "^3.1.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.12.0",
    "youtube-dl-exec": "^3.1.9"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.17"
  }
}
